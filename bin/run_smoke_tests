#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MANIFEST_FILE="$ROOT_DIR/rails/app/lib/temples/manifest.yml"

if [ ! -f "$MANIFEST_FILE" ]; then
  echo "Manifest not found at $MANIFEST_FILE" >&2
  exit 1
fi

DEFAULT_FALLBACK_URL="${SMOKE_DEFAULT_BASE_URL:-http://localhost:3001}"
EXPECTED_STATUS="${SMOKE_EXPECTED_STATUS:-200}"

mapfile -t TEMPLES < <(ruby <<'RUBY' "$MANIFEST_FILE"
require "yaml"
file = ARGV.first
data = YAML.safe_load_file(file).fetch("temples")
data.each do |entry|
  puts [entry.fetch("slug"), entry["public_url"]].join("|")
end
RUBY
)

if [ "${#TEMPLES[@]}" -eq 0 ]; then
  echo "No temples defined in manifest." >&2
  exit 1
fi

FAILURES=0

for entry in "${TEMPLES[@]}"; do
  IFS="|" read -r slug public_url <<<"$entry"
  base_url="${SMOKE_BASE_URL:-${public_url:-$DEFAULT_FALLBACK_URL}}"
  api_url="${base_url%/}/api/v1/temples/${slug}"

  echo "Checking ${slug} at ${api_url}"
  status="$(curl -s -o /dev/null -w "%{http_code}" "$api_url" || true)"
  if [ "$status" = "$EXPECTED_STATUS" ]; then
    echo "  ✅ API reachable"
  else
    fallback_label=${status:-connection_error}
    echo "  ❌ Expected status ${EXPECTED_STATUS}, got ${fallback_label}"
    FAILURES=$((FAILURES + 1))
  fi
done

if [ "$FAILURES" -gt 0 ]; then
  echo "${FAILURES} smoke checks failed."
  exit 1
fi

echo "All smoke checks passed."
