#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_FALLBACK="$ROOT_DIR/.env.development"

usage() {
  cat <<'USAGE'
Usage: bin/load_temple_env <temple-slug> [-- <command...>]

Loads .env, .env.<env>, and /etc/default/<temple-slug>-env (when readable),
falling back to .env.development.
before running the provided command. When no command is supplied it simply prints which
file would be loaded so you can confirm the path before exporting any credentials.
USAGE
  exit 1
}

[[ $# -lt 1 ]] && usage

TEMPLE_SLUG="$1"
shift

COMMAND=()
if [[ $# -gt 0 ]]; then
  if [[ "$1" == "--" ]]; then
    shift
  fi
  COMMAND=("$@")
fi

CURRENT_ENV="${APP_ENV:-${RAILS_ENV:-development}}"
BASE_ENV="$ROOT_DIR/.env"
ENV_SPECIFIC="$ROOT_DIR/.env.${CURRENT_ENV}"
SYSTEM_ENV="/etc/default/${TEMPLE_SLUG}-env"

load_env_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    echo " -> $file"
    # shellcheck disable=SC1090
    source "$file"
    return 0
  fi
  return 1
}

echo "Loading environment for temple slug: ${TEMPLE_SLUG}"
set -a
load_env_file "$BASE_ENV" || true
load_env_file "$ENV_SPECIFIC" || true
if [[ -r "$SYSTEM_ENV" ]]; then
  load_env_file "$SYSTEM_ENV" || true
else
  echo "    (no readable ${SYSTEM_ENV} found, falling back to ${DEFAULT_FALLBACK})"
  load_env_file "$DEFAULT_FALLBACK" || true
fi
set +a
export TEMPLE_SLUG

if [[ ${#COMMAND[@]} -eq 0 ]]; then
  echo "Environment evaluated. Provide '-- <command>' to run something with these vars."
else
  exec "${COMMAND[@]}"
fi
