# Temple-specific environment template (no secrets)
# Copy flow:
#   1) copy values into local .env.development and production /etc/default/<slug>-env
#   2) fill credentials manually (never commit secrets)

# --- Identity ---
PROJECT_SLUG=__SLUG__
PROJECT_NAME=
PROJECT_MARKETING_ORIGIN=
PROJECT_ADMIN_ORIGIN=

# --- Runtime ---
RAILS_ENV=production
RACK_ENV=production
PUMA_PORT=3000

# --- Vue public site ---
VITE_TEMPLE_SLUG=__SLUG__
VITE_TEMPLE_LAYOUT=classic
VITE_TEMPLE_THEME=temple-1
VITE_API_BASE_URL=
VITE_MARKETING_ORIGIN=
VITE_MARKETING_ADMIN_ORIGIN=
GOOGLE_MAPS_API_KEY=

# --- Contact / email ---
DEV_EMAIL=jimmy.chuang@outlook.com
DEV_APP_NOTIFICATION_EMAIL=jimmy.chuang@outlook.com
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# --- Auth ---
JWT_SECRET_KEY=

# --- Database (PostgreSQL) ---
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=templemate_data
PGDATABASE_TEST=templemate_test
PGUSER=templemate_admin
PGPASSWORD=

# --- Payments core provider selector ---
PAYMENTS_PROVIDER=fake
PAYMENTS_IDEMPOTENCY_WINDOW_SECONDS=

# Stripe (sandbox/test)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# LINE Pay (sandbox)
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=
LINE_PAY_API_BASE=https://sandbox-api-pay.line.me
LINE_PAY_CONFIRM_BASE_URL=

# --- Expo/mobile ---
EXPO_PROJECT_SLUG=shengfukung-wenfu
EXPO_PROJECT_SCHEME=shengfukungwenfu
EXPO_ANDROID_PACKAGE=com.shengfukungwenfu.console.admin
EXPO_IOS_BUNDLE_IDENTIFIER=com.shengfukungwenfu.console.admin
EAS_PROJECT_ID=9bb5082f-2b35-4168-bcf7-5a09c61bd2e1

# --- Optional uploads ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Central auth (OAuth broker) ---
AUTH_BASE_URL=
AUTH_CLIENT_ID=
AUTH_CLIENT_SECRET=
AUTH_TENANT_SLUG=
