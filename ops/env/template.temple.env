# Temple-specific environment template (no secrets)
# Copy flow:
#   1) bin/init_temple_env <slug>
#   2) fill credentials manually in etc/default/<slug>.env
#   3) bin/push_temple_env <slug> <user@host>   (initial onboarding only)

# --- Identity ---
PROJECT_SLUG=__SLUG__
PROJECT_NAME=
PROJECT_MARKETING_ORIGIN=
PROJECT_ADMIN_ORIGIN=

# --- Vue public site ---
VITE_TEMPLE_SLUG=__SLUG__
VITE_TEMPLE_LAYOUT=classic
VITE_TEMPLE_THEME=temple-1
VITE_API_BASE_URL=
VITE_MARKETING_ORIGIN=
VITE_MARKETING_ADMIN_ORIGIN=

# --- Contact / email ---
DEV_EMAIL=
DEV_APP_NOTIFICATION_EMAIL=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# --- Payments core provider selector ---
PAYMENTS_PROVIDER=fake
PAYMENTS_IDEMPOTENCY_WINDOW_SECONDS=

# Stripe (sandbox/test)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# LINE Pay (sandbox)
LINE_PAY_CHANNEL_ID=
LINE_PAY_CHANNEL_SECRET=
LINE_PAY_API_BASE=https://sandbox-api-pay.line.me
LINE_PAY_CONFIRM_BASE_URL=

# --- Expo/mobile ---
EXPO_PROJECT_SLUG=
EXPO_PROJECT_SCHEME=
EXPO_ANDROID_PACKAGE=
EXPO_IOS_BUNDLE_IDENTIFIER=
EAS_PROJECT_ID=

# --- Optional uploads ---
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
