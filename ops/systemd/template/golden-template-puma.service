
# ops/systemd/golden-template.service
#
# Systemd unit template for the Puma web server.
#
# NOTE:
# - Replace the placeholder slug (Golden-Template) with `AppConstants::Project::SLUG` if you rename the stack.
# - Keep `EnvironmentFile=/etc/default/<slug>-env` in sync with the supplied `.env` helpers.
#
# [Unit]
# Description={{project_name}} Puma HTTP Server
# After=network.target
#
# [Service]
# Type=simple
# User=deploy
# WorkingDirectory=/home/jimmy1768_user/Projects/{{project_slug}}/rails
# EnvironmentFile=/etc/default/{{project_slug}}-env
# ExecStart=/usr/bin/bash -lc 'bundle exec puma -C config/puma.rb'
# Restart=always
#
# [Install]
# WantedBy=multi-user.target
