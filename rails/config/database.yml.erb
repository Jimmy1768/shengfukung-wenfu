default: &default
  adapter: postgresql
  encoding: unicode
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>
  timeout: 5000
  host: <%= ENV.fetch("PGHOST", "localhost") %>
  port: <%= ENV.fetch("PGPORT", 5432) %>
  username: <%= ENV.fetch("PGUSER", "golden_template_dev") %>
  password: <%= ENV["PGPASSWORD"] %>

development:
  <<: *default
  database: <%= ENV.fetch("PGDATABASE", "golden_template_dev") %>

test:
  <<: *default
  database: <%= ENV.fetch("PGDATABASE_TEST", "golden_template_test") %>

production:
  <<: *default
  database: <%= ENV.fetch("PGDATABASE", "golden_template_prod") %>
