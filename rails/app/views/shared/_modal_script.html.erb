<script>
  (() => {
    const ready = (fn) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fn);
      } else {
        fn();
      }
    };

    const hideModal = (modal) => {
      if (!modal) return;
      if (!modal.classList.contains('is-hidden')) {
        modal.classList.add('is-hidden');
      }
      modal.setAttribute('aria-hidden', 'true');
      modal.setAttribute('hidden', 'hidden');
    };

    const toggleModal = (key, show) => {
      if (!key) return;
      const modal = document.querySelector(`[data-modal-key="${key}"]`);
      if (!modal) return;
      if (show) {
        modal.classList.remove('is-hidden');
        modal.removeAttribute('hidden');
        modal.setAttribute('aria-hidden', 'false');
      } else {
        hideModal(modal);
      }
    };

    document.addEventListener('click', (event) => {
      const openTrigger = event.target.closest('[data-modal-trigger]');
      if (openTrigger) {
        event.preventDefault();
        toggleModal(openTrigger.getAttribute('data-modal-trigger'), true);
        return;
      }

      const closeTrigger = event.target.closest('[data-modal-close]');
      if (closeTrigger) {
        event.preventDefault();
        toggleModal(closeTrigger.getAttribute('data-modal-close'), false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      document.querySelectorAll('[data-modal-key]').forEach(hideModal);
    });

    ready(() => {
      const menus = Array.from(document.querySelectorAll('[data-profile-menu]'));
      if (!menus.length) return;

      const closeMenu = (menu) => {
        menu.classList.remove('is-open');
        const trigger = menu.querySelector('[data-profile-menu-trigger]');
        if (trigger) trigger.setAttribute('aria-expanded', 'false');
      };

      const openMenu = (menu) => {
        menus.forEach((other) => {
          if (other !== menu) closeMenu(other);
        });
        menu.classList.add('is-open');
        const trigger = menu.querySelector('[data-profile-menu-trigger]');
        if (trigger) trigger.setAttribute('aria-expanded', 'true');
      };

      document.addEventListener('click', (event) => {
        const trigger = event.target.closest('[data-profile-menu-trigger]');
        if (trigger) {
          event.preventDefault();
          const menu = trigger.closest('[data-profile-menu]');
          if (!menu) return;
          if (menu.classList.contains('is-open')) {
            closeMenu(menu);
          } else {
            openMenu(menu);
          }
          return;
        }

        if (event.target.closest('[data-profile-menu]')) {
          return;
        }

        menus.forEach(closeMenu);
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          menus.forEach(closeMenu);
        }
      });
    });
  })();
</script>
