<!DOCTYPE html>
<html data-theme="<%= Themes::DEFAULT_KEY %>">
  <head>
    <meta charset="utf-8" />
    <title><%= AppConstants::Project.name %> · Internal</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="/backend/assets/admin.css" />
  </head>
  <body class="admin-body admin-body--internal">
    <div class="admin-shell">
      <header class="admin-nav">
        <div class="nav-leading">
          <div class="brand">
            <span class="brand-name">Internal Tools</span>
          </div>
          <% if flash.any? %>
            <div class="admin-flash-tray">
              <% flash.each do |type, message| %>
                <div class="admin-flash admin-flash-<%= type %>"><%= message %></div>
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="nav-links">
          <%= link_to "Temple admin", admin_dashboard_path, class: "pill-link secondary" %>
        </div>
      </header>
      <div class="admin-layout admin-layout--public">
        <main class="admin-main">
          <%= yield %>
        </main>
      </div>
    </div>
    <%= render "shared/confirmation_modal", scope: :admin %>
  </body>
  <%= render "shared/form_validation_script" %>
  <%= render "shared/inline_validation_template" %>
  <%= render "shared/modal_script" %>
</html>
