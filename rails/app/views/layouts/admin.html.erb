<!DOCTYPE html>
<html data-theme="<%= @active_theme_key || Themes::DEFAULT_KEY %>">
  <head>
    <meta charset="utf-8" />
    <title><%= AppConstants::Project.name %> · Admin</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="/backend/assets/admin.css" />
  </head>
  <body class="admin-body">
    <div class="admin-shell">
      <header class="admin-nav">
        <div class="brand">
          <span class="brand-name"><%= AppConstants::Project.name %></span>
          <span class="brand-slug"><%= AppConstants::Project.slug %></span>
        </div>
        <% if admin_signed_in? %>
          <div class="nav-controls">
            <%= render "admin/shared/temple_switcher" %>
            <div class="language-selector">
              <%= form_with url: admin_locale_path,
                            scope: :locale_switch,
                            method: :post,
                            data: { turbo: false },
                            local: true do |form| %>
                <label class="language-label"><%= t("admin.language_selector.label") %></label>
                <div class="language-field">
                  <%= form.select :locale,
                                  admin_locale_options.map { |option| [option[:label], option[:value]] },
                                  { selected: current_admin_locale },
                                  class: "language-dropdown" %>
                  <%= form.submit t("admin.language_selector.apply"), class: "language-submit" %>
                </div>
              <% end %>
            </div>
            <div class="nav-links">
              <span class="nav-user-label"><%= t("admin.nav.signed_in_label") %></span>
              <span class="nav-user-name"><%= current_admin&.english_name || current_admin&.email %></span>
            </div>
          </div>
        <% end %>
      </header>
      <div class="admin-layout">
        <%= render "admin/shared/nav" %>
        <main class="admin-main">
          <% flash.each do |type, message| %>
            <div class="flash flash-<%= type %>"><%= message %></div>
          <% end %>
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
  <%= render "shared/modal_script" %>
</html>
