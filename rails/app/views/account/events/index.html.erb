<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.events.upcoming.eyebrow") %></p>
      <h2><%= t("account.events.upcoming.title") %></h2>
      <p><%= t("account.events.upcoming.subtitle") %></p>
    </div>
  </header>

  <div class="event-grid">
    <% @upcoming_events.each do |event| %>
      <article class="event-card">
        <p class="event-date"><%= event[:date] %></p>
        <h3><%= event[:title] %></h3>
        <p class="event-meta"><%= event[:location] %> · <%= event[:status] %></p>
        <p class="event-notes"><%= event[:description] || event[:notes] %></p>
      </article>
    <% end %>
  </div>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.events.past.eyebrow") %></p>
      <h2><%= t("account.events.past.title") %></h2>
      <p><%= t("account.events.past.subtitle") %></p>
    </div>
  </header>

  <div class="timeline">
    <% @past_events.each do |event| %>
      <div class="timeline-entry">
        <div class="timeline-dot"></div>
        <div>
          <p class="timeline-date"><%= event[:date] %></p>
          <h3><%= event[:title] %></h3>
          <% if event[:gallery] %>
            <%= link_to t("account.events.past.gallery_link"), "#", class: "pill-link secondary" %>
          <% else %>
            <p class="muted"><%= t("account.events.past.gallery_pending") %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
