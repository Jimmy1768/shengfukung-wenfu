<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.events.offerings.eyebrow") %></p>
      <h2><%= t("account.events.offerings.title") %></h2>
      <p><%= t("account.events.offerings.subtitle") %></p>
    </div>
  </header>

  <% if @offerings.any? %>
    <div class="event-grid">
      <% @offerings.each do |event| %>
        <article class="event-card">
          <p class="event-date"><%= event[:date] %></p>
          <h3><%= event[:title] %></h3>
          <p class="event-meta">
            <%= event[:location] %> ·
            <%= t("account.events.statuses.#{event[:status]}", default: event[:status].to_s.humanize) %>
          </p>
          <% if event[:description].present? %>
            <p class="event-notes"><%= event[:description] %></p>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="account-empty"><%= t("account.events.offerings.empty") %></div>
  <% end %>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.events.gatherings.eyebrow") %></p>
      <h2><%= t("account.events.gatherings.title") %></h2>
      <p><%= t("account.events.gatherings.subtitle") %></p>
    </div>
  </header>

  <% if @gatherings.any? %>
    <div class="event-grid">
      <% @gatherings.each do |event| %>
        <article class="event-card">
          <p class="event-date"><%= event[:date] %></p>
          <h3><%= event[:title] %></h3>
          <p class="event-meta">
            <%= event[:location] %> ·
            <%= t("account.events.statuses.#{event[:status]}", default: event[:status].to_s.humanize) %>
          </p>
          <% if event[:description].present? %>
            <p class="event-notes"><%= event[:description] %></p>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="account-empty"><%= t("account.events.gatherings.empty") %></div>
  <% end %>
</section>

<% if @offerings.blank? && @gatherings.blank? %>
  <section class="account-section">
    <div class="account-empty"><%= t("account.events.empty_state") %></div>
  </section>
<% end %>
