<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.dashboard.intro.eyebrow") %></p>
      <h2><%= t("account.dashboard.intro.greeting", name: current_user.native_name.presence || current_user.english_name.presence || current_user.email) %></h2>
      <p><%= t("account.dashboard.intro.body") %></p>
    </div>
  </header>

  <div class="quick-links">
    <% @quick_actions.each do |action| %>
      <%= link_to action[:label], action[:url], class: "quick-link-card" %>
    <% end %>
    <%= link_to t("account.dashboard.quick_actions.contact"), "#", class: "quick-link-card support-link", data: { turbo_confirm: t("account.dashboard.quick_actions.contact_confirm") } %>
  </div>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.dashboard.registrations.eyebrow") %></p>
      <h2><%= t("account.dashboard.registrations.title") %></h2>
      <p><%= t("account.dashboard.registrations.subtitle") %></p>
    </div>
    <%= link_to t("account.dashboard.registrations.link"), account_registrations_path, class: "pill-link secondary" %>
  </header>

  <% if @registrations.any? %>
    <div class="event-grid">
      <% @registrations.each do |registration| %>
        <article class="event-card">
            <p class="event-date"><%= l(registration.created_at, format: :short) rescue registration.created_at.strftime("%Y/%m/%d") %></p>
            <h3><%= registration.temple_offering&.title || registration.reference_code %></h3>
            <p class="event-meta"><%= t("account.dashboard.payment_statuses.#{registration.payment_status}", default: registration.payment_status) %></p>
          <p class="event-notes"><%= t("account.dashboard.registrations.registrant_label") %>：<%= registration.registrant_name %></p>
          <p class="event-notes"><%= t("account.dashboard.registrations.certificate_label") %>：<%= registration.certificate_number.presence || t("account.dashboard.registrations.certificate_pending") %></p>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="muted"><%= t("account.dashboard.registrations.empty") %></p>
  <% end %>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.dashboard.certificates.eyebrow") %></p>
      <h2><%= t("account.dashboard.certificates.title") %></h2>
      <p><%= t("account.dashboard.certificates.subtitle") %></p>
    </div>
  </header>

  <% if @certificates.any? %>
    <div class="timeline">
      <% @certificates.each do |registration| %>
        <div class="timeline-entry">
          <div class="timeline-dot"></div>
          <div>
            <p class="timeline-date"><%= registration.updated_at.strftime("%Y/%m/%d") %></p>
            <h3><%= registration.temple_offering&.title || t("account.dashboard.certificates.offering_fallback") %></h3>
            <p class="muted"><%= t("account.dashboard.certificates.number_label") %>：<%= registration.certificate_number %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="muted"><%= t("account.dashboard.certificates.empty") %></p>
  <% end %>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.dashboard.payments.eyebrow") %></p>
      <h2><%= t("account.dashboard.payments.title") %></h2>
      <p><%= t("account.dashboard.payments.subtitle") %></p>
    </div>
    <%= link_to t("account.dashboard.payments.link"), account_payments_path, class: "pill-link secondary" %>
  </header>

  <% if @recent_payments.any? %>
    <div class="table-scroll">
      <table class="payment-table">
        <thead>
          <tr>
            <th><%= t("account.dashboard.payments.table_headers.reference") %></th>
            <th><%= t("account.dashboard.payments.table_headers.offering") %></th>
            <th><%= t("account.dashboard.payments.table_headers.amount") %></th>
            <th><%= t("account.dashboard.payments.table_headers.method") %></th>
            <th><%= t("account.dashboard.payments.table_headers.status") %></th>
            <th><%= t("account.dashboard.payments.table_headers.download") %></th>
          </tr>
        </thead>
        <tbody>
          <% @recent_payments.each do |payment| %>
            <tr>
              <td><%= payment.external_reference.presence || payment.temple_event_registration&.reference_code || payment.id %></td>
              <td><%= payment.temple_event_registration&.temple_offering&.title || "—" %></td>
              <td><%= Currency::Symbols.format_amount(payment.amount_cents, payment.currency) %></td>
              <td><%= t("account.dashboard.payment_methods.#{payment.payment_method}", default: payment.payment_method.titleize) %></td>
              <td><span class="status-pill status-<%= payment.status %>"><%= t("account.dashboard.payment_statuses.#{payment.status}", default: payment.status) %></span></td>
              <td>
                <% if payment.payment_method == "line_pay" %>
                  <span class="line-pay-placeholder" title="<%= t("account.dashboard.payments.line_pay_title") %>"><%= t("account.dashboard.payments.line_pay_label") %></span>
                <% else %>
                  <span class="muted"><%= t("account.dashboard.payments.paper_hint") %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t("account.dashboard.payments.empty") %></p>
  <% end %>
</section>
