<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.profile.header.eyebrow") %></p>
      <h2><%= t("account.profile.header.title") %></h2>
      <p><%= t("account.profile.header.subtitle") %></p>
    </div>
    <%= link_to t("account.profile.header.edit"), edit_account_profile_path, class: "pill-link primary" %>
  </header>

  <div class="profile-summary">
    <div>
      <span class="label"><%= t("account.profile.summary.english_name") %></span>
      <p><%= current_user.english_name.presence || t("account.profile.summary.not_provided") %></p>
    </div>
    <div>
      <span class="label"><%= t("account.profile.summary.native_name") %></span>
      <p><%= current_user.native_name.presence || t("account.profile.summary.not_provided") %></p>
    </div>
    <div>
      <span class="label"><%= t("account.profile.summary.phone") %></span>
      <p><%= current_user.metadata&.dig("phone") || t("account.profile.summary.not_provided") %></p>
    </div>
    <div>
      <span class="label"><%= t("account.profile.summary.city") %></span>
      <p><%= current_user.metadata&.dig("city") || t("account.profile.summary.not_provided") %></p>
    </div>
  </div>

  <div class="profile-notes">
    <span class="label"><%= t("account.profile.summary.notes") %></span>
    <p><%= current_user.metadata&.dig("notes").presence || t("account.profile.summary.no_notes") %></p>
  </div>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.profile.dependents.eyebrow") %></p>
      <h2><%= t("account.profile.dependents.title") %></h2>
      <p><%= t("account.profile.dependents.subtitle") %></p>
    </div>
    <%= link_to t("account.profile.dependents.add"), new_account_dependent_path, class: "pill-link primary" %>
    <%= link_to t("account.profile.dependents.support"), "#", class: "pill-link secondary", data: { turbo_confirm: t("account.profile.dependents.support_confirm") } %>
  </header>

  <% if @dependents.any? %>
    <div class="dependent-grid">
      <% @dependents.each do |link| %>
        <% dependent = link.dependent %>
        <article class="dependent-card">
          <div>
            <h3><%= dependent.english_name %></h3>
            <% if dependent.native_name.present? %>
              <p class="muted"><%= dependent.native_name %></p>
            <% end %>
            <p class="muted"><%= t("account.profile.dependents.relationship") %>：<%= link.relationship_label.presence || dependent.relationship_label || "—" %></p>
            <p class="muted"><%= t("account.profile.dependents.birthdate") %>：<%= dependent.birthdate&.strftime("%Y/%m/%d") || "—" %></p>
            <p class="muted"><%= t("account.profile.dependents.phone") %>：<%= dependent.metadata["phone"].presence || "—" %></p>
            <p class="muted"><%= t("account.profile.dependents.email") %>：<%= dependent.metadata["email"].presence || "—" %></p>
          </div>
          <div class="dependent-actions">
            <%= link_to t("account.profile.dependents.edit"), edit_account_dependent_path(link), class: "pill-link secondary" %>
            <%= button_to t("account.profile.dependents.delete"), account_dependent_path(link), method: :delete, data: { turbo_confirm: t("account.profile.dependents.delete_confirm") }, class: "pill-link danger" %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="muted"><%= t("account.profile.dependents.empty") %></p>
  <% end %>
</section>
