<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.profile.edit.eyebrow") %></p>
      <h2><%= t("account.profile.edit.title") %></h2>
      <p><%= t("account.profile.edit.subtitle") %></p>
    </div>
  </header>

  <%= form_with model: @form, url: account_profile_path, method: :put, class: "profile-form" do |f| %>
    <%= render "shared/form_errors", form: @form %>
    <div class="single-row-grid">
      <div class="field">
        <%= f.label :native_name, t("account.profile.summary.native_name") %>
        <%= f.text_field :native_name %>
      </div>
      <div class="field">
        <%= f.label :english_name, t("account.profile.summary.english_name") %>
        <%= f.text_field :english_name %>
      </div>
      <div class="field">
        <%= f.label :phone, t("account.profile.summary.phone") %>
        <%= f.text_field :phone %>
      </div>
      <div class="field">
        <%= f.label :city, t("account.profile.summary.city") %>
        <%= f.text_field :city %>
      </div>
    </div>

    <div class="field">
      <%= f.label :notes, t("account.profile.summary.notes") %>
      <%= f.text_area :notes, rows: 3 %>
    </div>

    <div class="form-actions">
      <%= f.submit t("account.profile.edit.save"), class: "btn btn-primary" %>
      <%= link_to t("account.profile.edit.cancel"), account_profile_path, class: "btn btn-secondary" %>
    </div>
  <% end %>
</section>
