<% registration_form = @registration_form || Account::RegistrationForm.new %>
<% oauth_links = oauth_provider_links %>

<section class="card login-card">
  <header>
    <h1><%= t("account.sessions.new.heading", temple: current_temple&.name || AppConstants::Project.name) %></h1>
    <p><%= t("account.sessions.new.subtitle") %></p>
  </header>

  <div class="login-grid">
    <div class="login-credentials field-panel register-panel register-social">
      <div class="login-panel-head">
        <h2 class="login-subhead"><%= t("account.sessions.new.social.title") %></h2>
        <p class="muted"><%= t("account.sessions.new.social.subtitle") %></p>
      </div>
      <% if oauth_links.any? %>
        <div class="oauth-button-grid">
          <% oauth_links.each do |provider| %>
            <%= link_to provider[:path], class: "btn btn-secondary oauth-btn" do %>
              <% if provider[:icon_path].present? %>
                <%= image_tag provider[:icon_path], alt: "", class: "oauth-icon", width: 28, height: 28 %>
              <% end %>
              <span><%= provider[:label] %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted"><%= t("account.sessions.new.social.empty") %></p>
      <% end %>
    </div>

    <div class="login-actions field-panel register-panel register-email">
      <div class="login-panel-head">
        <h2 class="login-subhead"><%= t("account.sessions.new.email.title") %></h2>
        <p class="muted"><%= t("account.sessions.new.email.subtitle") %></p>
      </div>
      <%= form_with url: account_sessions_path, scope: :session, local: true, class: "login-form" do |f| %>
        <div class="form-field">
          <%= f.label :email, t("account.sessions.new.email.email_label") %>
          <%= f.email_field :email, required: true, autofocus: true, value: params.dig(:session, :email),
            placeholder: "you@example.com" %>
        </div>
        <div class="form-field">
          <%= f.label :password, t("account.sessions.new.email.password_label") %>
          <%= f.password_field :password, required: true, placeholder: "••••••••" %>
        </div>
        <%= f.submit t("account.sessions.new.email.submit"), class: "btn btn-primary" %>
      <% end %>
      <p class="muted">
        <%= link_to t("account.sessions.new.forgot_password"), new_password_path %>
      </p>
      <p class="muted">
        <%= t("account.sessions.new.register_prompt") %>
        <button type="button" class="btn btn-secondary" data-modal-trigger="account-register-modal">
          <%= t("account.sessions.new.register_button") %>
        </button>
      </p>
    </div>
  </div>
</section>

<%= render "shared/modal_panel",
  title: t("account.signups.modal.title"),
  modal_key: "account-register-modal",
  open: @show_registration_modal,
  close_label: t("account.signups.modal.close_label") do %>
  <%= render "shared/form_errors", form: registration_form %>
  <%= render "account/signups/form", form: registration_form %>
<% end %>
