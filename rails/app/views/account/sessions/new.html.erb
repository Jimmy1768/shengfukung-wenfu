<% registration_form = @registration_form || Account::RegistrationForm.new %>
<% oauth_links = oauth_provider_links %>

<section class="card login-card">
  <header>
    <p class="eyebrow">Account</p>
    <h1>Welcome back</h1>
    <p>Choose a connected provider or continue with email.</p>
  </header>

  <div class="login-grid">
    <div class="login-credentials field-panel register-panel register-social">
      <div class="login-panel-head">
        <h2 class="login-subhead">Social sign in</h2>
        <p class="muted">Tap a provider to continue instantly.</p>
      </div>
      <% if oauth_links.any? %>
        <div class="oauth-button-grid">
          <% oauth_links.each do |provider| %>
            <%= link_to "/auth/#{provider[:strategy]}", class: "btn btn-secondary oauth-btn" do %>
              <% if provider[:icon_path].present? %>
                <img src="<%= provider[:icon_path] %>" alt="" class="oauth-icon" />
              <% end %>
              <span><%= provider[:label] %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted">OAuth providers are not configured yet.</p>
      <% end %>
    </div>

    <div class="login-actions field-panel register-panel register-email">
      <div class="login-panel-head">
        <h2 class="login-subhead">Email sign in</h2>
        <p class="muted">Use your password instead.</p>
      </div>
      <%= form_with url: account_sessions_path, scope: :session, local: true, class: "login-form" do |f| %>
        <div class="form-field">
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, required: true, autofocus: true, value: params.dig(:session, :email),
            placeholder: "you@example.com" %>
        </div>
        <div class="form-field">
          <%= f.label :password, "Password" %>
          <%= f.password_field :password, required: true, placeholder: "••••••••" %>
        </div>
        <%= f.submit "Sign in", class: "btn btn-primary" %>
      <% end %>
      <p class="muted">
        <%= link_to "Forgot your password?", new_password_path %>
      </p>
      <p class="muted">
        Prefer email onboarding?
        <button type="button" class="btn btn-secondary" data-modal-trigger="account-register-modal">
          Create account
        </button>
      </p>
    </div>
  </div>
</section>

<%= render "shared/modal_panel",
  title: "Create your account",
  modal_key: "account-register-modal",
  open: @show_registration_modal,
  close_label: "Close create account modal" do %>
  <%= render "shared/form_errors", form: registration_form %>
  <%= render "account/registrations/form", form: registration_form %>
<% end %>
