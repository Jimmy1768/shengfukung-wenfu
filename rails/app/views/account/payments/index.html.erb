<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow">付款紀錄</p>
      <h2>LINE Pay 收據</h2>
      <p>完整交易紀錄會在 LINE Pay 接上後自動同步，此處為示範資料。</p>
    </div>
  </header>

  <div class="table-scroll">
    <table class="payment-table">
      <thead>
        <tr>
          <th>編號</th>
          <th>項目</th>
          <th>金額</th>
          <th>狀態</th>
          <th>日期</th>
          <th>方式</th>
        </tr>
      </thead>
      <tbody>
        <% @entries.each do |entry| %>
          <tr>
            <td><%= entry[:code] %></td>
            <td><%= entry[:title] %></td>
            <td>$<%= entry[:amount] %></td>
            <td><span class="status-pill status-<%= entry[:status] %>"><%= entry[:status] %></span></td>
            <td><%= entry[:date] %></td>
            <td><%= entry[:method] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
