<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.payments_index.header.eyebrow") %></p>
      <h2><%= t("account.payments_index.header.title") %></h2>
      <p><%= t("account.payments_index.header.subtitle") %></p>
    </div>
  </header>

  <% if @payments.any? %>
    <div class="table-scroll">
      <table class="payment-table">
        <thead>
          <tr>
            <th><%= t("account.payments_index.table_headers.reference") %></th>
            <th><%= t("account.payments_index.table_headers.offering") %></th>
            <th><%= t("account.payments_index.table_headers.amount") %></th>
            <th><%= t("account.payments_index.table_headers.status") %></th>
            <th><%= t("account.payments_index.table_headers.date") %></th>
            <th><%= t("account.payments_index.table_headers.method") %></th>
            <th><%= t("account.payments_index.table_headers.registrant") %></th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr>
              <td><%= payment.external_reference.presence || payment.temple_event_registration&.reference_code || payment.id %></td>
              <td><%= payment.temple_event_registration&.temple_offering&.title || "—" %></td>
              <td><%= Currency::Symbols.format_amount(payment.amount_cents, payment.currency) %></td>
              <td><span class="status-pill status-<%= payment.status %>"><%= t("account.dashboard.payment_statuses.#{payment.status}", default: payment.status) %></span></td>
              <td><%= (payment.processed_at || payment.created_at).strftime("%Y/%m/%d") %></td>
              <td>
                <span><%= t("account.dashboard.payment_methods.#{payment.payment_method}", default: payment.payment_method.titleize) %></span>
                <% if payment.payment_method == "line_pay" %>
                  <span class="line-pay-placeholder" title="<%= t("account.dashboard.payments.line_pay_title") %>"><%= t("account.dashboard.payments.line_pay_label") %></span>
                <% end %>
              </td>
              <td><%= payment.temple_event_registration&.registrant_name || current_user.native_name.presence || current_user.english_name.presence || current_user.email %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t("account.payments_index.empty") %></p>
  <% end %>
</section>
