<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.registrations.index.eyebrow") %></p>
      <h2><%= t("account.registrations.index.title") %></h2>
      <p><%= t("account.registrations.index.subtitle") %></p>
    </div>
  </header>

  <% if @registrations.any? %>
    <div class="table-scroll">
      <table class="payment-table">
        <thead>
          <tr>
            <th><%= t("account.registrations.index.table.reference") %></th>
            <th><%= t("account.registrations.index.table.offering") %></th>
            <th><%= t("account.registrations.index.table.registrant") %></th>
            <th><%= t("account.registrations.index.table.status") %></th>
            <th><%= t("account.registrations.index.table.certificate") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @registrations.each do |registration| %>
            <tr>
              <td><%= registration.reference_code %></td>
              <td><%= registration.offering&.try(:title) || registration.reference_code %></td>
              <td><%= registration.registrant_name %></td>
              <td><span class="status-pill status-<%= registration.payment_status %>"><%= t("account.dashboard.payment_statuses.#{registration.payment_status}", default: registration.payment_status) %></span></td>
              <td><%= registration.certificate_number.presence || t("account.registrations.index.table.certificate_pending") %></td>
              <td>
                <%= link_to t("account.registrations.index.actions.view"), account_registration_path(registration), class: "pill-link" %>
                <%= link_to t("account.registrations.index.actions.edit"), edit_account_registration_path(registration), class: "pill-link secondary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t("account.registrations.index.empty") %></p>
  <% end %>
</section>
