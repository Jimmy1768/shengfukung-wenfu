<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.registrations.new.eyebrow") %></p>
      <h2><%= @offering.title %></h2>
      <p><%= t("account.registrations.new.subtitle") %></p>
    </div>
  </header>

  <article class="card">
    <dl class="detail-list">
      <div>
        <dt><%= t("account.registrations.new.details.temple") %></dt>
        <dd><%= @offering.temple.name %></dd>
      </div>
      <div>
        <dt><%= t("account.registrations.new.details.price") %></dt>
        <dd><%= Currency::Symbols.format_amount(@offering.price_cents, @offering.currency) %></dd>
      </div>
      <% if @offering.respond_to?(:starts_on) && @offering.starts_on.present? %>
        <div>
          <dt><%= t("account.registrations.new.details.date") %></dt>
          <dd><%= @offering.starts_on %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <%= render "shared/form_errors", form: @form %>

  <%= form_with model: @form,
    url: account_registrations_path(offering: @offering.slug, account_action: @account_action),
    local: true,
    class: "account-form account-registration-form" do |f| %>
    <div class="form-grid">
      <div class="form-field">
        <%= f.label :quantity, t("account.registrations.new.fields.quantity") %>
        <%= f.number_field :quantity, min: 1, max: 10, required: true %>
      </div>
      <div class="form-field">
        <%= f.label :contact_name, t("account.registrations.new.fields.contact_name") %>
        <%= f.text_field :contact_name, required: true %>
      </div>
      <div class="form-field">
        <%= f.label :contact_phone, t("account.registrations.new.fields.contact_phone") %>
        <%= f.telephone_field :contact_phone %>
      </div>
      <div class="form-field">
        <%= f.label :contact_email, t("account.registrations.new.fields.contact_email") %>
        <%= f.email_field :contact_email %>
      </div>
      <div class="form-field form-field--full">
        <%= f.label :household_notes, t("account.registrations.new.fields.household_notes") %>
        <%= f.text_area :household_notes, rows: 2 %>
      </div>
      <div class="form-field">
        <%= f.label :arrival_window, t("account.registrations.new.fields.arrival_window") %>
        <%= f.text_field :arrival_window, placeholder: "09:00" %>
      </div>
      <div class="form-field form-field--full">
        <%= f.label :ceremony_notes, t("account.registrations.new.fields.ceremony_notes") %>
        <%= f.text_area :ceremony_notes, rows: 3 %>
      </div>
    </div>
    <%= f.submit t("account.registrations.new.submit"), class: "btn btn-primary" %>
  <% end %>

  <p class="muted">
    <%= t(
      "account.registrations.new.after_submit_html",
      link: link_to(t("account.registrations.new.after_submit_link"), account_registrations_path)
    ).html_safe %>
  </p>
</section>
