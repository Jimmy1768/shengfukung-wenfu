<section class="account-section">
  <% gathering_registration = @offering.is_a?(TempleGathering) %>
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.registrations.new.eyebrow") %></p>
      <h2><%= @offering.title %></h2>
      <p><%= t("account.registrations.new.subtitle") %></p>
    </div>
  </header>

  <article class="card">
    <dl class="detail-list">
      <div>
        <dt><%= t("account.registrations.new.details.temple") %></dt>
        <dd><%= @offering.temple.name %></dd>
      </div>
      <div>
        <dt><%= t("account.registrations.new.details.price") %></dt>
        <dd><%= Currency::Symbols.format_amount(@offering.price_cents, @offering.currency) %></dd>
      </div>
      <% if @offering.respond_to?(:starts_on) && @offering.starts_on.present? %>
        <div>
          <dt><%= t("account.registrations.new.details.date") %></dt>
          <dd><%= @offering.starts_on %></dd>
        </div>
      <% end %>
      <% if (@offering.respond_to?(:start_time) && @offering.start_time.present?) || (@offering.respond_to?(:end_time) && @offering.end_time.present?) %>
        <% start_time = @offering.respond_to?(:start_time) ? @offering.start_time&.strftime("%H:%M") : nil %>
        <% end_time = @offering.respond_to?(:end_time) ? @offering.end_time&.strftime("%H:%M") : nil %>
        <div>
          <dt><%= t("account.registrations.new.details.time") %></dt>
          <dd><%= [start_time, end_time].compact.join(" - ") %></dd>
        </div>
      <% end %>
    </dl>
  </article>

  <%= render "shared/form_errors", form: @form %>

  <% if @existing_registration.present? %>
    <%= render "registrant_picker",
      form: @form,
      offering: @offering,
      dependents: @dependents,
      account_action: @account_action %>

    <div class="registrant-existing-card">
      <p class="hint"><%= t("account.registrations.new.fields.already_registered_detail") %></p>
      <%= render "existing_form", form: @metadata_form, registration: @existing_registration %>
    </div>
  <% else %>
    <%= render "registrant_picker",
      form: @form,
      offering: @offering,
      dependents: @dependents,
      account_action: @account_action %>

    <div class="registrant-existing-card registrant-new-card">
      <%= form_with model: @form,
        url: account_registrations_path(offering: @offering.slug, account_action: @account_action),
        local: true,
        class: "form-stack form-stack--inline" do |f| %>
        <%= hidden_field_tag :registrant_scope, @form.registrant_scope, id: nil %>
        <%= hidden_field_tag :dependent_id, @form.dependent_id, id: nil %>

        <% if @form.registrant_scope.blank? %>
          <p class="hint registrant-form-hint"><%= t("account.registrations.new.fields.select_registrant_hint") %></p>
        <% else %>
          <div class="form-grid">
            <div class="form-field">
              <%= f.label :quantity, t("account.registrations.new.fields.quantity") %>
              <%= f.number_field :quantity, min: 1, max: 10, required: true %>
            </div>
            <div class="form-field">
              <%= f.label :contact_name, t("account.registrations.form.contact_name") %>
              <%= f.text_field :contact_name, required: true %>
            </div>
            <div class="form-field">
              <%= f.label :contact_phone, t("account.registrations.form.contact_phone") %>
              <%= f.telephone_field :contact_phone %>
            </div>
            <div class="form-field">
              <%= f.label :contact_email, t("account.registrations.form.contact_email") %>
              <%= f.email_field :contact_email %>
            </div>
            <div class="form-field form-field--full">
              <%= f.label :household_notes, t("account.registrations.form.household_notes") %>
              <%= f.text_area :household_notes, rows: 3 %>
            </div>
            <% unless gathering_registration %>
              <div class="form-field">
                <%= f.label :arrival_window, t("account.registrations.form.arrival_window") %>
                <%= f.text_field :arrival_window, placeholder: t("account.registrations.form.arrival_placeholder") %>
              </div>
              <div class="form-field form-field--full">
                <%= f.label :ceremony_notes, t("account.registrations.form.ceremony_notes") %>
                <%= f.text_area :ceremony_notes, rows: 3 %>
              </div>
            <% end %>
          </div>
          <%= f.submit t("account.registrations.new.submit"), class: "btn btn-primary w-100" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>
