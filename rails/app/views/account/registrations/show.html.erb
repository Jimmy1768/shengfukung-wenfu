<section class="account-section">
  <% gathering_registration = @registration.registrable_type == "TempleGathering" %>
  <% free_gathering = gathering_registration && @registration.no_payment_required? %>
  <% status_key = @registration.payment_status_for_display %>
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.registrations.show.eyebrow") %></p>
      <h2><%= @registration.offering&.try(:title) || @registration.reference_code %></h2>
      <p><%= t("account.registrations.show.subtitle") %></p>
    </div>
    <% if registration_lifecycle_policy.gathering_editable? %>
      <%= link_to t("account.registrations.show.edit"), edit_account_registration_path(@registration), class: "pill-link" %>
    <% end %>
    <% if open_assistance_request_for(@registration) %>
      <span class="pill-link secondary"><%= t("account.assistance_requests.status.open") %></span>
    <% else %>
      <%= button_to t("account.assistance_requests.actions.request"),
        account_assistance_requests_path,
        method: :post,
        params: {
          account_assistance_request: {
            registration_id: @registration.id,
            channel: "registration_detail"
          }
        },
        class: "pill-link danger" %>
    <% end %>
  </header>

  <dl class="detail-list registration-summary-list">
    <div>
      <dt><%= t("account.registrations.show.registrant") %></dt>
      <dd><%= @registration.registrant_name %></dd>
    </div>
    <div>
      <dt><%= t("account.registrations.show.certificate") %></dt>
      <dd><%= @registration.certificate_number.presence || t("account.registrations.show.certificate_pending") %></dd>
    </div>
    <div>
      <dt><%= t("account.registrations.show.status") %></dt>
      <dd><span class="status-pill status-<%= status_key %>"><%= t("account.dashboard.payment_statuses.#{status_key}", default: status_key.to_s.humanize) %></span></dd>
    </div>
    <div>
      <% if free_gathering %>
        <dt><%= t("account.registrations.show.quantity_only") %></dt>
        <dd><%= @registration.quantity %></dd>
      <% else %>
        <dt><%= t("account.registrations.show.totals") %></dt>
        <dd><%= @registration.quantity %> × <%= Currency::Symbols.format_amount(@registration.unit_price_cents, @registration.currency) %></dd>
      <% end %>
    </div>
  </dl>

  <article class="card">
    <h3><%= t("account.registrations.show.contact.title") %></h3>
    <% contact = @registration.contact_payload || {} %>
    <dl class="detail-list registration-detail-list">
      <div>
        <dt><%= t("account.registrations.show.contact.primary") %></dt>
        <dd><%= contact["primary_contact"].presence || "—" %></dd>
      </div>
      <div>
        <dt><%= t("account.registrations.show.contact.phone") %></dt>
        <dd><%= contact["phone"].presence || "—" %></dd>
      </div>
      <div>
        <dt>Email</dt>
        <dd><%= contact["email"].presence || "—" %></dd>
      </div>
      <div>
        <dt><%= t("account.registrations.show.contact.dependents") %></dt>
        <dd><%= contact["dependents_notes"].presence || "—" %></dd>
      </div>
    </dl>
  </article>

  <% unless gathering_registration %>
    <article class="card">
      <h3><%= t("account.registrations.show.logistics.title") %></h3>
      <% logistics = @registration.logistics_payload || {} %>
      <% metadata = @registration.metadata || {} %>
      <dl class="detail-list registration-detail-list">
        <div>
          <dt><%= t("account.registrations.show.logistics.arrival") %></dt>
          <dd><%= logistics["arrival_window"].presence || "—" %></dd>
        </div>
        <div>
          <dt><%= t("account.registrations.show.logistics.notes") %></dt>
          <dd><%= metadata["ceremony_notes"].presence || "—" %></dd>
        </div>
      </dl>
    </article>
  <% end %>
</section>
