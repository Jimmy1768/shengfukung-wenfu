<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.registrations.show.eyebrow") %></p>
      <h2><%= @registration.offering&.try(:title) || @registration.reference_code %></h2>
      <p><%= t("account.registrations.show.subtitle") %></p>
    </div>
    <%= link_to t("account.registrations.show.edit"), edit_account_registration_path(@registration), class: "pill-link" %>
  </header>

  <dl class="detail-list">
    <div>
      <dt><%= t("account.registrations.show.registrant") %></dt>
      <dd><%= @registration.registrant_name %></dd>
    </div>
    <div>
      <dt><%= t("account.registrations.show.certificate") %></dt>
      <dd><%= @registration.certificate_number.presence || t("account.registrations.show.certificate_pending") %></dd>
    </div>
    <div>
      <dt><%= t("account.registrations.show.status") %></dt>
      <dd><span class="status-pill status-<%= @registration.payment_status %>"><%= t("account.dashboard.payment_statuses.#{@registration.payment_status}", default: @registration.payment_status) %></span></dd>
    </div>
    <div>
      <dt><%= t("account.registrations.show.totals") %></dt>
      <dd><%= @registration.quantity %> × <%= Currency::Symbols.format_amount(@registration.unit_price_cents, @registration.currency) %></dd>
    </div>
  </dl>

  <article class="card">
    <h3><%= t("account.registrations.show.contact.title") %></h3>
    <% contact = @registration.contact_payload || {} %>
    <ul class="detail-list">
      <li><strong><%= t("account.registrations.show.contact.primary") %>：</strong><%= contact["primary_contact"].presence || "—" %></li>
      <li><strong><%= t("account.registrations.show.contact.phone") %>：</strong><%= contact["phone"].presence || "—" %></li>
      <li><strong>Email：</strong><%= contact["email"].presence || "—" %></li>
      <li><strong><%= t("account.registrations.show.contact.dependents") %>：</strong><%= contact["dependents_notes"].presence || "—" %></li>
    </ul>
  </article>

  <article class="card">
    <h3><%= t("account.registrations.show.logistics.title") %></h3>
    <% logistics = @registration.logistics_payload || {} %>
    <% metadata = @registration.metadata || {} %>
    <ul class="detail-list">
      <li><strong><%= t("account.registrations.show.logistics.arrival") %>：</strong><%= logistics["arrival_window"].presence || "—" %></li>
      <li><strong><%= t("account.registrations.show.logistics.notes") %>：</strong><%= metadata["ceremony_notes"].presence || "—" %></li>
    </ul>
  </article>
</section>
