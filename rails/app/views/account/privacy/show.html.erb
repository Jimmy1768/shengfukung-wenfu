<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.privacy.header.eyebrow") %></p>
      <h2><%= t("account.privacy.header.title") %></h2>
      <p><%= t("account.privacy.header.subtitle") %></p>
    </div>
    <%= link_to t("account.privacy.header.back"), account_profile_path, class: "pill-link secondary" %>
  </header>

  <div class="profile-summary">
    <div>
      <span class="label"><%= t("account.privacy.summary.account_status") %></span>
      <p><%= current_user.closed_account? ? t("account.privacy.summary.closed") : t("account.privacy.summary.active") %></p>
    </div>
    <div>
      <span class="label"><%= t("account.privacy.summary.email") %></span>
      <p><%= current_user.email %></p>
    </div>
  </div>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.privacy.close_account.eyebrow") %></p>
      <h2><%= t("account.privacy.close_account.title") %></h2>
      <p><%= t("account.privacy.close_account.subtitle") %></p>
    </div>
  </header>

  <p class="muted"><%= t("account.privacy.close_account.retention_notice") %></p>

  <div class="form-actions">
    <%= button_to t("account.privacy.close_account.submit"),
                  close_account_privacy_path,
                  method: :post,
                  class: "btn btn-danger",
                  data: { turbo_confirm: t("account.privacy.close_account.confirm") } %>
  </div>
</section>

<section class="account-section">
  <header class="section-header">
    <div>
      <p class="eyebrow"><%= t("account.privacy.requests.eyebrow") %></p>
      <h2><%= t("account.privacy.requests.title") %></h2>
      <p><%= t("account.privacy.requests.subtitle") %></p>
    </div>
  </header>

  <% if @privacy_requests.any? %>
    <div class="timeline">
      <% @privacy_requests.each do |request| %>
        <div class="timeline-entry">
          <div class="timeline-dot"></div>
          <div>
            <p class="timeline-date"><%= l(request.requested_at, format: :short) rescue request.requested_at.strftime("%Y/%m/%d") %></p>
            <h3><%= t("account.privacy.requests.request_type_labels.#{request.request_type}", default: request.request_type.humanize) %></h3>
            <p class="muted"><%= t("account.privacy.requests.status_labels.#{request.status}", default: request.status.humanize) %></p>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="muted"><%= t("account.privacy.requests.empty") %></p>
  <% end %>
</section>
