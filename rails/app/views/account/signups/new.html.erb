<% registration_form = @registration_form || @form || Account::RegistrationForm.new %>

<section class="card login-card register-card">
  <header>
    <p class="eyebrow">Create account</p>
    <h1>Join in one tap</h1>
    <p>Pick Google, Apple, or email to get started.</p>
  </header>

  <%= render "shared/form_errors", form: registration_form %>

  <%= field_row class: "login-grid" do %>
    <%= field_panel class: "register-panel register-social login-credentials" do %>
      <div class="login-panel-head">
        <h2 class="login-subhead">Social sign in</h2>
        <p class="muted">Choose a connected provider to sign in instantly.</p>
      </div>
      <% oauth_links = oauth_provider_links %>

      <% if oauth_links.any? %>
        <div class="oauth-button-grid">
          <% oauth_links.each do |provider| %>
            <%= link_to provider[:path], class: "btn btn-secondary oauth-btn" do %>
              <% if provider[:icon_path].present? %>
                <%= image_tag provider[:icon_path], alt: "", class: "oauth-icon", width: 28, height: 28 %>
              <% end %>
              <span><%= provider[:label] %></span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <p class="muted">OAuth providers are not configured yet.</p>
      <% end %>
      <p class="muted">
        By continuing you accept the default terms (<%= AppConstants::Legal.default_terms_version %>).
      </p>
    <% end %>

    <%= field_panel class: "register-panel register-email login-actions" do %>
      <div class="login-panel-head">
        <h2 class="login-subhead">Email signup</h2>
        <p class="muted">Prefer email? Create a password and you're in.</p>
      </div>
      <%= render "account/signups/form", form: registration_form %>
      <p class="muted">
        Already have an account?
        <%= link_to "Sign in", account_login_path %>
      </p>
    <% end %>
  <% end %>
</section>
