<% currency_unit = @payments.first&.currency || "TWD" %>

<section class="card">
  <header>
    <p class="eyebrow">Payments</p>
    <h1>Payment reporting</h1>
    <p class="muted">
      Totals update in real time as payments are recorded. Export CSVs for finance teams from here.
    </p>
    <% if @show_export %>
      <%= link_to "Download CSV export", export_admin_payments_path(format: :csv), class: "pill-link" %>
    <% end %>
  </header>

  <div class="metric-row">
    <article class="metric">
      <span>Total received</span>
      <strong><%= number_to_currency(@payment_summary.total_amount_cents / 100.0, unit: "#{currency_unit} ") %></strong>
    </article>
    <article class="metric">
      <span>Payments logged</span>
      <strong><%= @payment_summary.total_count %></strong>
    </article>
  </div>
</section>

<section class="card">
  <header>
    <p class="eyebrow">Breakdowns</p>
    <h2>By method / offering / day</h2>
  </header>
  <div class="payment-breakdowns">
    <div>
      <h3>By method</h3>
      <ul class="breakdown-list">
        <% @payment_summary.totals_by_method.each do |entry| %>
          <li>
            <span><%= entry[:label].titleize %></span>
            <strong><%= number_to_currency(entry[:amount_cents] / 100.0, unit: "#{currency_unit} ") %></strong>
          </li>
        <% end %>
      </ul>
    </div>
    <div>
      <h3>By offering</h3>
      <ul class="breakdown-list">
        <% @payment_summary.totals_by_offering.each do |entry| %>
          <li>
            <span><%= entry[:label] %></span>
            <strong><%= number_to_currency(entry[:amount_cents] / 100.0, unit: "#{currency_unit} ") %></strong>
          </li>
        <% end %>
      </ul>
    </div>
    <div>
      <h3>By date</h3>
      <ul class="breakdown-list">
        <% @payment_summary.totals_by_date.each do |entry| %>
          <li>
            <span><%= entry[:label] %></span>
            <strong><%= number_to_currency(entry[:amount_cents] / 100.0, unit: "#{currency_unit} ") %></strong>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</section>

<section class="card">
  <header>
    <p class="eyebrow">Recent activity</p>
    <h2>Latest 100 payments</h2>
  </header>

  <% if @payments.any? %>
    <div class="table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>編號</th>
            <th>Method</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Registration</th>
            <th>Recorded by</th>
            <th>Processed</th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr>
              <td><%= payment.external_reference.presence || payment.id %></td>
              <td><%= payment.payment_method.humanize %></td>
              <td><%= number_to_currency(payment.amount_cents / 100.0, unit: payment.currency) %></td>
              <td><span class="status-pill status-<%= payment.status %>"><%= payment.status.humanize %></span></td>
              <td>
                <% if payment.temple_event_registration&.temple_offering.present? %>
                  <%= link_to payment.temple_event_registration.reference_code,
                    admin_offering_offering_order_path(payment.temple_event_registration.temple_offering, payment.temple_event_registration),
                    class: "pill-link" %>
                <% else %>
                  —
                <% end %>
              </td>
              <td><%= payment.admin_account&.user&.english_name || payment.user&.english_name || "System" %></td>
              <td><%= payment.processed_at&.strftime("%Y/%m/%d %H:%M") || payment.created_at.strftime("%Y/%m/%d %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted">No payments recorded yet.</p>
  <% end %>
</section>
