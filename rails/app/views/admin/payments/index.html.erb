<% currency_unit = @payments.first&.currency || "TWD" %>
<% breakdown_limit = 4 %>

<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide payments-report-card payments-report-card--summary">
      <header>
        <h1><%= t("admin.payments.index.title") %></h1>
        <p class="muted"><%= t("admin.payments.index.body") %></p>
        <% if @show_export %>
          <%= link_to t("admin.payments.index.export"), export_admin_payments_path({ format: :csv, filter: @filters.compact_blank }), class: "pill-link" %>
        <% end %>
      </header>

      <div class="metric-row payments-report-metrics">
        <article class="metric">
          <span><%= t("admin.payments.index.metrics.completed_amount") %></span>
          <strong><%= Currency::Symbols.format_amount(@payment_summary.completed_amount_cents, currency_unit) %></strong>
        </article>
        <article class="metric">
          <span><%= t("admin.payments.index.metrics.completed_count") %></span>
          <strong><%= @payment_summary.completed_count %></strong>
        </article>
        <article class="metric">
          <span><%= t("admin.payments.index.metrics.pending_count") %></span>
          <strong><%= @payment_summary.pending_count %></strong>
        </article>
        <article class="metric">
          <span><%= t("admin.payments.index.metrics.refunded_count") %></span>
          <strong><%= @payment_summary.refunded_count %></strong>
        </article>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide payments-report-card payments-report-card--breakdowns">
      <header>
        <h2><%= t("admin.payments.index.breakdowns.title") %></h2>
      </header>
      <div class="metrics-grid-container">
        <div class="metrics-grid metrics-grid--pill-row">
          <% method_entries = @payment_summary.totals_by_method %>
          <% offering_entries = @payment_summary.totals_by_offering %>
          <% date_entries = @payment_summary.totals_by_date %>

          <article class="metric-card metric-card--list">
            <p class="muted"><%= t("admin.payments.index.breakdowns.by_method") %></p>
            <div class="metric-card-list">
              <% method_entries.first(breakdown_limit).each do |entry| %>
                <div class="metric-card-list__item">
                  <span><%= t("admin.payments.methods.#{entry[:label]}", default: entry[:label].titleize) %></span>
                  <strong><%= Currency::Symbols.format_amount(entry[:amount_cents], currency_unit) %></strong>
                </div>
              <% end %>
            </div>
            <% if method_entries.size > breakdown_limit %>
              <p class="metric-card-note muted">
                <%= t("admin.payments.index.breakdowns.more_methods", default: "另有 %{count} 筆可在下方列表檢視", count: method_entries.size - breakdown_limit) %>
              </p>
            <% end %>
          </article>
          <article class="metric-card metric-card--list">
            <p class="muted"><%= t("admin.payments.index.breakdowns.by_offering") %></p>
            <div class="metric-card-list">
              <% offering_entries.first(breakdown_limit).each do |entry| %>
                <div class="metric-card-list__item">
                  <span><%= entry[:label] %></span>
                  <strong><%= Currency::Symbols.format_amount(entry[:amount_cents], currency_unit) %></strong>
                </div>
              <% end %>
            </div>
            <% if offering_entries.size > breakdown_limit %>
              <p class="metric-card-note muted">
                <%= t("admin.payments.index.breakdowns.more_offerings", default: "另有 %{count} 筆可在下方列表檢視", count: offering_entries.size - breakdown_limit) %>
              </p>
            <% end %>
          </article>
          <article class="metric-card metric-card--list">
            <p class="muted"><%= t("admin.payments.index.breakdowns.by_date") %></p>
            <div class="metric-card-list metric-card-list--wrap">
              <% date_entries.first(breakdown_limit).each do |entry| %>
                <div class="metric-card-list__item metric-card-list__item--wrap">
                  <span><%= entry[:label] %></span>
                  <strong><%= Currency::Symbols.format_amount(entry[:amount_cents], currency_unit) %></strong>
                </div>
              <% end %>
            </div>
            <% if date_entries.size > breakdown_limit %>
              <p class="metric-card-note muted">
                <%= t("admin.payments.index.breakdowns.more_dates", default: "另有 %{count} 筆可在下方列表檢視", count: date_entries.size - breakdown_limit) %>
              </p>
            <% end %>
          </article>
        </div>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide admin-card-with-filter payments-report-card payments-report-card--filters">
      <header>
        <h2><%= t("admin.payments.filters.title") %></h2>
        <p class="muted"><%= t("admin.payments.filters.subtitle") %></p>
      </header>

      <div class="filter-chip-row">
        <% payment_month_presets.each do |preset| %>
          <% classes = ["filter-chip"] %>
          <% active = @filters[:start_date].to_s == preset[:filters][:start_date].to_s && @filters[:end_date].to_s == preset[:filters][:end_date].to_s %>
          <% classes << "is-active" if active %>
          <%= link_to preset[:label], admin_payments_path(filter: preset[:filters].merge(month_preset: preset[:key])), class: classes.join(" ") %>
        <% end %>
      </div>

      <%= render "admin/shared/filters",
        filters: @filters,
        filter_path: admin_payments_path,
        clear_path: admin_payments_path,
        offerings: @filter_offerings,
        payment_methods: @filter_payment_methods,
        status_options: @filter_statuses,
        status_translation_scope: "admin.payments.statuses",
        show_status_chips: false,
        hidden_params: @filter_hidden_fields %>

      <% if @default_payment_window %>
        <p class="filter-hint muted"><%= t("admin.payments.filters.default_window_hint") %></p>
      <% end %>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--fluid stack-item--with-gutter admin-table-card">
      <header>
        <h2><%= t("admin.payments.index.recent.title") %></h2>
      </header>

      <%= render "ledger_table", payments: @payments, empty_message: t("admin.payments.index.empty") %>
    </section>
  </div>
</div>
