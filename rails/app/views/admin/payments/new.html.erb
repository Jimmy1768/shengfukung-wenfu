<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--narrow">
      <header>
        <h1>Record Cash Payment</h1>
        <p class="muted">
          <strong><%= @registration.reference_code %></strong>
          · Total due <%= Currency::Symbols.format_amount(@registration.total_price_cents, @registration.currency) %>
        </p>
      </header>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--narrow">
      <%= form_with model: [:admin, @payment],
            url: admin_payments_path(registration_id: @registration.id),
            class: "form-stack" do |form| %>
        <% if @payment.errors.any? %>
          <div class="alert alert-danger">
            <ul>
              <% @payment.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="field">
          <%= form.label :amount_cents, "Amount (cents)" %>
          <%= form.number_field :amount_cents, min: 0, step: 100 %>
        </div>

        <div class="field">
          <%= form.label :currency %>
          <%= form.select :currency,
                Currency::Symbols.options,
                {},
                { class: "select" } %>
        </div>

        <div class="field">
          <%= form.label :notes %>
          <%= form.text_area :notes, rows: 3 %>
          <p class="hint">Optional – note who provided the cash or any receipt details.</p>
        </div>

        <%= form.submit "Record cash payment", class: "btn btn-primary" %>
      <% end %>
    </section>
  </div>
</div>
