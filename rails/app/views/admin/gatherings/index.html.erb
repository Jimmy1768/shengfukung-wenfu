<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <header class="admin-section-header">
        <div>
          <h1><%= t("admin.gatherings.index.title") %></h1>
          <p class="muted"><%= t("admin.gatherings.index.body") %></p>
        </div>
        <div class="actions actions--inline">
          <%= link_to t("admin.gatherings.actions.new"), new_admin_gathering_path, class: "btn btn-primary" %>
          <% if @show_archived %>
            <%= link_to t("admin.gatherings.actions.view_active"), admin_gatherings_path, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to t("admin.gatherings.actions.view_archived"), admin_gatherings_path(archived: true), class: "btn btn-ghost" %>
          <% end %>
        </div>
      </header>

      <% if @gatherings.any? %>
        <div class="admin-list">
          <% @gatherings.each do |gathering| %>
            <% schedule_label =
              if gathering.starts_on.present?
                start_label = gathering.starts_on.strftime("%Y/%m/%d")
                end_label = if gathering.ends_on.present? && gathering.ends_on != gathering.starts_on
                  gathering.ends_on.strftime("%Y/%m/%d")
                end
                [start_label, end_label].compact.join(" – ")
              else
                t("admin.gatherings.labels.unscheduled")
              end %>
            <% time_label =
              if gathering.start_time.present? || gathering.end_time.present?
                [gathering.start_time&.strftime("%H:%M"), gathering.end_time&.strftime("%H:%M")].compact.join(" – ")
              end %>
            <% location_label = gathering.location_name.presence || gathering.location_address.presence || t("admin.gatherings.labels.location_pending") %>

            <article class="admin-list__row">
              <div>
                <div class="admin-list__heading">
                  <strong><%= gathering.title %></strong>
                  <% if gathering.subtitle.present? %>
                    <p class="muted"><%= gathering.subtitle %></p>
                  <% end %>
                </div>
                <dl class="admin-list__meta admin-list__meta--columns-4">
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.gatherings.table.schedule") %></dt>
                    <dd class="admin-list__meta-value">
                      <div><%= schedule_label %></div>
                      <% if time_label.present? %>
                        <div class="muted"><%= time_label %></div>
                      <% end %>
                    </dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.gatherings.table.location") %></dt>
                    <dd class="admin-list__meta-value"><%= location_label %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.gatherings.table.price") %></dt>
                    <dd class="admin-list__meta-value"><%= Currency::Symbols.format_amount(gathering.price_cents, gathering.currency) %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.gatherings.table.status") %></dt>
                    <dd class="admin-list__meta-value"><%= t("admin.gatherings.statuses.#{gathering.status}", default: gathering.status.to_s.titleize) %></dd>
                  </div>
                </dl>
              </div>
              <div class="admin-list__actions">
                <div class="table-actions__buttons">
                  <%= link_to t("admin.gatherings.actions.view"), edit_admin_gathering_path(gathering), class: "btn btn-secondary btn-small" %>
                  <%= link_to t("admin.gatherings.actions.view_orders"), admin_gathering_offering_orders_path(gathering), class: "btn btn-secondary btn-small" %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <p class="muted"><%= t("admin.gatherings.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
