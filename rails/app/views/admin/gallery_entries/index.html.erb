<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <header class="admin-section-header">
        <div>
          <h1><%= t("admin.gallery_entries.index.title") %></h1>
          <p class="muted"><%= t("admin.gallery_entries.index.body") %></p>
        </div>
        <%= link_to t("admin.gallery_entries.actions.new"), new_admin_gallery_entry_path, class: "btn btn-primary" %>
      </header>

      <% if @gallery_entries.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th><%= t("admin.gallery_entries.table.title") %></th>
              <th><%= t("admin.gallery_entries.table.event_date") %></th>
              <th><%= t("admin.gallery_entries.table.photos") %></th>
              <th class="text-right"><%= t("admin.gallery_entries.table.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @gallery_entries.each do |entry| %>
              <tr>
                <td><%= entry.title %></td>
                <td><%= entry.event_date&.strftime("%Y/%m/%d") %></td>
                <td><%= entry.photo_urls.count %></td>
                <td class="table-actions">
                  <div class="table-actions__buttons">
                    <%= link_to t("admin.gallery_entries.actions.edit"), edit_admin_gallery_entry_path(entry), class: "btn btn-ghost btn-small" %>
                    <%= link_to t("admin.gallery_entries.actions.delete"), admin_gallery_entry_path(entry),
                      method: :delete,
                      data: { confirm: t("admin.gallery_entries.confirmations.delete") },
                      class: "btn btn-ghost btn-small btn-danger" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted"><%= t("admin.gallery_entries.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
