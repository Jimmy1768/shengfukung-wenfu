<% form_action = gallery_entry.persisted? ? admin_gallery_entry_path(gallery_entry) : admin_gallery_entries_path %>
<%= form_with model: gallery_entry, url: form_action, scope: :temple_gallery_entry, class: "form-stack" do |form| %>
  <% if gallery_entry.errors.any? %>
    <div class="inline-validation" data-inline-validation>
      <strong><%= t("admin.gallery_entries.form.errors", count: gallery_entry.errors.count) %></strong>
      <ul>
        <% gallery_entry.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title, t("admin.gallery_entries.fields.title") %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :body, t("admin.gallery_entries.fields.body") %>
    <%= form.text_area :body, rows: 6 %>
  </div>

  <div class="field">
    <%= form.label :event_date, t("admin.gallery_entries.fields.event_date") %>
    <%= form.date_field :event_date %>
  </div>

  <% asset_lookup = gallery_entry.temple.media_assets.where(id: gallery_entry.media_asset_ids).index_by(&:id) if gallery_entry.temple && gallery_entry.media_asset_ids.any? %>
  <% asset_payload = if asset_lookup.present?
      gallery_entry.media_asset_ids.filter_map do |asset_id|
        asset = asset_lookup[asset_id.to_i]
        asset.present? ? { id: asset.id, url: asset.url } : nil
      end
    else
      []
    end %>

  <div class="field">
    <label><%= t("admin.gallery_entries.fields.upload_media") %></label>
    <div class="media-upload media-upload--gallery"
      data-media-upload
      data-media-upload-context="gallery"
      data-media-upload-append="#gallery-photo-urls"
      data-media-upload-assets="#gallery-uploaded-assets">
      <div class="media-upload__controls">
        <select data-media-upload-kind class="media-upload__select">
          <option value="image"><%= t("admin.gallery_entries.fields.media_image") %></option>
          <option value="video"><%= t("admin.gallery_entries.fields.media_video") %></option>
        </select>
        <input type="file" accept="image/*,video/*" data-media-upload-file class="media-upload__file-input">
        <button type="button" class="btn btn-secondary" data-media-upload-button>
          <%= t("admin.media_uploads.actions.upload") %>
        </button>
        <span class="media-upload__status" data-media-upload-status></span>
      </div>
      <p class="muted"><%= t("admin.gallery_entries.hints.upload_media") %></p>
    </div>
    <%= hidden_field_tag "temple_gallery_entry[uploaded_assets_payload]",
      asset_payload.to_json,
      id: "gallery-uploaded-assets" %>
  </div>

  <div class="field">
    <%= form.label :photo_urls_raw, t("admin.gallery_entries.fields.photo_urls") %>
    <%= text_area_tag "temple_gallery_entry[photo_urls_raw]",
      gallery_entry.photo_urls.join("\n"),
      rows: 4,
      class: "form-control",
      id: "gallery-photo-urls" %>
    <p class="muted"><%= t("admin.gallery_entries.hints.photo_urls") %></p>
  </div>

  <div class="form-actions form-actions--centered">
    <%= form.submit t("admin.gallery_entries.actions.save"), class: "btn btn-primary" %>
    <%= link_to t("admin.gallery_entries.actions.cancel"), admin_gallery_entries_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<%= render "admin/shared/media_upload_script" %>
