<div class="admin-stack">
  <% if allow_archive_details? %>
    <div class="admin-stack__row">
      <section class="card stack-item admin-card-with-filter">
        <header>
          <h1><%= t("admin.archives.payments.title") %></h1>
          <p class="muted"><%= t("admin.archives.payments.subtitle") %></p>
        </header>

        <div class="filter-chip-row">
          <% archive_month_presets.each do |preset| %>
            <% classes = ["filter-chip"] %>
            <% active = @filters[:start_date].to_s == preset[:filters][:start_date].to_s && @filters[:end_date].to_s == preset[:filters][:end_date].to_s %>
            <% classes << "is-active" if active %>
            <%= link_to preset[:label], admin_archives_path(filter: preset[:filters]), class: classes.join(" ") %>
          <% end %>
        </div>

        <%= render "admin/shared/filters",
          filters: @filters,
          filter_path: admin_archives_path,
          clear_path: admin_archives_path,
          offerings: @filter_offerings,
          payment_methods: @filter_payment_methods,
          show_status_chips: false,
          hidden_params: @filter_hidden_fields %>

        <% if @filter_errors.any? %>
          <ul class="filter-error-list">
            <% @filter_errors.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        <% end %>
      </section>
    </div>

    <% if @awaiting_range %>
      <div class="admin-stack__row">
        <section class="card stack-item empty-state-card">
          <p class="muted"><%= t("admin.archives.payments.awaiting_range") %></p>
        </section>
      </div>
    <% else %>
      <div class="admin-stack__row">
        <section class="card stack-item">
          <div class="metric-row">
            <article class="metric">
              <span><%= t("admin.archives.payments.summary.total_amount") %></span>
              <strong><%= Currency::Symbols.format_amount(@archive_summary[:total_amount_cents], @archived_payments.first&.currency || "TWD") %></strong>
            </article>
            <article class="metric">
              <span><%= t("admin.archives.payments.summary.payments_logged") %></span>
              <strong><%= @archive_summary[:payment_count] %></strong>
            </article>
            <article class="metric">
              <span><%= t("admin.archives.payments.summary.completed") %></span>
              <strong><%= @archive_summary[:completed_count] %></strong>
            </article>
            <article class="metric">
              <span><%= t("admin.archives.payments.summary.refunded") %></span>
              <strong><%= @archive_summary[:refunded_count] %></strong>
            </article>
          </div>
        </section>
      </div>

      <div class="admin-stack__row">
        <section class="card stack-item stack-item--fluid admin-table-card">
          <header class="admin-section-header">
            <div>
              <h2><%= archive_heading_title %></h2>
              <p class="muted"><%= archive_heading_hint %></p>
            </div>
            <% if allow_archive_exports? %>
              <div class="page-header-actions">
                <%= link_to t("admin.archives.payments.exports.payments"), admin_archive_payments_export_path(**archive_export_filter_params), class: "btn btn-secondary" %>
                <%= link_to t("admin.archives.payments.exports.registrations"), admin_archive_registrations_export_path(**archive_export_filter_params), class: "btn btn-secondary" %>
                <%= link_to t("admin.archives.payments.exports.certificates"), admin_archive_certificates_export_path(**archive_export_filter_params), class: "btn btn-secondary" %>
              </div>
            <% end %>
          </header>

          <%= render "admin/payments/ledger_table",
            payments: @archived_payments,
            empty_message: t("admin.archives.payments.empty_range") %>
        </section>
      </div>
    <% end %>
  <% else %>
    <div class="admin-stack__row">
      <section class="card stack-item">
        <header>
          <h2><%= t("admin.archives.limited.title") %></h2>
        </header>
        <p class="muted"><%= t("admin.archives.limited.body_html") %></p>
      </section>
    </div>
  <% end %>
</div>
