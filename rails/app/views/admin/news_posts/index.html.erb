<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <header class="admin-section-header">
        <div>
          <h1><%= t("admin.news_posts.index.title") %></h1>
          <p class="muted"><%= t("admin.news_posts.index.body") %></p>
        </div>
        <%= link_to t("admin.news_posts.actions.new"), new_admin_news_post_path, class: "btn btn-primary" %>
      </header>

      <% if @news_posts.any? %>
        <table class="admin-table">
          <thead>
            <tr>
              <th><%= t("admin.news_posts.table.title") %></th>
              <th><%= t("admin.news_posts.table.published") %></th>
              <th><%= t("admin.news_posts.table.published_at") %></th>
              <th class="text-right"><%= t("admin.news_posts.table.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @news_posts.each do |post| %>
              <tr>
                <td><%= post.title %></td>
                <td><%= post.published? ? t("admin.news_posts.labels.published") : t("admin.news_posts.labels.draft") %></td>
                <td><%= post.published_at&.strftime("%Y/%m/%d %H:%M") %></td>
                <td class="text-right">
                  <%= link_to t("admin.news_posts.actions.edit"), edit_admin_news_post_path(post), class: "pill-link" %>
                  <%= link_to t("admin.news_posts.actions.delete"), admin_news_post_path(post),
                    method: :delete,
                    data: { confirm: t("admin.news_posts.confirmations.delete") },
                    class: "pill-link danger" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="muted"><%= t("admin.news_posts.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
