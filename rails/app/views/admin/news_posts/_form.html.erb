<% form_action = news_post.persisted? ? admin_news_post_path(news_post) : admin_news_posts_path %>
<%= form_with model: news_post, url: form_action, scope: :news_post, class: "form-stack" do |form| %>
  <% if news_post.errors.any? %>
    <div class="inline-validation" data-inline-validation>
      <strong><%= t("admin.news_posts.form.errors", count: news_post.errors.count) %></strong>
      <ul>
        <% news_post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :title, t("admin.news_posts.fields.title") %>
    <%= form.text_field :title, required: true %>
  </div>

  <div class="field">
    <%= form.label :body, t("admin.news_posts.fields.body") %>
    <%= form.text_area :body, rows: 6 %>
  </div>

  <div class="field">
    <%= form.label :published_at, t("admin.news_posts.fields.published_at") %>
    <%= form.datetime_local_field :published_at %>
    <p class="muted"><%= t("admin.news_posts.hints.published_at") %></p>
  </div>

  <%= render "admin/shared/segmented_boolean",
    name: "news_post[published]",
    id_prefix: "news_post_published",
    label: t("admin.news_posts.fields.published"),
    selected_value: news_post.published? ? "1" : "0",
    options: [[1, t("admin.shared.binary.published")], [0, t("admin.shared.binary.draft")]] %>

  <div class="form-actions form-actions--centered">
    <%= form.submit t("admin.news_posts.actions.save"), class: "btn btn-primary" %>
    <%= link_to t("admin.news_posts.actions.cancel"), admin_news_posts_path, class: "btn btn-secondary" %>
  </div>
<% end %>
