<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="hero stack-item stack-item--hero">
      <div class="hero-text">
        <h1><%= t("admin.dashboard.hero.title", name: current_admin&.english_name || current_admin&.email) %></h1>
        <p><%= t("admin.dashboard.hero.body_html") %></p>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--metrics metrics-card">
      <header>
        <h2><%= t("admin.dashboard.metrics.title") %></h2>
        <p class="muted"><%= t("admin.dashboard.metrics.subtitle") %></p>
      </header>
      <div class="metrics-grid-container">
        <div class="metrics-grid">
          <% @metrics.each do |metric| %>
            <article class="metric-card">
              <h3><%= metric[:value] %></h3>
              <p class="muted"><%= metric[:label] %></p>
            </article>
          <% end %>
        </div>
      </div>
    </section>
  </div>

  <% if @queue_metrics.present? %>
    <div class="admin-stack__row">
      <section class="card stack-item stack-item--metrics metrics-card">
        <header>
          <h2><%= t("admin.dashboard.metrics.queue_title") %></h2>
          <p class="muted"><%= t("admin.dashboard.metrics.queue_subtitle") %></p>
        </header>
        <div class="metrics-grid-container">
          <div class="metrics-grid">
            <% @queue_metrics.each do |metric| %>
              <article class="metric-card">
                <h3><%= metric[:value] %></h3>
                <p class="muted"><%= metric[:label] %></p>
              </article>
            <% end %>
          </div>
        </div>
      </section>
    </div>
  <% end %>

  <% if @open_assistance_requests.present? %>
    <div class="admin-stack__row">
      <section class="card stack-item">
        <header class="section-header">
          <div>
            <h2><%= t("admin.assistance_requests.dashboard.title") %></h2>
            <p class="muted"><%= t("admin.assistance_requests.dashboard.subtitle") %></p>
          </div>
          <%= link_to t("admin.assistance_requests.dashboard.view_all"), admin_assistance_requests_path, class: "pill-link secondary" %>
        </header>

        <div class="table-shell">
          <table class="data-table">
            <thead>
              <tr>
                <th><%= t("admin.assistance_requests.table.requested_at") %></th>
                <th><%= t("admin.assistance_requests.table.patron") %></th>
                <th><%= t("admin.assistance_requests.table.context") %></th>
                <th><%= t("admin.assistance_requests.table.message") %></th>
                <th><%= t("admin.assistance_requests.table.actions") %></th>
              </tr>
            </thead>
            <tbody>
              <% @open_assistance_requests.each do |request| %>
                <tr>
                  <td><%= l(request.requested_at, format: :short) rescue request.requested_at.strftime("%Y/%m/%d") %></td>
                  <td>
                    <strong><%= request.user.native_name.presence || request.user.english_name.presence || request.user.email %></strong>
                    <div class="muted"><%= request.user.email %></div>
                  </td>
                  <td><%= request.temple_registration&.reference_code.presence || t("admin.assistance_requests.context.profile") %></td>
                  <td><%= request.display_message.presence || t("admin.internal.shared.none") %></td>
                  <td>
                    <%= button_to t("admin.assistance_requests.actions.close"),
                      close_admin_assistance_request_path(request),
                      method: :post,
                      class: "btn btn-ghost btn-small" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  <% end %>

  <div class="admin-stack__row">
    <section class="card stack-item">
      <% if @next_steps.any? %>
        <header>
          <h2><%= t("admin.dashboard.next_steps.title") %></h2>
          <p><%= t("admin.dashboard.next_steps.subtitle") %></p>
        </header>
      <% end %>
      <% if @next_steps.any? %>
        <div class="next-step-actions">
          <% @next_steps.each do |step| %>
            <% if step[:url].present? %>
              <%= link_to step[:label], step[:url], class: "btn btn-secondary next-step-button" %>
            <% else %>
              <div class="next-step-button next-step-button--static"><%= step[:label] %></div>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <header>
          <h2><%= t("admin.dashboard.next_steps.complete_heading") %></h2>
        </header>
        <p class="muted"><%= t("admin.dashboard.next_steps.complete") %></p>
      <% end %>
    </section>
  </div>
</div>
