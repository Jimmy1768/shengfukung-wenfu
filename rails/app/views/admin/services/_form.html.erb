<% show_form_actions = local_assigns.fetch(:show_form_actions, true) %>
<% validation_rule = local_assigns[:validation_rule] %>
<% required_fields = validation_rule ? Forms::FieldValidation.required_fields(validation_rule) : [] %>
<% form_scope = @offering.model_name.param_key %>
<%
  form_html_options = { id: "service-form" }
  if required_fields.any?
    form_html_options[:data] = {
      form_validation: true,
      required_fields: required_fields.join(","),
      param_scope: form_scope,
      validation_message: t("admin.offerings.validation.required_message", default: "請完整填寫所有欄位")
    }
  end
%>
<%
  default_form_url =
    if local_assigns[:form_url]
      local_assigns[:form_url]
    elsif @offering.persisted?
      admin_service_path(@offering)
    else
      admin_services_path
    end
%>
<%= form_with model: @offering, url: default_form_url, local: true, class: "form-stack", html: form_html_options do |form| %>
  <% if @offering.errors.any? %>
    <div class="alert alert-danger">
      <h3><%= pluralize(@offering.errors.count, "error") %> prevented saving:</h3>
      <ul>
        <% @offering.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <% hidden_params = local_assigns[:hidden_params] || {} %>
  <% hidden_params.each do |key, value| %>
    <%= hidden_field_tag key, value %>
  <% end %>

<% metadata = (@offering.metadata || {}).with_indifferent_access %>
<% form_ui = metadata["form_ui"].is_a?(Hash) ? metadata["form_ui"].with_indifferent_access : {} %>
<% template_locked = params[:template_slug].present? && !@offering.persisted? %>
<% show_availability_window = form_ui.key?(:show_availability_window) ? form_ui[:show_availability_window] : false %>
<% show_default_location = form_ui.key?(:show_default_location) ? form_ui[:show_default_location] : false %>
<% lock_registration_period_key = form_ui.key?(:lock_registration_period_key) ? form_ui[:lock_registration_period_key] : @offering.registration_period_key.present? %>

  <section class="card form-section">
    <header>
      <h2><%= t("admin.services.form.sections.basics") %></h2>
      <p class="muted"><%= t("admin.services.form.sections.basics_hint") %></p>
    </header>
    <div class="field-row">
      <div class="field-panel">
        <%= form.label :title, t("admin.offering_form.fields.title") %>
        <%= form.text_field :title, readonly: template_locked %>
      </div>
    </div>
    <div class="field-row">
      <div class="field-panel">
        <%= form.label :subtitle, t("admin.services.form.fields.subtitle") %>
        <%= form.text_field :subtitle %>
      </div>
      <div class="field-panel">
        <%= form.label :hero_image_url, t("admin.services.form.fields.hero_image_url") %>
        <%= form.text_field :hero_image_url %>
      </div>
    </div>
    <div class="field-panel">
      <%= form.label :description, t("admin.offering_form.fields.description") %>
      <%= form.text_area :description, rows: 3 %>
    </div>
  </section>

  <section class="card form-section">
    <header>
      <h2><%= t("admin.services.form.sections.availability") %></h2>
    </header>
    <div class="field-row">
      <div class="field-panel">
        <%= form.label :registration_period_key, (lock_registration_period_key ? t("admin.services.form.fields.period_label") : t("admin.services.form.fields.registration_period_key")) %>
        <% period_options =
             current_temple.registration_periods.map do |entry|
               label = current_temple.registration_period_label(entry)
               [label, entry[:key], { "data-label": label }]
             end %>
        <% if lock_registration_period_key %>
          <%= form.hidden_field :registration_period_key %>
          <%= text_field_tag nil, current_temple.registration_period_label_for(@offering.registration_period_key), readonly: true %>
        <% else %>
          <%= form.select :registration_period_key,
            options_for_select(period_options, @offering.registration_period_key),
            { include_blank: t("admin.services.form.fields.registration_period_blank") },
            disabled: period_options.empty?, data: { period_selector: true } %>
        <% end %>
      </div>
      <div class="field-panel">
        <%= form.label :period_label, t("admin.services.form.fields.period_label") %>
        <%= form.text_field :period_label, readonly: true, data: { period_label_input: true }, value: current_temple.registration_period_label_for(@offering.registration_period_key) %>
      </div>
      <div class="field-panel">
        <%= form.label :quantity_limit, t("admin.services.form.fields.quantity_limit") %>
        <%= form.number_field :quantity_limit, min: 0 %>
      </div>
    </div>
    <% if show_availability_window %>
      <div class="field-row">
        <div class="field-panel">
          <%= form.label :available_from, t("admin.services.form.fields.available_from") %>
          <%= form.date_field :available_from, class: "admin-date-input" %>
        </div>
        <div class="field-panel">
          <%= form.label :available_until, t("admin.services.form.fields.available_until") %>
          <%= form.date_field :available_until, class: "admin-date-input" %>
        </div>
      </div>
    <% end %>
    <div class="field-row">
      <% if show_default_location %>
        <div class="field-panel">
          <%= form.label :default_location, t("admin.services.form.fields.default_location") %>
          <%= form.text_field :default_location %>
        </div>
      <% end %>
      <div class="field-panel">
        <%= form.label :fulfillment_notes, t("admin.services.form.fields.fulfillment_notes") %>
        <%= form.text_area :fulfillment_notes, rows: 2 %>
      </div>
    </div>
  </section>

  <div class="offering-form-stage">
    <section class="card form-section offering-form-stage__primary">
      <header>
        <h2><%= t("admin.services.form.sections.pricing") %></h2>
      </header>
      <div class="field-row">
        <div class="field-panel">
          <%= form.label :price_cents, t("admin.registration_form.fields.unit_price") %>
          <%= form.number_field :price_cents, min: 0, value: Currency::Symbols.admin_input_value(@offering.price_cents, @offering.currency || "TWD") %>
        </div>
        <div class="field-panel">
          <%= form.label :currency, t("admin.offering_form.fields.currency") %>
          <%= form.select :currency, options_for_select(Currency::Symbols.options, @offering.currency || "TWD") %>
        </div>
      </div>
      <div class="field">
        <%= form.label :status, t("admin.services.form.fields.status") %>
        <%= form.select :status, options_for_select([["Draft", "draft"], ["Published", "published"], ["Archived", "archived"]], @offering.status) %>
      </div>
    </section>

    <div class="offering-form-stage__secondary-list">
      <%= render_offering_sections(
            form,
            metadata,
            skip_fields: %i[
              title subtitle hero_image_url description period_label registration_period_key quantity_limit available_from available_until default_location fulfillment_notes price_cents currency status offering_type
            ]
          ) %>
    </div>
  </div>

  <% if Rails.env.development? && metadata.dig("form_defaults", "offering_type").present? %>
    <p class="muted offering-form-dev-hint">Dev hint: offering_type = <%= localized_offering_type(metadata.dig("form_defaults", "offering_type")) %> (<%= metadata.dig("form_defaults", "offering_type") %>)</p>
  <% end %>

  <% if show_form_actions %>
    <div class="form-actions">
      <%= form.submit t("admin.offering_form.actions.save"), class: "btn btn-primary" %>
    </div>
  <% end %>
<% end %>

<% content_for :admin_footer_scripts do %>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      var periodSelect = document.querySelector('[data-period-selector="true"]');
      var periodLabelInput = document.querySelector('[data-period-label-input="true"]');
      if (!periodSelect || !periodLabelInput) return;

      function updatePeriodLabel() {
        var option = periodSelect.options[periodSelect.selectedIndex];
        var label = option && option.getAttribute("data-label") ? option.getAttribute("data-label") : "";
        periodLabelInput.value = label;
      }

      periodSelect.addEventListener("change", updatePeriodLabel);
      updatePeriodLabel();
    });
  </script>
<% end %>
