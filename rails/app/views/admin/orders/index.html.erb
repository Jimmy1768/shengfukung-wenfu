<section class="card">
  <header>
    <p class="eyebrow"><%= t("admin.orders.index.eyebrow") %></p>
    <h1><%= t("admin.orders.index.title") %></h1>
    <p class="muted"><%= t("admin.orders.index.body") %></p>
  </header>

  <% if @registrations.any? %>
    <div class="table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th><%= t("admin.orders.index.table.reference") %></th>
            <th><%= t("admin.orders.index.table.offering") %></th>
            <th><%= t("admin.orders.index.table.applicant") %></th>
            <th><%= t("admin.orders.index.table.quantity") %></th>
            <th><%= t("admin.orders.index.table.status") %></th>
            <th><%= t("admin.orders.index.table.created") %></th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @registrations.each do |registration| %>
            <tr>
              <td><%= registration.reference_code %></td>
              <td><%= registration.temple_offering&.title || "—" %></td>
              <td><%= registration.user&.english_name || registration.user&.email || t("admin.orders.index.guest_fallback") %></td>
              <td><%= registration.quantity %></td>
              <td>
                <span class="status-pill status-<%= registration.payment_status %>">
                  <%= t("admin.orders.statuses.#{registration.payment_status}", default: registration.payment_status.humanize) %>
                </span>
              </td>
              <td><%= registration.created_at.strftime("%Y/%m/%d %H:%M") %></td>
              <td>
                <% if registration.temple_offering.present? %>
                  <%= link_to t("admin.orders.index.table.view"), admin_offering_offering_order_path(registration.temple_offering, registration), class: "pill-link" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted"><%= t("admin.orders.index.empty") %></p>
  <% end %>
</section>
