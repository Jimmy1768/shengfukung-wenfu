<section class="card">
  <header>
    <p class="eyebrow">Orders</p>
    <h1>Registrations & onsite orders</h1>
    <p class="muted">
      Use this list to review recent registrations before refining the reporting filters in the next phase.
    </p>
  </header>

  <% if @registrations.any? %>
    <div class="table-scroll">
      <table class="admin-table">
        <thead>
          <tr>
            <th>編號</th>
            <th>Offering</th>
            <th>Applicant</th>
            <th>Quantity</th>
            <th>Status</th>
            <th>Created</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @registrations.each do |registration| %>
            <tr>
              <td><%= registration.reference_code %></td>
              <td><%= registration.temple_offering&.title || "—" %></td>
              <td><%= registration.user&.english_name || registration.user&.email || "Guest" %></td>
              <td><%= registration.quantity %></td>
              <td><span class="status-pill status-<%= registration.payment_status %>"><%= registration.payment_status.humanize %></span></td>
              <td><%= registration.created_at.strftime("%Y/%m/%d %H:%M") %></td>
              <td>
                <% if registration.temple_offering.present? %>
                  <%= link_to "View", admin_offering_offering_order_path(registration.temple_offering, registration), class: "pill-link" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="muted">No registrations have been recorded for this temple yet.</p>
  <% end %>
</section>
