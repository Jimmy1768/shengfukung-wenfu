<% if orders.any? %>
  <div class="table-scroll">
    <table class="admin-table admin-orders-table">
      <thead>
        <tr>
          <th><%= t("admin.orders.index.table.patron") %></th>
          <th><%= t("admin.orders.index.table.source") %></th>
          <th><%= t("admin.orders.index.table.payment_method") %></th>
          <th><%= t("admin.orders.index.table.amount") %></th>
          <th class="orders-created"><%= t("admin.orders.index.table.created") %></th>
          <th><%= t("admin.orders.index.table.status") %></th>
          <th class="text-right"><%= t("admin.orders.index.table.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% orders.each do |registration| %>
          <% latest_payment = registration.temple_payments.max_by { |payment| payment.processed_at || payment.created_at } %>
          <% status_key = registration.payment_status_for_display %>
          <% no_payment_required = status_key == "no_payment_required" %>
          <% row_classes = ["orders-row"] %>
          <% row_classes << "is-unpaid" unless registration.payment_status == TempleEventRegistration::PAYMENT_STATUSES[:paid] || no_payment_required %>
          <% display_name = registration.registrant_name.presence || t("admin.orders.index.guest_fallback") %>
          <tr class="<%= row_classes.join(" ") %>">
            <td>
              <%= display_name %>
              <% if registration.dependent_registration? %>
                <span class="muted">(<%= t("admin.registration_form.labels.registrant_dependent", default: "Dependent") %>)</span>
              <% end %>
            </td>
            <td>
              <% offering = registration.offering %>
              <% if offering.present? %>
                <% type_label =
                  case offering
                  when TempleService
                    t("admin.filters.offering.service_prefix")
                  when TempleGathering
                    t("admin.filters.offering.gathering_prefix")
                  else
                    t("admin.filters.offering.event_prefix")
                  end %>
                <div class="orders-source">
                  <span class="orders-source__type"><%= type_label %></span>
                  <span class="orders-source__title"><%= offering.title %></span>
                </div>
              <% else %>
                —
              <% end %>
            </td>
            <td>
              <% if latest_payment.present? %>
                <span class="payment-method-pill"><%= admin_filter_payment_label(latest_payment.payment_method) %></span>
              <% else %>
                <span class="payment-method-pill unpaid"><%= t("admin.orders.index.table.unpaid_payment") %></span>
              <% end %>
            </td>
            <td><%= Currency::Symbols.format_amount(registration.total_price_cents, registration.currency) %></td>
            <td class="orders-created"><%= registration.created_at.strftime("%Y/%m/%d %H:%M") %></td>
            <td>
              <span class="status-pill status-<%= status_key %>">
                <% if no_payment_required %>
                  <%= t("admin.orders.index.table.no_payment_required") %>
                <% else %>
                  <%= t("admin.orders.statuses.#{status_key}", default: status_key.humanize) %>
                <% end %>
              </span>
            </td>
            <td class="table-actions">
              <div class="table-actions__buttons">
                <% if show_mark_button && registration.payment_status != TempleEventRegistration::PAYMENT_STATUSES[:paid] %>
                  <button type="button" class="btn btn-ghost btn-small" disabled>Mark as paid</button>
                <% end %>
                <% if registration.offering.present? %>
                  <%= link_to t("admin.orders.index.table.view"),
                    admin_offering_order_path_for(registration.offering, registration),
                    class: "btn btn-secondary btn-small",
                    title: t("admin.orders.index.table.reference_hint", reference: registration.reference_code) %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="muted">No registrations match the current filters.</p>
<% end %>
