<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item">
      <header class="admin-section-header">
        <div>
          <h1><%= t("admin.offerings.index.title") %></h1>
          <p class="muted"><%= t("admin.offerings.index.body", default: "管理法會、活動、供燈與供桌等所有供品。") %></p>
        </div>
        <div class="actions actions--inline">
          <% if current_admin_permissions&.allow?(:manage_offerings) %>
            <% if offerings_v1_frozen? %>
              <span class="btn btn-primary is-disabled" title="<%= t("admin.offerings.index.new_button_disabled_hint") %>">
                <%= t("admin.offerings.index.new_button") %>
              </span>
            <% else %>
              <%= link_to t("admin.offerings.index.new_button"), new_admin_offering_path, class: "btn btn-primary" %>
            <% end %>
          <% end %>
          <% if archived_view? %>
            <%= link_to t("admin.offerings.index.view_active"), admin_offerings_path, class: "btn btn-secondary" %>
          <% else %>
            <%= link_to t("admin.offerings.index.view_archived"), admin_offerings_path(archived: true), class: "btn btn-ghost" %>
          <% end %>
        </div>
      </header>
      <% if offerings_v1_frozen? %>
        <p class="muted"><%= t("admin.offerings.index.freeze_notice") %></p>
      <% end %>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <% if @offerings.any? %>
        <div class="admin-list admin-list--offerings">
          <% @offerings.each do |offering| %>
            <% type_label =
              case offering
              when TempleService
                t("admin.filters.offering.service_prefix")
              when TempleGathering
                t("admin.filters.offering.gathering_prefix")
              else
                t("admin.filters.offering.event_prefix")
              end %>
            <article class="admin-list__row">
              <div>
                <div class="admin-list__heading">
                  <strong><%= offering.title %></strong>
                  <% if offering.respond_to?(:subtitle) && offering.subtitle.present? %>
                    <p class="muted"><%= offering.subtitle %></p>
                  <% end %>
                </div>
                <dl class="admin-list__meta admin-list__meta--columns-4">
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offerings.index.table.type") %></dt>
                    <dd class="admin-list__meta-value"><%= type_label %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offerings.index.table.price") %></dt>
                    <dd class="admin-list__meta-value"><%= Currency::Symbols.format_amount(offering.price_cents, offering.currency) %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offerings.index.table.status") %></dt>
                    <dd class="admin-list__meta-value"><%= t("admin.offerings.statuses.#{offering.status}", default: offering.status.to_s.titleize) %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offerings.index.table.updated", default: "Updated") %></dt>
                    <dd class="admin-list__meta-value"><%= l(offering.updated_at, format: :short) %></dd>
                  </div>
                </dl>
              </div>
              <div class="admin-list__actions">
                <div class="table-actions__buttons">
                  <%= link_to t("admin.offerings.index.table.view"), admin_offering_path_for(offering), class: "btn btn-secondary btn-small" %>
                  <% if current_admin_permissions&.allow?(:manage_offerings) %>
                    <%= link_to t("admin.offerings.index.table.edit", default: "Edit"), edit_admin_offering_path_for(offering), class: "btn btn-primary btn-small" %>
                  <% end %>
                </div>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <% empty_key = archived_view? ? "archived_empty" : "empty" %>
        <p class="muted"><%= t("admin.offerings.index.#{empty_key}", default: "沒有符合條件的供品。") %></p>
      <% end %>
    </section>
  </div>
</div>
