<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="hero stack-item stack-item--hero">
      <div class="hero-text">
        <h1><%= t("admin.offerings.new.title") %></h1>
        <p><%= t("admin.offerings.new.body", default: t("admin.dashboard.hero.body_html")) %></p>
      </div>
    </section>
  </div>

  <% selected_template_entry = @selected_template %>

  <% if @templates.any? %>
    <div class="admin-stack__row">
      <section class="card stack-item stack-item--wide">
        <div class="template-picker">
          <% if selected_template_entry.present? %>
            <div class="template-picker__body">
              <p class="muted">
                <%= t("admin.offerings.new.template_selected", name: selected_template_entry[:label] || selected_template_entry[:slug]) %>
              </p>
              <div class="template-picker__actions">
                <button type="button" class="btn btn-secondary" data-modal-trigger="offering-template-modal">
                  <%= t("admin.offerings.new.template_change") %>
                </button>
                <button type="submit" form="<%= @offering_kind == :service ? "service-form" : "event-form" %>" class="btn btn-primary">
                  <%= t("admin.offering_form.actions.save") %>
                </button>
              </div>
            </div>
          <% else %>
            <button type="button" class="btn btn-secondary" data-modal-trigger="offering-template-modal">
              <%= t("admin.offerings.new.template_open") %>
            </button>
          <% end %>
        </div>

        <%= render "shared/modal_panel",
          modal_key: "offering-template-modal",
          title: t("admin.offerings.new.template_modal_title"),
          close_label: t("admin.offerings.new.template_close") do %>
          <div class="template-list">
            <% @templates.each do |template| %>
              <% slug = template[:slug] %>
              <% selected = slug == params[:template_slug] %>
              <% kind_label = template[:kind] == :service ? t("admin.filters.offering.service_prefix") : t("admin.filters.offering.event_prefix") %>
              <%= button_to new_admin_offering_path,
                method: :get,
                params: { template_slug: slug },
                class: ["btn", "template-card-button", ("is-selected" if selected)] do %>
                <div class="template-card-body">
                  <div>
                    <h3><%= template[:label] || slug.titleize %></h3>
                    <p class="template-meta"><%= kind_label %></p>
                  </div>
                  <% if template[:defaults]&.[](:period).present? %>
                    <p class="template-meta"><%= t("admin.offerings.new.template_period", period: template[:defaults][:period]) %></p>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </section>
    </div>
  <% end %>

  <% unless selected_template_entry.present? %>
    <div class="admin-stack__row">
      <section class="card stack-item stack-item--wide">
        <div class="alert alert-info">
          <%= t("admin.offerings.new.template_prompt") %>
        </div>
      </section>
    </div>
  <% end %>

  <% if selected_template_entry.present? && @offering.present? %>
    <div class="admin-stack__row">
      <section class="card stack-item stack-item--fluid">
        <% hidden_params = { offering_kind: @offering_kind, template_slug: params[:template_slug] } %>
        <% if @offering_kind == :service || @offering.is_a?(TempleService) %>
          <%= render "admin/services/form",
            form_url: admin_offerings_path,
            hidden_params: hidden_params %>
        <% else %>
          <%= render "admin/events/form",
            form_url: admin_offerings_path,
            hidden_params: hidden_params %>
        <% end %>
      </section>
    </div>
  <% end %>
</div>
