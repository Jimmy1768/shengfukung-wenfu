<%= form_with model: [:admin, @offering], local: true, class: "form-stack" do |form| %>
  <% if @offering.errors.any? %>
    <div class="alert alert-danger">
      <h3><%= pluralize(@offering.errors.count, "error") %> prevented saving:</h3>
      <ul>
        <% @offering.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% metadata = (@offering.metadata || {}).with_indifferent_access %>

  <%= render_offering_sections(form, metadata) %>

  <%= form.submit t("admin.offering_form.actions.save"), class: "btn btn-primary" %>
<% end %>
