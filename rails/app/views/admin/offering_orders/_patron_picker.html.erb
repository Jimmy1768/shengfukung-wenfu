<% search_endpoint = admin_patrons_path(format: :json) %>
<% create_endpoint = admin_patrons_path(format: :json) %>
<% selected_patron = registration.user %>

<section id="patron-picker" class="card form-section patron-picker"
  data-search-endpoint="<%= search_endpoint %>"
  data-create-endpoint="<%= create_endpoint %>"
  data-csrf="<%= form_authenticity_token %>"
  data-selected-hint="<%= t('admin.registration_form.hints.selected_patron') %>"
  data-created-hint="<%= t('admin.registration_form.hints.created_patron') %>"
  data-no-results="<%= t('admin.registration_form.hints.no_results_placeholder') %>"
  data-search-error="<%= t('admin.registration_form.errors.search_failed') %>"
  data-create-error="<%= t('admin.registration_form.errors.create_failed') %>"
  data-dependents-label="<%= t('admin.registration_form.labels.dependents') %>"
  data-offering-slug="<%= @offering.slug %>">
  <header>
    <p class="eyebrow"><%= t("admin.registration_form.sections.patron") %></p>
    <h2><%= t("admin.registration_form.headings.patron") %></h2>
    <p class="muted"><%= t("admin.registration_form.hints.patron") %></p>
  </header>

  <div class="patron-picker-grid">
    <div class="patron-picker-search">
      <label for="patron-search-field"><%= t("admin.registration_form.fields.search_patron") %></label>
      <div class="patron-search-field" data-role="search-field">
        <input id="patron-search-field" type="search" class="patron-search-input" data-role="patron-search" placeholder="<%= t('admin.registration_form.placeholders.patron_search') %>" autocomplete="off" />
        <div class="patron-search-results" data-role="results" aria-live="polite" hidden></div>
      </div>
      <p class="hint"><%= t("admin.registration_form.hints.patron_search") %></p>
      <div class="selected-patron" data-role="selection">
        <% if selected_patron.present? %>
          <p><%= t("admin.registration_form.hints.selected_patron", name: selected_patron.english_name) %></p>
        <% else %>
          <p class="muted"><%= t("admin.registration_form.hints.no_patron") %></p>
        <% end %>
      </div>
      <div class="picker-message" data-role="picker-message"></div>
    </div>

    <div class="patron-picker-create">
      <h3><%= t("admin.registration_form.headings.new_patron") %></h3>
      <p class="muted"><%= t("admin.registration_form.hints.new_patron") %></p>
      <form data-role="create-form">
        <div class="field">
          <label><%= t("admin.registration_form.fields.primary_contact") %></label>
          <input type="text" name="patron[english_name]" required />
        </div>
        <div class="field">
          <label><%= t("admin.registration_form.fields.email") %></label>
          <input type="email" name="patron[email]" required />
        </div>
        <div class="field">
          <label><%= t("admin.registration_form.fields.phone") %></label>
          <input type="tel" name="patron[phone]" />
        </div>
        <div class="field">
          <label><%= t("admin.registration_form.fields.contact_notes") %></label>
          <textarea name="patron[notes]" rows="2"></textarea>
        </div>
        <div class="field">
          <button type="submit" class="btn btn-secondary"><%= t("admin.registration_form.actions.create_patron") %></button>
        </div>
      </form>
    </div>
  </div>

  <input type="hidden" name="temple_event_registration[user_id]" id="temple_event_registration_user_id" value="<%= registration.user_id %>" />

  <noscript>
    <div class="field">
      <label><%= t("admin.registration_form.fields.manual_user_id") %></label>
      <%= form.number_field :user_id %>
      <p class="hint"><%= t("admin.registration_form.hints.manual_user_id") %></p>
    </div>
  </noscript>
</section>

<script>
  (function() {
    function initializePatronPicker() {
      const picker = document.getElementById("patron-picker");
      if (!picker || picker.dataset.initialized === "true") return;
      picker.dataset.initialized = "true";

      const searchInput = picker.querySelector('[data-role="patron-search"]');
      const resultsNode = picker.querySelector('[data-role="results"]');
      const hiddenField = document.getElementById("temple_event_registration_user_id");
      const selectionNode = picker.querySelector('[data-role="selection"]');
      const createForm = picker.querySelector('[data-role="create-form"]');
      const messageNode = picker.querySelector('[data-role="picker-message"]');
      const formElement = picker.closest('form[data-registration-form]') ||
        document.querySelector('form[data-registration-form]') ||
        picker.closest('form');
      const offeringSlug = picker.dataset.offeringSlug;
      let debounceTimer;
      let lastQueryToken = 0;

      function findFormField(selector) {
        if (!selector) return null;
        if (formElement) {
          const insideForm = formElement.querySelector(selector);
          if (insideForm) return insideForm;
        }
        return document.querySelector(selector);
      }

      const REGISTRATION_FIELD_SELECTORS = {
        quantity: '[name="temple_event_registration[quantity]"]',
        unit_price_cents: '[name="temple_event_registration[unit_price_cents]"]',
        currency: '[name="temple_event_registration[currency]"]',
        certificate_number: '[name="temple_event_registration[certificate_number]"]',
        preferred_date: '[name="temple_event_registration[logistics_details][preferred_date]"]',
        preferred_slot: '[name="temple_event_registration[logistics_details][preferred_slot]"]',
        arrival_window: '[name="temple_event_registration[logistics_details][arrival_window]"]',
        ceremony_location: '[name="temple_event_registration[logistics_details][ceremony_location]"]',
        ancestor_placard_name: '[name="temple_event_registration[ritual_metadata][ancestor_placard_name]"]',
        dedication_message: '[name="temple_event_registration[ritual_metadata][dedication_message]"]',
        incense_option: '[name="temple_event_registration[ritual_metadata][incense_option]"]',
        certificate_notes: '[name="temple_event_registration[ritual_metadata][certificate_notes]"]'
      };

      function setMessage(text, variant) {
        if (!messageNode) return;
        messageNode.textContent = text || "";
        messageNode.className = variant ? `picker-message ${variant}` : "picker-message";
      }

      function escapeHTML(str) {
        return (str || "").replace(/[&<>"']/g, function(tag) {
          const chars = {"&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"};
          return chars[tag] || tag;
        });
      }

      function setContactField(name, value) {
        if (!formElement) return;
        const field = findFormField(`[data-contact-field="${name}"]`) ||
          findFormField(`[name="temple_event_registration[contact_details][${name}]"]`);
        if (field) {
          field.value = value || "";
          const event = new Event('input', { bubbles: true });
          field.dispatchEvent(event);
        }
      }

      function populateContactFields(patron) {
        setContactField('primary_contact', patron.name);
        setContactField('email', patron.email);
        setContactField('phone', patron.phone);
        setContactField('dependents_notes', (patron.dependents || []).join(', '));
        setContactField('notes', patron.notes);
      }

      function setRegistrationField(name, value) {
        if (!formElement || value === undefined || value === null) return;
        const selector = REGISTRATION_FIELD_SELECTORS[name];
        if (!selector) return;
        const field = findFormField(selector);
        if (!field) return;
        field.value = value;
        const event = new Event('input', { bubbles: true });
        field.dispatchEvent(event);
      }

      function populateOfferingFields(patron) {
        if (!offeringSlug) return;
        const offerings = patron.offerings || {};
        const offeringPayload = offerings[offeringSlug];
        if (!offeringPayload || typeof offeringPayload !== 'object') return;
        Object.keys(offeringPayload).forEach(function(key) {
          setRegistrationField(key, offeringPayload[key]);
        });
      }

      function openResults() {
        if (!resultsNode) return;
        resultsNode.hidden = false;
        resultsNode.classList.add('is-open');
      }

      function closeResults() {
        if (!resultsNode) return;
        resultsNode.hidden = true;
        resultsNode.classList.remove('is-open');
        resultsNode.innerHTML = "";
      }

      function dependentsMarkup(list) {
        if (!list || !list.length) return "";
        const safeList = list.map(function(name) { return escapeHTML(name); }).join(', ');
        return `<em>${escapeHTML(picker.dataset.dependentsLabel)} ${safeList}</em>`;
      }

      function renderResults(patrons) {
        if (!resultsNode) return;
        resultsNode.innerHTML = "";

        if (!patrons.length) {
          resultsNode.innerHTML = `<p class="muted">${escapeHTML(picker.dataset.noResults)}</p>`;
          openResults();
          return;
        }

        patrons.forEach(function(patron) {
          const option = document.createElement('button');
          option.type = 'button';
          option.className = 'patron-result-option';
          option.innerHTML = `
            <strong>${escapeHTML(patron.name)}</strong>
            <span>${escapeHTML(patron.email)}</span>
            ${dependentsMarkup(patron.dependents)}
          `;
          option.addEventListener('click', function() {
            selectPatron(patron);
            closeResults();
          });
          resultsNode.appendChild(option);
        });

        openResults();
      }

      function renderError(message) {
        if (!resultsNode) return;
        resultsNode.innerHTML = `<p class="error">${escapeHTML(message)}</p>`;
        openResults();
      }

      function performSearch(query) {
        const trimmed = (query || "").trim();
        if (!trimmed) {
          closeResults();
          return;
        }
        const endpoint = picker.dataset.searchEndpoint;
        if (!endpoint) return;
        const requestId = ++lastQueryToken;
        const url = new URL(endpoint, window.location.origin);
        url.searchParams.set('q', trimmed);
        fetch(url.toString(), { headers: { Accept: 'application/json' } })
          .then(function(response) { return response.json(); })
          .then(function(payload) {
            if (requestId !== lastQueryToken) return;
            renderResults(payload.patrons || []);
          })
          .catch(function() {
            if (requestId !== lastQueryToken) return;
            renderError(picker.dataset.searchError);
          });
      }

      function selectPatron(patron) {
        hiddenField.value = patron.id;
        selectionNode.innerHTML = `<p>${escapeHTML(picker.dataset.selectedHint.replace('%{name}', patron.name))}</p>`;
        setMessage("");
        populateContactFields(patron);
        populateOfferingFields(patron);
      }

      if (searchInput) {
        searchInput.addEventListener('input', function() {
          clearTimeout(debounceTimer);
          const query = searchInput.value;
          debounceTimer = setTimeout(function() {
            performSearch(query);
          }, 250);
        });

        searchInput.addEventListener('keydown', function(event) {
          if (event.key === 'Escape') {
            closeResults();
            searchInput.blur();
          }
        });
      }

      document.addEventListener('click', function(event) {
        if (!picker.contains(event.target)) {
          closeResults();
        }
      });

      if (createForm) {
        createForm.addEventListener('submit', function(event) {
          event.preventDefault();
          const formData = new FormData(createForm);
          const payload = {};
          formData.forEach(function(value, key) {
            const match = key.match(/patron\[(.+)\]/);
            const attribute = match ? match[1] : key;
            payload[attribute] = value;
          });

          fetch(picker.dataset.createEndpoint, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json',
              'X-CSRF-Token': picker.dataset.csrf
            },
            body: JSON.stringify({ patron: payload })
          })
            .then(function(response) {
              if (!response.ok) { throw response; }
              return response.json();
            })
            .then(function(data) {
              if (data.patron) {
                selectPatron(data.patron);
                createForm.reset();
                setMessage(picker.dataset.createdHint.replace('%{name}', data.patron.name), 'success');
                closeResults();
                if (searchInput) searchInput.value = '';
              }
            })
            .catch(function(response) {
              if (response && response.json) {
                response.json().then(function(body) {
                  setMessage(body.errors ? body.errors.join(', ') : picker.dataset.createError, 'error');
                });
              } else {
                setMessage(picker.dataset.createError, 'error');
              }
            });
        });
      }
    }

    document.addEventListener('DOMContentLoaded', initializePatronPicker);
    document.addEventListener('turbo:load', initializePatronPicker);
    if (document.readyState === 'interactive' || document.readyState === 'complete') {
      initializePatronPicker();
    }

    document.addEventListener('turbo:before-cache', function() {
      const picker = document.getElementById('patron-picker');
      if (picker) {
        delete picker.dataset.initialized;
      }
    });
  })();
</script>
