<h1>New Registration</h1>

<%= form_with model: [:admin, @offering, @registration], url: admin_offering_offering_orders_path(@offering) do |form| %>
  <% if @registration.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @registration.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :user_id, "Existing User ID" %>
    <%= form.number_field :user_id %>
    <p class="hint"># TODO: replace with searchable user picker.</p>
  </div>

  <div class="field">
    <%= form.label :quantity %>
    <%= form.number_field :quantity %>
  </div>

  <div class="field">
    <%= form.label :unit_price_cents, "Unit price (cents)" %>
    <%= form.number_field :unit_price_cents %>
  </div>

  <div class="field">
    <%= form.label :currency %>
    <%= form.text_field :currency %>
  </div>

  <div class="field">
    <%= form.label :certificate_number %>
    <%= form.text_field :certificate_number %>
  </div>

  <div class="field">
    <%= form.label :contact_payload, "Contact details (JSON)" %>
    <%= form.text_area :contact_payload, value: JSON.pretty_generate(@registration.contact_payload || {}), rows: 4 %>
  </div>

  <div class="field">
    <%= form.label :logistics_payload, "Logistics (JSON)" %>
    <%= form.text_area :logistics_payload, value: JSON.pretty_generate(@registration.logistics_payload || {}), rows: 4 %>
    <p class="hint"># TODO: capture certificate/award metadata after onsite interview.</p>
  </div>

  <div class="field">
    <%= form.label :metadata, "Metadata (JSON)" %>
    <%= form.text_area :metadata, value: JSON.pretty_generate(@registration.metadata || {}), rows: 4 %>
  </div>

  <%= form.submit "Create registration", class: "button" %>
<% end %>
