<% edit_mode = @registration.persisted? %>
<% gathering_mode = @offering.is_a?(TempleGathering) %>
<% contact_fields_locked = edit_mode && (@registration.temple_payments.exists? || @registration.paid?) %>
<div class="admin-registration-layout">
  <section class="page-header">
    <div class="page-header-body">
      <h1>
        <%= if gathering_mode
          edit_mode ? t("admin.registration_form.gathering.edit_title") : t("admin.registration_form.gathering.title")
        else
          edit_mode ? t("admin.registration_form.edit_title") : t("admin.registration_form.title")
        end %>
      </h1>
      <p class="muted">
        <%= if gathering_mode
          t("admin.registration_form.gathering.subtitle", offering: @offering.title)
        else
          t("admin.registration_form.subtitle", offering: @offering.title)
        end %>
      </p>
    </div>
    <div class="page-header-actions">
      <%= link_to(
            gathering_mode ? t("admin.registration_form.actions.back_to_attendance") : t("admin.registration_form.actions.back_to_orders"),
            admin_offering_orders_path_for(@offering),
            class: "btn btn-secondary"
          ) %>
    </div>
  </section>

  <section class="card form-card">
    <%= form_with model: [:admin, @offering, @registration],
        scope: :temple_event_registration,
        url: edit_mode ? admin_offering_order_path_for(@offering, @registration) : admin_offering_orders_path_for(@offering),
        method: edit_mode ? :patch : :post,
        local: true,
        data: { registration_form: true },
        class: "form-stack" do |form| %>
    <% if @registration.errors.any? %>
      <div class="alert alert-danger">
        <h3><%= t("admin.registration_form.errors_heading", count: @registration.errors.count) %></h3>
        <ul>
          <% @registration.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% schema = registration_form_schema %>
    <% unless edit_mode %>
      <%= render "patron_picker", form:, registration: @registration %>
    <% end %>
    <% if gathering_mode && !edit_mode %>
      <section class="card form-section">
        <header>
          <h2><%= t("admin.registration_form.headings.order") %></h2>
        </header>
        <div class="field-row">
          <div class="field-panel">
            <%= form.label :quantity, t("admin.registration_form.fields.quantity") %>
            <%= form.number_field :quantity, min: 1, value: (@registration.quantity.presence || 1) %>
          </div>
        </div>
        <%= form.hidden_field :unit_price_cents, value: (@registration.unit_price_cents.presence || @offering.price_cents) %>
        <%= form.hidden_field :currency, value: (@registration.currency.presence || @offering.currency) %>
      </section>
    <% else %>

    <% if schema.section?(:order) && !edit_mode %>
      <section class="card form-section">
        <header>
          <h2><%= t("admin.registration_form.headings.order") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.order") %></p>
        </header>

        <% if schema.include_field?(:order, :quantity) || schema.include_field?(:order, :unit_price_cents) %>
          <div class="field-row">
            <% if schema.include_field?(:order, :quantity) %>
              <div class="field-panel">
                <%= form.label :quantity, t("admin.registration_form.fields.quantity") %>
                <%= registration_field_control(form, :quantity,
                      type: :number,
                      schema:,
                      value: @registration.quantity,
                      html_options: { min: 1 }) %>
                <%= registration_multi_value_toggle(:quantity, schema) %>
              </div>
            <% end %>
            <% if schema.include_field?(:order, :unit_price_cents) %>
              <div class="field-panel">
                <%= form.label :unit_price_cents, t("admin.registration_form.fields.unit_price") %>
                <%= registration_field_control(form, :unit_price_cents,
                      type: :number,
                      schema:,
                      value: @registration.unit_price_cents) %>
                <%= registration_multi_value_toggle(:unit_price_cents, schema) %>
                <p class="hint"><%= t("admin.registration_form.hints.unit_price") %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if schema.include_field?(:order, :currency) || schema.include_field?(:order, :certificate_number) %>
          <div class="field-row">
            <% if schema.include_field?(:order, :currency) %>
              <div class="field-panel">
                <%= form.label :currency, t("admin.registration_form.fields.currency") %>
                <%= registration_field_control(form, :currency,
                      type: :text,
                      schema:,
                      value: @registration.currency || @offering.currency) %>
                <%= registration_multi_value_toggle(:currency, schema) %>
              </div>
            <% end %>
            <% if schema.include_field?(:order, :certificate_number) %>
              <div class="field-panel">
                <%= form.label :certificate_number, t("admin.registration_form.fields.certificate_number") %>
                <%= registration_field_control(form, :certificate_number,
                      type: :text,
                      schema:,
                      value: @registration.certificate_number) %>
                <%= registration_multi_value_toggle(:certificate_number, schema) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>

    <% contact_data = @registration.contact_payload.with_indifferent_access %>
    <% if schema.section?(:contact) %>
      <section class="card form-section">
        <header>
          <h2><%= t("admin.registration_form.headings.contact") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.contact") %></p>
        </header>

        <%= form.fields_for :contact_details, contact_data do |contact_fields| %>
          <% if schema.include_field?(:contact, :primary_contact) || schema.include_field?(:contact, :phone) %>
            <div class="field-row">
              <% if schema.include_field?(:contact, :primary_contact) %>
                <div class="field-panel">
                  <%= contact_fields.label :primary_contact, t("admin.registration_form.fields.primary_contact") %>
                  <%= registration_field_control(contact_fields, :primary_contact,
                        type: :text,
                        schema:,
                        value: contact_data[:primary_contact],
                        html_options: { data: { contact_field: "primary_contact" }, readonly: contact_fields_locked }) %>
                </div>
              <% end %>
              <% if schema.include_field?(:contact, :phone) %>
                <div class="field-panel">
                  <%= contact_fields.label :phone, t("admin.registration_form.fields.phone") %>
                  <%= registration_field_control(contact_fields, :phone,
                        type: :telephone,
                        schema:,
                        value: contact_data[:phone],
                        html_options: { data: { contact_field: "phone" }, readonly: contact_fields_locked }) %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:contact, :email) || schema.include_field?(:contact, :dependents_notes) %>
            <div class="field-row">
              <% if schema.include_field?(:contact, :email) %>
                <div class="field-panel">
                  <%= contact_fields.label :email, t("admin.registration_form.fields.email") %>
                  <%= registration_field_control(contact_fields, :email,
                        type: :email,
                        schema:,
                        value: contact_data[:email],
                        html_options: { data: { contact_field: "email" }, readonly: contact_fields_locked }) %>
                </div>
              <% end %>
              <% if schema.include_field?(:contact, :dependents_notes) %>
                <div class="field-panel">
                  <%= contact_fields.label :dependents_notes, t("admin.registration_form.fields.dependents") %>
                  <%= registration_field_control(contact_fields, :dependents_notes,
                        type: :text,
                        schema:,
                        value: contact_data[:dependents_notes],
                        html_options: { data: { contact_field: "dependents_notes" }, readonly: contact_fields_locked }) %>
                  <p class="hint"><%= t("admin.registration_form.hints.dependents") %></p>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:contact, :notes) %>
            <div class="field-panel">
              <%= contact_fields.label :notes, t("admin.registration_form.fields.contact_notes") %>
              <%= registration_field_control(contact_fields, :notes,
                    type: :textarea,
                    schema:,
                    value: contact_data[:notes],
                    html_options: { rows: 3, data: { contact_field: "notes" }, readonly: contact_fields_locked }) %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <% logistics_data = @registration.logistics_payload.with_indifferent_access %>
    <% if schema.section?(:logistics) %>
      <section class="card form-section">
        <header>
          <h2><%= t("admin.registration_form.headings.logistics") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.logistics") %></p>
        </header>

        <%= form.fields_for :logistics_details, logistics_data do |logistics_fields| %>
          <% if schema.include_field?(:logistics, :preferred_date) || schema.include_field?(:logistics, :preferred_slot) %>
            <div class="field-row">
              <% if schema.include_field?(:logistics, :preferred_date) %>
                <div class="field-panel">
                  <%= logistics_fields.label :preferred_date, t("admin.registration_form.fields.preferred_date") %>
                  <%= registration_field_control(logistics_fields, :preferred_date,
                        type: :date,
                        schema:,
                        value: logistics_data[:preferred_date]) %>
                  <%= registration_multi_value_toggle(:preferred_date, schema) %>
                </div>
              <% end %>
              <% if schema.include_field?(:logistics, :preferred_slot) %>
                <div class="field-panel">
                  <%= logistics_fields.label :preferred_slot, t("admin.registration_form.fields.preferred_slot") %>
                  <%= registration_field_control(logistics_fields, :preferred_slot,
                        type: :text,
                        schema:,
                        value: logistics_data[:preferred_slot],
                        html_options: { placeholder: t("admin.registration_form.placeholders.preferred_slot") }) %>
                  <%= registration_multi_value_toggle(:preferred_slot, schema) %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:logistics, :arrival_window) || schema.include_field?(:logistics, :ceremony_location) %>
            <div class="field-row">
              <% if schema.include_field?(:logistics, :arrival_window) %>
                <div class="field-panel">
                  <%= logistics_fields.label :arrival_window, t("admin.registration_form.fields.arrival_window") %>
                  <%= registration_field_control(logistics_fields, :arrival_window,
                        type: :text,
                        schema:,
                        value: logistics_data[:arrival_window]) %>
                  <%= registration_multi_value_toggle(:arrival_window, schema) %>
                </div>
              <% end %>
              <% if schema.include_field?(:logistics, :ceremony_location) %>
                <div class="field-panel">
                  <%= logistics_fields.label :ceremony_location, t("admin.registration_form.fields.ceremony_location") %>
                  <%= registration_field_control(logistics_fields, :ceremony_location,
                        type: :text,
                        schema:,
                        value: logistics_data[:ceremony_location]) %>
                  <%= registration_multi_value_toggle(:ceremony_location, schema) %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <% ritual_metadata = @registration.metadata.with_indifferent_access %>
    <% if schema.section?(:ritual_metadata) %>
      <section class="card form-section">
        <header>
          <h2><%= t("admin.registration_form.headings.ritual_metadata") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.ritual_metadata") %></p>
        </header>

        <%= form.fields_for :ritual_metadata, ritual_metadata do |metadata_fields| %>
          <% if schema.include_field?(:ritual_metadata, :ancestor_placard_name) || schema.include_field?(:ritual_metadata, :dedication_message) %>
            <div class="field-row">
              <% if schema.include_field?(:ritual_metadata, :ancestor_placard_name) %>
                <div class="field-panel">
                  <%= metadata_fields.label :ancestor_placard_name, t("admin.registration_form.fields.ancestor_placard") %>
                  <%= registration_field_control(metadata_fields, :ancestor_placard_name,
                        type: :text,
                        schema:,
                        value: ritual_metadata[:ancestor_placard_name]) %>
                  <%= registration_multi_value_toggle(:ancestor_placard_name, schema) %>
                </div>
              <% end %>
              <% if schema.include_field?(:ritual_metadata, :dedication_message) %>
                <div class="field-panel">
                  <%= metadata_fields.label :dedication_message, t("admin.registration_form.fields.dedication_message") %>
                  <%= registration_field_control(metadata_fields, :dedication_message,
                        type: :text,
                        schema:,
                        value: ritual_metadata[:dedication_message]) %>
                  <%= registration_multi_value_toggle(:dedication_message, schema) %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:ritual_metadata, :incense_option) || schema.include_field?(:ritual_metadata, :certificate_notes) %>
            <div class="field-row">
              <% if schema.include_field?(:ritual_metadata, :incense_option) %>
                <div class="field-panel">
                  <%= metadata_fields.label :incense_option, t("admin.registration_form.fields.incense_option") %>
                  <%= registration_field_control(metadata_fields, :incense_option,
                        type: :text,
                        schema:,
                        value: ritual_metadata[:incense_option]) %>
                  <%= registration_multi_value_toggle(:incense_option, schema) %>
                </div>
              <% end %>
              <% if schema.include_field?(:ritual_metadata, :certificate_notes) %>
                <div class="field-panel">
                  <%= metadata_fields.label :certificate_notes, t("admin.registration_form.fields.certificate_notes") %>
                  <%= registration_field_control(metadata_fields, :certificate_notes,
                        type: :textarea,
                        schema:,
                        value: ritual_metadata[:certificate_notes],
                        html_options: { rows: 3 }) %>
                  <%= registration_multi_value_toggle(:certificate_notes, schema) %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>
    <% end %>

      <div class="form-actions">
        <%= link_to t("admin.registration_form.actions.cancel"), admin_offering_orders_path_for(@offering), class: "btn btn-secondary" %>
        <%= form.submit(edit_mode ? t("admin.registration_form.actions.update") : t("admin.registration_form.actions.submit"), class: "btn btn-primary") %>
      </div>
    <% end %>
  </section>
</div>
