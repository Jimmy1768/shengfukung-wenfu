<section class="page-header">
  <div class="page-header-body">
    <p class="eyebrow"><%= t("admin.registration_form.sections.patron") %></p>
    <h1><%= t("admin.registration_form.title") %></h1>
    <p class="muted"><%= t("admin.registration_form.subtitle", offering: @offering.title) %></p>
  </div>
  <div class="page-header-actions">
    <%= link_to t("admin.registration_form.actions.back_to_orders"), admin_offering_offering_orders_path(@offering), class: "btn btn-secondary" %>
  </div>
</section>

<section class="card form-card">
  <%= form_with model: [:admin, @offering, @registration],
        url: admin_offering_offering_orders_path(@offering),
        local: true,
        data: { registration_form: true },
        class: "form-stack" do |form| %>
    <% if @registration.errors.any? %>
      <div class="alert alert-danger">
        <h3><%= t("admin.registration_form.errors_heading", count: @registration.errors.count) %></h3>
        <ul>
          <% @registration.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% schema = registration_form_schema %>
    <%= render "patron_picker", form:, registration: @registration %>

    <% if schema.section?(:order) %>
      <section class="card form-section">
        <header>
          <p class="eyebrow"><%= t("admin.registration_form.sections.order") %></p>
          <h2><%= t("admin.registration_form.headings.order") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.order") %></p>
        </header>

        <% if schema.include_field?(:order, :quantity) || schema.include_field?(:order, :unit_price_cents) %>
          <div class="field-row">
            <% if schema.include_field?(:order, :quantity) %>
              <div class="field-panel">
                <%= form.label :quantity, t("admin.registration_form.fields.quantity") %>
                <%= form.number_field :quantity, min: 1, value: @registration.quantity %>
              </div>
            <% end %>
            <% if schema.include_field?(:order, :unit_price_cents) %>
              <div class="field-panel">
                <%= form.label :unit_price_cents, t("admin.registration_form.fields.unit_price") %>
                <%= form.number_field :unit_price_cents %>
                <p class="hint"><%= t("admin.registration_form.hints.unit_price") %></p>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if schema.include_field?(:order, :currency) || schema.include_field?(:order, :certificate_number) %>
          <div class="field-row">
            <% if schema.include_field?(:order, :currency) %>
              <div class="field-panel">
                <%= form.label :currency, t("admin.registration_form.fields.currency") %>
                <%= form.text_field :currency, value: @registration.currency || @offering.currency %>
              </div>
            <% end %>
            <% if schema.include_field?(:order, :certificate_number) %>
              <div class="field-panel">
                <%= form.label :certificate_number, t("admin.registration_form.fields.certificate_number") %>
                <%= form.text_field :certificate_number %>
              </div>
            <% end %>
          </div>
        <% end %>
      </section>
    <% end %>

    <% contact_data = @registration.contact_payload.with_indifferent_access %>
    <% if schema.section?(:contact) %>
      <section class="card form-section">
        <header>
          <p class="eyebrow"><%= t("admin.registration_form.sections.contact") %></p>
          <h2><%= t("admin.registration_form.headings.contact") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.contact") %></p>
        </header>

        <%= form.fields_for :contact_details, contact_data do |contact_fields| %>
          <% if schema.include_field?(:contact, :primary_contact) || schema.include_field?(:contact, :phone) %>
            <div class="field-row">
              <% if schema.include_field?(:contact, :primary_contact) %>
                <div class="field-panel">
                  <%= contact_fields.label :primary_contact, t("admin.registration_form.fields.primary_contact") %>
                  <%= contact_fields.text_field :primary_contact, data: { contact_field: "primary_contact" } %>
                </div>
              <% end %>
              <% if schema.include_field?(:contact, :phone) %>
                <div class="field-panel">
                  <%= contact_fields.label :phone, t("admin.registration_form.fields.phone") %>
                  <%= contact_fields.telephone_field :phone, data: { contact_field: "phone" } %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:contact, :email) || schema.include_field?(:contact, :dependents_notes) %>
            <div class="field-row">
              <% if schema.include_field?(:contact, :email) %>
                <div class="field-panel">
                  <%= contact_fields.label :email, t("admin.registration_form.fields.email") %>
                  <%= contact_fields.email_field :email, data: { contact_field: "email" } %>
                </div>
              <% end %>
              <% if schema.include_field?(:contact, :dependents_notes) %>
                <div class="field-panel">
                  <%= contact_fields.label :dependents_notes, t("admin.registration_form.fields.dependents") %>
                  <%= contact_fields.text_field :dependents_notes, data: { contact_field: "dependents_notes" } %>
                  <p class="hint"><%= t("admin.registration_form.hints.dependents") %></p>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:contact, :notes) %>
            <div class="field-panel">
              <%= contact_fields.label :notes, t("admin.registration_form.fields.contact_notes") %>
              <%= contact_fields.text_area :notes, rows: 3, data: { contact_field: "notes" } %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <% logistics_data = @registration.logistics_payload.with_indifferent_access %>
    <% if schema.section?(:logistics) %>
      <section class="card form-section">
        <header>
          <p class="eyebrow"><%= t("admin.registration_form.sections.logistics") %></p>
          <h2><%= t("admin.registration_form.headings.logistics") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.logistics") %></p>
        </header>

        <%= form.fields_for :logistics_details, logistics_data do |logistics_fields| %>
          <% if schema.include_field?(:logistics, :preferred_date) || schema.include_field?(:logistics, :preferred_slot) %>
            <div class="field-row">
              <% if schema.include_field?(:logistics, :preferred_date) %>
                <div class="field-panel">
                  <%= logistics_fields.label :preferred_date, t("admin.registration_form.fields.preferred_date") %>
                  <%= logistics_fields.date_field :preferred_date %>
                </div>
              <% end %>
              <% if schema.include_field?(:logistics, :preferred_slot) %>
                <div class="field-panel">
                  <%= logistics_fields.label :preferred_slot, t("admin.registration_form.fields.preferred_slot") %>
                  <%= logistics_fields.text_field :preferred_slot, placeholder: t("admin.registration_form.placeholders.preferred_slot") %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:logistics, :arrival_window) || schema.include_field?(:logistics, :ceremony_location) %>
            <div class="field-row">
              <% if schema.include_field?(:logistics, :arrival_window) %>
                <div class="field-panel">
                  <%= logistics_fields.label :arrival_window, t("admin.registration_form.fields.arrival_window") %>
                  <%= logistics_fields.text_field :arrival_window %>
                </div>
              <% end %>
              <% if schema.include_field?(:logistics, :ceremony_location) %>
                <div class="field-panel">
                  <%= logistics_fields.label :ceremony_location, t("admin.registration_form.fields.ceremony_location") %>
                  <%= logistics_fields.text_field :ceremony_location %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <% ritual_metadata = @registration.metadata.with_indifferent_access %>
    <% if schema.section?(:ritual_metadata) %>
      <section class="card form-section">
        <header>
          <p class="eyebrow"><%= t("admin.registration_form.sections.ritual_metadata") %></p>
          <h2><%= t("admin.registration_form.headings.ritual_metadata") %></h2>
          <p class="muted"><%= t("admin.registration_form.hints.ritual_metadata") %></p>
        </header>

        <%= form.fields_for :ritual_metadata, ritual_metadata do |metadata_fields| %>
          <% if schema.include_field?(:ritual_metadata, :ancestor_placard_name) || schema.include_field?(:ritual_metadata, :dedication_message) %>
            <div class="field-row">
              <% if schema.include_field?(:ritual_metadata, :ancestor_placard_name) %>
                <div class="field-panel">
                  <%= metadata_fields.label :ancestor_placard_name, t("admin.registration_form.fields.ancestor_placard") %>
                  <%= metadata_fields.text_field :ancestor_placard_name %>
                </div>
              <% end %>
              <% if schema.include_field?(:ritual_metadata, :dedication_message) %>
                <div class="field-panel">
                  <%= metadata_fields.label :dedication_message, t("admin.registration_form.fields.dedication_message") %>
                  <%= metadata_fields.text_field :dedication_message %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if schema.include_field?(:ritual_metadata, :incense_option) || schema.include_field?(:ritual_metadata, :certificate_notes) %>
            <div class="field-row">
              <% if schema.include_field?(:ritual_metadata, :incense_option) %>
                <div class="field-panel">
                  <%= metadata_fields.label :incense_option, t("admin.registration_form.fields.incense_option") %>
                  <%= metadata_fields.text_field :incense_option %>
                </div>
              <% end %>
              <% if schema.include_field?(:ritual_metadata, :certificate_notes) %>
                <div class="field-panel">
                  <%= metadata_fields.label :certificate_notes, t("admin.registration_form.fields.certificate_notes") %>
                  <%= metadata_fields.text_area :certificate_notes, rows: 3 %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>

    <div class="form-actions">
      <%= link_to t("admin.registration_form.actions.cancel"), admin_offering_offering_orders_path(@offering), class: "btn btn-secondary" %>
      <%= form.submit t("admin.registration_form.actions.submit"), class: "btn btn-primary" %>
    </div>
  <% end %>
</section>
