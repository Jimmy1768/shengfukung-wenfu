<div class="admin-registration-layout">
  <% gathering_mode = @offering.is_a?(TempleGathering) %>
  <section class="page-header">
    <div class="page-header-body">
      <h1><%= @registration.reference_code %></h1>
      <p class="muted"><%= t("admin.registration_show.hints.summary", offering: @registration.offering&.title) %></p>
    </div>
    <div class="page-header-actions">
      <%= link_to(
            gathering_mode ? t("admin.registration_show.actions.back_to_attendance") : t("admin.registration_show.actions.back_to_orders"),
            admin_offering_orders_path_for(@offering),
            class: "btn btn-secondary"
          ) %>
      <% unless gathering_mode %>
        <%= link_to(
              t("admin.registration_show.actions.edit_registration"),
              edit_admin_offering_order_path_for(@offering, @registration),
              class: "btn btn-secondary"
            ) %>
      <% end %>
      <% if current_admin_permissions&.allow?(:record_cash_payments) && !@registration.paid? %>
        <%= link_to t("admin.registration_show.actions.record_cash"),
          new_admin_payment_path(registration_id: @registration.id),
          class: "btn btn-primary" %>
      <% end %>
    </div>
  </section>

  <div class="admin-registration-show">
    <section class="card">
      <header>
        <h2><%= t("admin.registration_show.headings.summary") %></h2>
      </header>
      <dl class="detail-grid">
        <div>
          <dt><%= t("admin.registration_show.labels.patron") %></dt>
          <dd>
            <%= @registration.registrant_name.presence || t("admin.registration_show.labels.guest") %>
            <% if @registration.dependent_registration? %>
              <span class="muted">(<%= t("admin.registration_form.labels.registrant_dependent", default: "Dependent") %>)</span>
            <% end %>
          </dd>
        </div>
        <div>
          <dt><%= t("admin.registration_show.labels.quantity") %></dt>
          <dd><%= @registration.quantity %></dd>
        </div>
        <div>
          <dt><%= t("admin.registration_show.labels.payment_status") %></dt>
          <% status_key = @registration.payment_status_for_display %>
          <dd>
            <span class="status-pill status-<%= status_key %>">
              <% if status_key == "no_payment_required" %>
                <%= t("admin.orders.index.table.no_payment_required") %>
              <% else %>
                <%= t("admin.orders.statuses.#{status_key}", default: status_key.humanize) %>
              <% end %>
            </span>
          </dd>
        </div>
        <div>
          <dt><%= t("admin.registration_show.labels.total") %></dt>
          <dd><%= Currency::Symbols.format_amount(@registration.total_price_cents, @registration.currency) %></dd>
        </div>
        <% unless gathering_mode %>
          <div>
            <dt><%= t("admin.registration_show.labels.certificate_number") %></dt>
            <dd><%= @registration.certificate_number.presence || "—" %></dd>
          </div>
        <% end %>
      </dl>
    </section>

    <% unless gathering_mode %>
      <% contact_data = @registration.contact_payload.with_indifferent_access %>
      <section class="card">
        <header>
          <h2><%= t("admin.registration_show.headings.contact") %></h2>
        </header>
        <dl class="detail-grid">
          <div>
            <dt><%= t("admin.registration_form.fields.primary_contact") %></dt>
            <dd><%= contact_data[:primary_contact].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.phone") %></dt>
            <dd><%= contact_data[:phone].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.email") %></dt>
            <dd><%= contact_data[:email].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.dependents") %></dt>
            <dd><%= contact_data[:dependents_notes].presence || "—" %></dd>
          </div>
        </dl>
        <% if contact_data[:notes].present? %>
          <p class="muted"><strong><%= t("admin.registration_form.fields.contact_notes") %>:</strong> <%= contact_data[:notes] %></p>
        <% end %>
      </section>

      <% logistics_data = @registration.logistics_payload.with_indifferent_access %>
      <section class="card">
        <header>
          <h2><%= t("admin.registration_show.headings.logistics") %></h2>
        </header>
        <dl class="detail-grid">
          <div>
            <dt><%= t("admin.registration_form.fields.preferred_date") %></dt>
            <dd><%= logistics_data[:preferred_date].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.preferred_slot") %></dt>
            <dd><%= logistics_data[:preferred_slot].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.arrival_window") %></dt>
            <dd><%= logistics_data[:arrival_window].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.ceremony_location") %></dt>
            <dd><%= logistics_data[:ceremony_location].presence || "—" %></dd>
          </div>
        </dl>
      </section>

      <% ritual_metadata = @registration.metadata.with_indifferent_access %>
      <section class="card">
        <header>
          <h2><%= t("admin.registration_show.headings.ritual") %></h2>
        </header>
        <dl class="detail-grid">
          <div>
            <dt><%= t("admin.registration_form.fields.ancestor_placard") %></dt>
            <dd><%= ritual_metadata[:ancestor_placard_name].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.dedication_message") %></dt>
            <dd><%= ritual_metadata[:dedication_message].presence || "—" %></dd>
          </div>
          <div>
            <dt><%= t("admin.registration_form.fields.incense_option") %></dt>
            <dd><%= ritual_metadata[:incense_option].presence || "—" %></dd>
          </div>
        </dl>
        <% if ritual_metadata[:certificate_notes].present? %>
          <p class="muted"><strong><%= t("admin.registration_form.fields.certificate_notes") %>:</strong> <%= ritual_metadata[:certificate_notes] %></p>
        <% end %>
      </section>
    <% end %>
  </div>
</div>
