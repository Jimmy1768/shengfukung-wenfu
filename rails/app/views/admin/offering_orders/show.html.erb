<section class="page-header">
  <div class="page-header-body">
    <h1><%= @registration.reference_code %></h1>
    <p class="muted"><%= t("admin.registration_show.hints.summary", offering: @registration.offering&.title) %></p>
  </div>
  <div class="page-header-actions">
    <%= link_to t("admin.registration_show.actions.back_to_orders"), admin_offering_orders_path_for(@offering), class: "btn btn-secondary" %>
    <% if current_admin_permissions&.allow?(:record_cash_payments) && !@registration.paid? %>
      <%= link_to t("admin.registration_show.actions.record_cash"),
        new_admin_payment_path(registration_id: @registration.id),
        class: "btn btn-primary" %>
    <% end %>
  </div>
</section>

<section class="card">
  <header>
    <h2><%= t("admin.registration_show.headings.summary") %></h2>
  </header>
  <dl class="detail-grid">
    <div>
      <dt><%= t("admin.registration_show.labels.patron") %></dt>
      <dd><%= @registration.user&.english_name || @registration.user&.email || t("admin.registration_show.labels.guest") %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_show.labels.quantity") %></dt>
      <dd><%= @registration.quantity %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_show.labels.payment_status") %></dt>
      <dd><span class="status-pill status-<%= @registration.payment_status %>"><%= @registration.payment_status.humanize %></span></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_show.labels.total") %></dt>
      <dd><%= Currency::Symbols.format_amount(@registration.total_price_cents, @registration.currency) %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_show.labels.certificate_number") %></dt>
      <dd><%= @registration.certificate_number.presence || "—" %></dd>
    </div>
  </dl>
</section>

<% contact_data = @registration.contact_payload.with_indifferent_access %>
<section class="card">
  <header>
    <h2><%= t("admin.registration_show.headings.contact") %></h2>
  </header>
  <dl class="detail-grid">
    <div>
      <dt><%= t("admin.registration_form.fields.primary_contact") %></dt>
      <dd><%= contact_data[:primary_contact].presence || "—" %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_form.fields.phone") %></dt>
      <dd><%= contact_data[:phone].presence || "—" %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_form.fields.email") %></dt>
      <dd><%= contact_data[:email].presence || "—" %></dd>
    </div>
    <div>
      <dt><%= t("admin.registration_form.fields.dependents") %></dt>
      <dd><%= contact_data[:dependents_notes].presence || "—" %></dd>
    </div>
  </dl>
  <% if contact_data[:notes].present? %>
    <p class="muted"><strong><%= t("admin.registration_form.fields.contact_notes") %>:</strong> <%= contact_data[:notes] %></p>
  <% end %>
</section>

<% logistics_data = @registration.logistics_payload.with_indifferent_access %>
<section class="card">
  <header>
    <h2><%= t("admin.registration_show.headings.logistics") %></h2>
  </header>
  <dl class="detail-grid">
    <div>
      <dt><%= t("admin.registration_form.fields.preferred_date") %></dt>
