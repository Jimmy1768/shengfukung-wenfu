<div class="admin-stack">
  <% gathering_mode = @offering.is_a?(TempleGathering) %>
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide card--page-header">
      <div class="page-header">
        <div class="page-header-body">
          <h1>
            <%= if gathering_mode
              t("admin.offering_orders.index.gathering.title", offering: @offering.title)
            else
              t("admin.offering_orders.index.title", offering: @offering.title)
            end %>
          </h1>
          <p class="muted">
            <%= if gathering_mode
              t("admin.offering_orders.index.gathering.body")
            else
              t("admin.offering_orders.index.body")
            end %>
          </p>
          <% if @offering.respond_to?(:registration_period_key) && @offering.registration_period_key.present? %>
            <p class="muted"><%= t("admin.services.show.registration_period_key") %>：<%= @offering.registration_period_key %></p>
          <% end %>
        </div>
        <div class="page-header-actions">
          <%= link_to(
                gathering_mode ? t("admin.offering_orders.index.gathering.view_offering") : t("admin.offering_orders.index.view_offering"),
                admin_offering_path_for(@offering),
                class: "btn btn-secondary"
              ) %>
          <% if admin_registration_entry_enabled_for?(@offering) %>
            <%= link_to(
                  gathering_mode ? t("admin.offering_orders.index.gathering.new_registration") : t("admin.offering_orders.index.new_registration"),
                  new_admin_offering_order_path_for(@offering),
                  class: "btn btn-primary"
                ) %>
          <% else %>
            <span class="btn btn-primary is-disabled" title="<%= t("admin.offering_orders.index.new_registration_disabled_hint") %>">
              <%= gathering_mode ? t("admin.offering_orders.index.gathering.new_registration") : t("admin.offering_orders.index.new_registration") %>
            </span>
          <% end %>
        </div>
      </div>
      <% unless admin_registration_entry_enabled_for?(@offering) %>
        <p class="muted"><%= t("admin.offering_orders.index.freeze_notice") %></p>
      <% end %>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--metrics metrics-card">
      <div class="metrics-grid-container">
        <div class="metrics-grid">
          <article class="metric-card">
            <h3><%= number_with_delimiter(@registrations_total) %></h3>
            <p class="muted"><%= t("admin.offering_orders.index.metrics.total_hint") %></p>
          </article>
        <article class="metric-card">
          <h3><%= number_with_delimiter(@registrations_paid) %></h3>
          <p class="muted"><%= t("admin.offering_orders.index.metrics.paid_hint") %></p>
        </article>
        <article class="metric-card">
          <h3><%= number_with_delimiter(@registrations_pending) %></h3>
          <p class="muted"><%= t("admin.offering_orders.index.metrics.pending_hint") %></p>
        </article>
          <article class="metric-card">
            <h3><%= Currency::Symbols.format_amount(@registrations_total_amount_cents, @offering.currency) %></h3>
            <p class="muted"><%= t("admin.offering_orders.index.metrics.gross_hint") %></p>
          </article>
        </div>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--metrics">
      <header>
        <h2>
          <%= if gathering_mode
            t("admin.offering_orders.index.gathering.table_heading")
          else
            t("admin.offering_orders.index.table_heading")
          end %>
        </h2>
        <p class="muted">
          <%= if gathering_mode
            t("admin.offering_orders.index.gathering.table_body")
          else
            t("admin.offering_orders.index.table_body")
          end %>
        </p>
      </header>

      <% if @registrations.any? %>
        <div class="table-scroll">
          <table class="admin-table">
            <thead>
              <tr>
                <th><%= t("admin.offering_orders.index.table.reference") %></th>
                <th><%= gathering_mode ? t("admin.offering_orders.index.table.attendee") : t("admin.offering_orders.index.table.user") %></th>
                <th><%= t("admin.offering_orders.index.table.status") %></th>
                <th><%= t("admin.offering_orders.index.table.quantity") %></th>
                <th><%= t("admin.offering_orders.index.table.total") %></th>
                <th><%= t("admin.offering_orders.index.table.created") %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @registrations.each do |registration| %>
                <tr>
                  <td><%= registration.reference_code %></td>
                  <td>
                    <%= registration.registrant_name.presence || t("admin.offering_orders.index.guest_fallback") %>
                    <% if registration.dependent_registration? %>
                      <span class="muted">(<%= t("admin.registration_form.labels.registrant_dependent", default: "Dependent") %>)</span>
                    <% end %>
                  </td>
                  <td>
                    <% status_key = registration.payment_status_for_display %>
                    <span class="status-pill status-<%= status_key %>">
                      <% if status_key == "no_payment_required" %>
                        <%= t("admin.orders.index.table.no_payment_required") %>
                      <% else %>
                        <%= t("admin.orders.statuses.#{status_key}", default: status_key.humanize) %>
                      <% end %>
                    </span>
                  </td>
                  <td><%= registration.quantity %></td>
                  <td><%= Currency::Symbols.format_amount(registration.total_price_cents, registration.currency) %></td>
                  <td><%= l(registration.created_at, format: :short) %></td>
                  <td>
                    <div class="table-actions__buttons">
                      <%= link_to t("admin.offering_orders.index.table.view"), admin_offering_order_path_for(@offering, registration), class: "btn btn-ghost btn-small" %>
                      <% unless gathering_mode %>
                        <%= link_to t("admin.offering_orders.index.table.edit", default: "Edit"), edit_admin_offering_order_path_for(@offering, registration), class: "btn btn-secondary btn-small" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="muted"><%= gathering_mode ? t("admin.offering_orders.index.gathering.empty") : t("admin.offering_orders.index.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
