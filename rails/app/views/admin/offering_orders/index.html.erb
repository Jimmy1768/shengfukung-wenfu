<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide card--page-header">
      <div class="page-header">
        <div class="page-header-body">
          <h1><%= t("admin.offering_orders.index.title", offering: @offering.title) %></h1>
          <p class="muted"><%= t("admin.offering_orders.index.body") %></p>
        </div>
        <div class="page-header-actions">
          <%= link_to t("admin.offering_orders.index.view_offering"), admin_offering_path(@offering), class: "btn btn-secondary" %>
          <%= link_to t("admin.offering_orders.index.new_registration"), new_admin_offering_offering_order_path(@offering), class: "btn btn-primary" %>
        </div>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--metrics metrics-card">
      <div class="metrics-grid-container">
        <div class="metrics-grid">
          <article class="metric-card">
            <h3><%= number_with_delimiter(@registrations_total) %></h3>
            <p class="muted"><%= t("admin.offering_orders.index.metrics.total_hint") %></p>
          </article>
        <article class="metric-card">
          <h3><%= number_with_delimiter(@registrations_paid) %></h3>
          <p class="muted"><%= t("admin.offering_orders.index.metrics.paid_hint") %></p>
        </article>
        <article class="metric-card">
          <h3><%= number_with_delimiter(@registrations_pending) %></h3>
          <p class="muted"><%= t("admin.offering_orders.index.metrics.pending_hint") %></p>
        </article>
          <article class="metric-card">
            <h3><%= Currency::Symbols.format_amount(@registrations_total_amount_cents, @offering.currency) %></h3>
            <p class="muted"><%= t("admin.offering_orders.index.metrics.gross_hint") %></p>
          </article>
        </div>
      </div>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <header>
        <h2><%= t("admin.offering_orders.index.table_heading") %></h2>
        <p class="muted"><%= t("admin.offering_orders.index.table_body") %></p>
      </header>

      <% if @registrations.any? %>
        <div class="table-scroll">
          <table class="admin-table">
            <thead>
              <tr>
                <th><%= t("admin.offering_orders.index.table.reference") %></th>
                <th><%= t("admin.offering_orders.index.table.user") %></th>
                <th><%= t("admin.offering_orders.index.table.status") %></th>
                <th><%= t("admin.offering_orders.index.table.quantity") %></th>
                <th><%= t("admin.offering_orders.index.table.total") %></th>
                <th><%= t("admin.offering_orders.index.table.created") %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @registrations.each do |registration| %>
                <tr>
                  <td><%= registration.reference_code %></td>
                  <td><%= registration.user&.english_name || registration.user&.email || registration.contact_payload.to_h["contact_name"] || t("admin.offering_orders.index.guest_fallback") %></td>
                  <td>
                    <span class="status-pill status-<%= registration.payment_status %>">
                      <%= t("admin.orders.statuses.#{registration.payment_status}", default: registration.payment_status.humanize) %>
                    </span>
                  </td>
                  <td><%= registration.quantity %></td>
                  <td><%= Currency::Symbols.format_amount(registration.total_price_cents, registration.currency) %></td>
                  <td><%= l(registration.created_at, format: :short) %></td>
                  <td>
                    <%= link_to t("admin.offering_orders.index.table.view"), admin_offering_offering_order_path(@offering, registration), class: "pill-link" %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="muted"><%= t("admin.offering_orders.index.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
