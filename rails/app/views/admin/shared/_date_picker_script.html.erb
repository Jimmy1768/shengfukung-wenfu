<script>
  (function() {
    if (window.__adminDatePickerInitialized) return;
    window.__adminDatePickerInitialized = true;

    function enhance(input) {
      if (!input) return;
      if (!input.classList.contains("admin-date-input")) {
        input.classList.add("admin-date-input");
      }
      if (!input.getAttribute("placeholder")) {
        var defaultPlaceholder = input.getAttribute("type") === "datetime-local"
          ? "yyyy/mm/dd --:--"
          : "yyyy/mm/dd";
        input.setAttribute("placeholder", input.dataset.placeholder || defaultPlaceholder);
      }
    }

    function enhanceAll() {
      document.querySelectorAll("input[type='date'], input[type='datetime-local']").forEach(enhance);
    }

    function handleClick(event) {
      var input = event.target.closest("input[type='date'], input[type='datetime-local']");
      if (!input) return;
      if (typeof input.showPicker === "function") {
        input.showPicker();
      } else {
        input.focus();
      }
    }

    document.addEventListener("click", handleClick);
    document.addEventListener("DOMContentLoaded", enhanceAll);
    document.addEventListener("turbo:render", enhanceAll);
    document.addEventListener("turbo:frame-load", enhanceAll);
    enhanceAll();
  })();
</script>
