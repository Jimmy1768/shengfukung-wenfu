<script>
  (() => {
    const I18N = {
      success: "<%= j t("admin.media_uploads.status.success") %>",
      error: "<%= j t("admin.media_uploads.status.error") %>",
      generic: "<%= j t("admin.media_uploads.status.generic") %>"
    };

    const ready = (fn) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fn);
      } else {
        fn();
      }
    };

    const csrfToken = () => {
      const meta = document.querySelector('meta[name="csrf-token"]');
      return meta ? meta.content : null;
    };

    const appendUrl = (textarea, url) => {
      if (!textarea || !url) return;
      const lines = textarea.value.split(/\r?\n/).map((line) => line.trim()).filter(Boolean);
      if (!lines.includes(url)) lines.push(url);
      textarea.value = lines.join("\n");
    };

    const updateAssetsPayload = (input, assetId, url) => {
      if (!input || !assetId || !url) return;
      let payload = [];
      try {
        payload = JSON.parse(input.value || "[]");
      } catch (_e) {
        payload = [];
      }
      const filtered = payload.filter((item) => item.id !== assetId && item.url !== url);
      filtered.push({ id: assetId, url });
      input.value = JSON.stringify(filtered);
    };

    const optionalSelector = (selector) => {
      if (!selector || !selector.trim()) return null;
      try {
        return document.querySelector(selector);
      } catch (_error) {
        return null;
      }
    };

    const bindMediaUpload = (container) => {
      if (container.dataset.mediaUploadBound === "true") return;
      container.dataset.mediaUploadBound = "true";

      const fileInput = container.querySelector("[data-media-upload-file]");
      const uploadButton = container.querySelector("[data-media-upload-button]");
      const statusEl = container.querySelector("[data-media-upload-status]");
      const fileNameEl = container.querySelector("[data-media-upload-filename]");
      if (!fileInput || !uploadButton) return;

      const targetUrl = optionalSelector(container.dataset.mediaUploadTargetUrl);
      const targetAsset = optionalSelector(container.dataset.mediaUploadTargetAsset);
      const preview = optionalSelector(container.dataset.mediaUploadPreview);
      const appendTextarea = optionalSelector(container.dataset.mediaUploadAppend);
      const assetsPayloadInput = optionalSelector(container.dataset.mediaUploadAssets);
      const kindSelect = container.querySelector("[data-media-upload-kind]");
      const defaultLabel = uploadButton.textContent;
      const uploadingLabel = uploadButton.dataset.uploadingLabel || "<%= j t("admin.media_uploads.actions.uploading") %>";

      fileInput.addEventListener("change", () => {
        const hasFile = fileInput.files && fileInput.files.length > 0;
        uploadButton.disabled = !hasFile;
        if (fileNameEl) {
          fileNameEl.textContent = hasFile ? fileInput.files[0].name : "<%= j t("admin.media_uploads.status.no_file") %>";
        }
        if (hasFile) setStatus(statusEl, "");
      });

      uploadButton.disabled = !(fileInput.files && fileInput.files.length > 0);

      uploadButton.addEventListener("click", async () => {
        const file = fileInput.files ? fileInput.files[0] : null;
        if (!file) return;
        const context = resolveContext(container, kindSelect);
        if (!context) {
          setStatus(statusEl, I18N.error);
          return;
        }
        uploadButton.disabled = true;
        uploadButton.textContent = uploadingLabel;
        setStatus(statusEl, "");

        const formData = new FormData();
        formData.append("file", file);
        formData.append("context", context);

        try {
          const response = await fetch("/admin/media_uploads", {
            method: "POST",
            headers: csrfToken() ? { "X-CSRF-Token": csrfToken() } : {},
            body: formData
          });
          const payload = await response.json().catch(() => ({}));
          if (!response.ok) {
            throw new Error(payload.error || I18N.generic);
          }

          const url = payload.url;
          if (targetUrl && url) targetUrl.value = url;
          if (preview && url) preview.src = url;
          if (targetAsset && payload.asset_id) targetAsset.value = payload.asset_id;
          if (appendTextarea && url) appendUrl(appendTextarea, url);
          if (assetsPayloadInput && payload.asset_id && url) {
            updateAssetsPayload(assetsPayloadInput, payload.asset_id, url);
          }

          fileInput.value = "";
          if (fileNameEl) fileNameEl.textContent = "<%= j t("admin.media_uploads.status.no_file") %>";
          uploadButton.textContent = defaultLabel;
          uploadButton.disabled = true;
          setStatus(statusEl, I18N.success, "success");
        } catch (error) {
          uploadButton.disabled = false;
          uploadButton.textContent = defaultLabel;
          setStatus(statusEl, error.message || I18N.error, "error");
        }
      });
    };

    const resolveContext = (container, kindSelect) => {
      const baseContext = container.dataset.mediaUploadContext;
      if (baseContext === "gallery") {
        const kind = kindSelect ? kindSelect.value : "image";
        return kind === "video" ? "gallery_video" : "gallery_image";
      }
      return baseContext;
    };

    const setStatus = (element, message, state = "muted") => {
      if (!element) return;
      element.textContent = message || "";
      element.dataset.state = state;
    };

    const bindAllMediaUploads = () => {
      document.querySelectorAll("[data-media-upload]").forEach(bindMediaUpload);
    };

    if (!window.AdminMediaUploadInit) {
      window.AdminMediaUploadInit = true;
      ready(bindAllMediaUploads);
      document.addEventListener("turbo:load", bindAllMediaUploads);
    }

    bindAllMediaUploads();
  })();
</script>
