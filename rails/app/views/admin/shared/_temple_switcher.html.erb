<div class="temple-switcher">
  <% if allow_temple_switch? %>
    <%= form_with url: admin_temple_switch_path,
                  method: :post,
                  class: "temple-switcher-form",
                  local: true do |form| %>
      <%= form.select :temple_slug,
        options_from_collection_for_select(available_admin_temples, :slug, :name, current_temple&.slug),
        {},
        class: "temple-switcher-select",
        onchange: "this.form.submit()",
        aria: { label: t("admin.nav.temple_selector_label") } %>
    <% end %>
  <% else %>
    <span class="temple-switcher-name"><%= current_temple&.name || t("admin.nav.no_temple") %></span>
  <% end %>
</div>
