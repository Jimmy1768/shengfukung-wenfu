<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item">
      <header class="admin-section-header">
        <div>
          <h1><%= t("admin.offering_setup_drafts.index.title") %></h1>
          <p class="muted"><%= t("admin.offering_setup_drafts.index.body") %></p>
        </div>
        <div class="actions actions--inline">
          <%= link_to t("admin.offering_setup_drafts.index.back_to_offerings"), admin_offerings_path, class: "btn btn-secondary" %>
          <%= link_to t("admin.offering_setup_drafts.index.new_button"), new_admin_offering_setup_draft_path, class: "btn btn-primary" %>
        </div>
      </header>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <% if @drafts.any? %>
        <div class="admin-list">
          <% @drafts.each do |draft| %>
            <article class="admin-list__row">
              <div>
                <div class="admin-list__heading">
                  <strong><%= draft.label %></strong>
                  <p class="muted"><%= draft.slug %></p>
                </div>
                <dl class="admin-list__meta admin-list__meta--columns-4">
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.kind") %></dt>
                    <dd class="admin-list__meta-value"><%= t("admin.offering_setup_drafts.kinds.#{draft.offering_kind}") %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.price") %></dt>
                    <dd class="admin-list__meta-value"><%= Currency::Symbols.format_amount(draft.price_cents, draft.currency) %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.status") %></dt>
                    <dd class="admin-list__meta-value"><%= t("admin.offering_setup_drafts.statuses.#{draft.status}") %></dd>
                  </div>
                  <div class="admin-list__meta-item">
                    <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.updated") %></dt>
                    <dd class="admin-list__meta-value"><%= l(draft.updated_at, format: :short) %></dd>
                  </div>
                </dl>
              </div>
              <div class="admin-list__actions">
                <%= link_to t("admin.offering_setup_drafts.table.view"), admin_offering_setup_draft_path(draft), class: "btn btn-secondary btn-small" %>
              </div>
            </article>
          <% end %>
        </div>
      <% else %>
        <p class="muted"><%= t("admin.offering_setup_drafts.index.empty") %></p>
      <% end %>
    </section>
  </div>
</div>
