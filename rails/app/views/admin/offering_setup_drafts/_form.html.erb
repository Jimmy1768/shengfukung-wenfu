<% payload = (@draft.setup_payload || {}).with_indifferent_access %>
<% selected_fields = Array(payload[:field_requirements]).map(&:to_s) %>
<% catalog_keys = Offerings::SetupFieldCatalog.supported_keys %>
<% unsupported_fields = selected_fields - catalog_keys %>
<% option_entries = Array(payload[:options]).map { |option| option.respond_to?(:with_indifferent_access) ? option.with_indifferent_access : {} } %>
<% unsupported_option_fields = option_entries.map { |option| option[:field].to_s }.reject(&:blank?) - Offerings::SetupFieldCatalog.option_bearing_keys %>
<% option_field_choices =
  [[t("admin.offering_setup_drafts.form.fields.option_blank"), ""]] +
  Offerings::SetupFieldCatalog.option_bearing_keys.map { |key| [Offerings::SetupFieldCatalog.find(key).label, key] } +
  unsupported_option_fields.map { |key| [t("admin.offering_setup_drafts.form.fields.unsupported_option_field_choice", field: key), key] } %>
<% option_row_count = [option_entries.size + 3, 3].max %>

<% form_url = @draft.persisted? ? admin_offering_setup_draft_path(@draft) : admin_offering_setup_drafts_path %>
<%= form_with model: @draft, url: form_url, local: true, class: "form-stack" do |form| %>
  <% if @draft.errors.any? %>
    <div class="alert alert-danger">
      <h3><%= t("admin.offering_setup_drafts.form.errors") %></h3>
      <ul>
        <% @draft.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <section class="card form-section">
    <header>
      <h2><%= t("admin.offering_setup_drafts.form.sections.basics") %></h2>
    </header>
    <div class="field-row">
      <div class="field-panel">
        <%= form.label :offering_kind, t("admin.offering_setup_drafts.form.fields.offering_kind") %>
        <%= form.select :offering_kind, options_for_select([
          [t("admin.offering_setup_drafts.kinds.service"), "service"],
          [t("admin.offering_setup_drafts.kinds.event"), "event"]
        ], @draft.offering_kind || "service") %>
      </div>
      <div class="field-panel">
        <%= form.label :label, t("admin.offering_setup_drafts.form.fields.label") %>
        <%= form.text_field :label %>
      </div>
      <div class="field-panel">
        <%= form.label :slug, t("admin.offering_setup_drafts.form.fields.slug") %>
        <%= form.text_field :slug %>
      </div>
    </div>
    <div class="field-row">
      <div class="field-panel">
        <%= label_tag "temple_offering_setup_draft_category", t("admin.offering_setup_drafts.form.fields.category") %>
        <%= text_field_tag "temple_offering_setup_draft[category]", payload[:category], id: "temple_offering_setup_draft_category" %>
      </div>
      <div class="field-panel">
        <%= form.label :registration_period_key, t("admin.offering_setup_drafts.form.fields.registration_period_key") %>
        <%= form.select :registration_period_key,
          options_for_select(current_temple.registration_period_options, @draft.registration_period_key),
          { include_blank: t("admin.offering_setup_drafts.form.fields.registration_period_blank") } %>
      </div>
    </div>
  </section>

  <section class="card form-section">
    <header>
      <h2><%= t("admin.offering_setup_drafts.form.sections.pricing") %></h2>
    </header>
    <div class="field-row">
      <div class="field-panel">
        <%= form.label :price_cents, t("admin.offering_setup_drafts.form.fields.price") %>
        <%= form.number_field :price_cents, min: 0, value: Currency::Symbols.admin_input_value(@draft.price_cents, @draft.currency || "TWD") %>
      </div>
      <div class="field-panel">
        <%= form.label :currency, t("admin.offering_setup_drafts.form.fields.currency") %>
        <%= form.select :currency, options_for_select(Currency::Symbols.options, @draft.currency || "TWD") %>
      </div>
    </div>
  </section>

  <section class="card form-section">
    <header>
      <h2><%= t("admin.offering_setup_drafts.form.sections.structure") %></h2>
    </header>
    <div class="admin-list">
      <% Offerings::SetupFieldCatalog.grouped_fields.each do |group, fields| %>
        <article class="admin-list__row">
          <div>
            <strong><%= t("admin.offering_setup_drafts.catalog.groups.#{group}", default: group.to_s.humanize) %></strong>
            <div class="field-row">
              <% fields.each do |field| %>
                <label class="field-panel">
                  <%= check_box_tag "temple_offering_setup_draft[field_requirements][]", field.key, selected_fields.include?(field.key), id: "temple_offering_setup_draft_field_#{field.key}" %>
                  <strong><%= field.label %></strong>
                  <span class="muted"><%= field.hint %></span>
                </label>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>
    <% if unsupported_fields.any? %>
      <div class="field-panel">
        <%= label_tag "temple_offering_setup_draft_field_requirements_text", t("admin.offering_setup_drafts.form.fields.unsupported_field_requirements") %>
        <%= text_area_tag "temple_offering_setup_draft[field_requirements_text]", unsupported_fields.join("\n"), id: "temple_offering_setup_draft_field_requirements_text", rows: 3 %>
      </div>
    <% end %>
    <div class="field-row">
      <% option_row_count.times do |index| %>
        <% option = option_entries[index] || {} %>
        <div class="field-panel">
          <%= label_tag "temple_offering_setup_draft_options_#{index}_field", t("admin.offering_setup_drafts.form.fields.option_field") %>
          <%= select_tag "temple_offering_setup_draft[options][#{index}][field]",
            options_for_select(option_field_choices, option[:field]),
            id: "temple_offering_setup_draft_options_#{index}_field" %>
          <%= label_tag "temple_offering_setup_draft_options_#{index}_label", t("admin.offering_setup_drafts.form.fields.option_label") %>
          <%= text_field_tag "temple_offering_setup_draft[options][#{index}][label]", option[:label], id: "temple_offering_setup_draft_options_#{index}_label" %>
          <%= label_tag "temple_offering_setup_draft_options_#{index}_value", t("admin.offering_setup_drafts.form.fields.option_value") %>
          <%= text_field_tag "temple_offering_setup_draft[options][#{index}][value]", option[:value], id: "temple_offering_setup_draft_options_#{index}_value" %>
        </div>
      <% end %>
    </div>
    <div class="field-panel">
      <%= label_tag "temple_offering_setup_draft_operational_notes", t("admin.offering_setup_drafts.form.fields.operational_notes") %>
      <%= text_area_tag "temple_offering_setup_draft[operational_notes]", payload[:operational_notes], id: "temple_offering_setup_draft_operational_notes", rows: 4 %>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit t("admin.offering_setup_drafts.form.actions.save"), class: "btn btn-primary" %>
    <%= link_to t("admin.offering_setup_drafts.form.actions.cancel"), admin_offering_setup_drafts_path, class: "btn btn-secondary" %>
  </div>
<% end %>
