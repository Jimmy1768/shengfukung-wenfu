<div class="admin-stack">
  <div class="admin-stack__row">
    <section class="card stack-item">
      <header class="admin-section-header">
        <div>
          <h1><%= @draft.label %></h1>
          <p class="muted"><%= t("admin.offering_setup_drafts.show.subtitle", status: t("admin.offering_setup_drafts.statuses.#{@draft.status}")) %></p>
        </div>
        <div class="actions actions--inline">
          <%= link_to t("admin.offering_setup_drafts.show.back"), admin_offering_setup_drafts_path, class: "btn btn-secondary" %>
          <% if @draft.editable? %>
            <%= link_to t("admin.offering_setup_drafts.show.edit"), edit_admin_offering_setup_draft_path(@draft), class: "btn btn-primary" %>
          <% end %>
        </div>
      </header>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item">
      <header>
        <h2><%= t("admin.offering_setup_drafts.show.summary") %></h2>
      </header>
      <dl class="admin-list__meta admin-list__meta--columns-4">
        <div class="admin-list__meta-item">
          <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.kind") %></dt>
          <dd class="admin-list__meta-value"><%= t("admin.offering_setup_drafts.kinds.#{@draft.offering_kind}") %></dd>
        </div>
        <div class="admin-list__meta-item">
          <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.price") %></dt>
          <dd class="admin-list__meta-value"><%= Currency::Symbols.format_amount(@draft.price_cents, @draft.currency) %></dd>
        </div>
        <div class="admin-list__meta-item">
          <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.form.fields.registration_period_key") %></dt>
          <dd class="admin-list__meta-value"><%= @draft.registration_period_key.presence || "—" %></dd>
        </div>
        <div class="admin-list__meta-item">
          <dt class="admin-list__meta-label"><%= t("admin.offering_setup_drafts.table.status") %></dt>
          <dd class="admin-list__meta-value"><%= t("admin.offering_setup_drafts.statuses.#{@draft.status}") %></dd>
        </div>
      </dl>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item stack-item--wide">
      <header>
        <h2><%= t("admin.offering_setup_drafts.show.preview") %></h2>
      </header>
      <pre><code><%= @draft.generated_template_yaml %></code></pre>
    </section>
  </div>

  <div class="admin-stack__row">
    <section class="card stack-item">
      <header>
        <h2><%= t("admin.offering_setup_drafts.show.actions") %></h2>
      </header>
      <div class="actions actions--inline">
        <% if @draft.status == "draft" %>
          <%= button_to t("admin.offering_setup_drafts.actions.submit"), submit_admin_offering_setup_draft_path(@draft), method: :post, class: "btn btn-primary" %>
        <% end %>
        <% if @draft.status == "submitted" %>
          <%= form_with url: review_admin_offering_setup_draft_path(@draft), method: :post, local: true, class: "form-stack" do %>
            <div class="field-panel">
              <%= label_tag "temple_offering_setup_draft_review_notes", t("admin.offering_setup_drafts.form.fields.review_notes") %>
              <%= text_area_tag "temple_offering_setup_draft[review_notes]", @draft.review_notes, id: "temple_offering_setup_draft_review_notes", rows: 3 %>
            </div>
            <%= submit_tag t("admin.offering_setup_drafts.actions.review"), class: "btn btn-primary" %>
          <% end %>
        <% end %>
        <% if @draft.status == "reviewed" %>
          <%= button_to t("admin.offering_setup_drafts.actions.apply"), apply_admin_offering_setup_draft_path(@draft), method: :post, class: "btn btn-primary" %>
        <% end %>
      </div>
    </section>
  </div>
</div>
