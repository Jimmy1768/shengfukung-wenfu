<div class="admin-stack">
  <div class="admin-stack__row admin-stack__row--hero-intro">
    <section class="hero stack-item stack-item--hero">
      <div class="hero-text">
        <h1><%= t("admin.payment_methods.hero.title") %></h1>
        <p><%= t("admin.payment_methods.hero.body") %></p>
      </div>
    </section>
  </div>

  <%= form_with model: @form,
        scope: :payment_methods,
        url: admin_payment_methods_path,
        method: :patch,
        class: "form-stack",
        authenticity_token: true,
        local: true,
        data: { turbo: false } do |form| %>
    <div class="admin-stack__row admin-stack__row--primary">
      <section class="card stack-item stack-item--xl stack-item--with-gutter billing-shell" data-billing-tabs>
        <header class="billing-shell__header">
          <div class="billing-shell__intro">
            <p class="billing-shell__eyebrow"><%= t("admin.payment_methods.hero.eyebrow") %></p>
            <h2><%= t("admin.payment_methods.hero.heading") %></h2>
            <p class="muted"><%= t("admin.payment_methods.hero.subheading") %></p>
          </div>

          <div class="billing-pills">
            <span class="billing-pill billing-pill--<%= @form.ecpay_status_tone %>">
              <span class="billing-pill__label"><%= t("admin.payment_methods.status.ecpay_setup") %></span>
              <strong><%= t("admin.payment_methods.status.#{@form.ecpay_status_i18n_key}") %></strong>
            </span>
            <span class="billing-pill billing-pill--<%= @form.online_payments_status_tone %>">
              <span class="billing-pill__label"><%= t("admin.payment_methods.status.online_payments") %></span>
              <strong><%= t("admin.payment_methods.status.#{@form.online_payments_status_i18n_key}", **@form.online_payments_status_i18n_options) %></strong>
            </span>
          </div>
        </header>

        <% if @form.errors.any? %>
          <div class="admin-flash admin-flash-alert">
            <%= t("admin.payment_methods.flash.review_errors") %>
          </div>
        <% end %>

        <div class="billing-tabs" role="tablist" aria-label="<%= t("admin.payment_methods.tabs.aria_label") %>">
          <button type="button" class="billing-tabs__tab is-active" data-billing-tab-target="button" data-tab-id="ecpay" role="tab" aria-selected="true">
            <%= t("admin.payment_methods.tabs.ecpay") %>
          </button>
          <button type="button" class="billing-tabs__tab" data-billing-tab-target="button" data-tab-id="payment-method" role="tab" aria-selected="false">
            <%= t("admin.payment_methods.tabs.payment_method") %>
          </button>
        </div>

        <section class="billing-panel is-active" data-billing-tab-panel="ecpay" role="tabpanel">
          <div class="billing-layout">
            <section class="billing-card billing-card--guide">
              <div class="billing-card__header">
                <p class="billing-card__eyebrow"><%= t("admin.payment_methods.sections.ecpay.eyebrow") %></p>
                <h3><%= t("admin.payment_methods.sections.ecpay.title") %></h3>
                <p><%= t("admin.payment_methods.sections.ecpay.subtitle") %></p>
              </div>

              <div class="billing-step-list">
                <article class="billing-step-card" data-billing-highlight="ecpay-portal">
                  <span class="billing-step-card__label"><%= t("admin.payment_methods.sections.ecpay.steps.open_portal.kicker") %></span>
                  <strong><%= t("admin.payment_methods.sections.ecpay.steps.open_portal.title") %></strong>
                  <p><%= t("admin.payment_methods.sections.ecpay.steps.open_portal.body") %></p>
                  <%= link_to t("admin.payment_methods.sections.ecpay.actions.open_portal"),
                        @form.ecpay_portal_url,
                        class: "billing-button billing-button--secondary",
                        target: "_blank",
                        rel: "noopener" %>
                </article>

                <article class="billing-step-card" data-billing-highlight="ecpay-portal">
                  <span class="billing-step-card__label"><%= t("admin.payment_methods.sections.ecpay.steps.system_settings.kicker") %></span>
                  <strong><%= t("admin.payment_methods.sections.ecpay.steps.system_settings.title") %></strong>
                  <p><%= t("admin.payment_methods.sections.ecpay.steps.system_settings.body") %></p>
                </article>

                <article class="billing-step-card" data-billing-highlight="ecpay-fields">
                  <span class="billing-step-card__label"><%= t("admin.payment_methods.sections.ecpay.steps.paste_back.kicker") %></span>
                  <strong><%= t("admin.payment_methods.sections.ecpay.steps.paste_back.title") %></strong>
                  <p><%= t("admin.payment_methods.sections.ecpay.steps.paste_back.body") %></p>
                </article>
              </div>

              <div class="billing-mini-grid">
                <% if Rails.env.development? %>
                  <article class="billing-mini-card">
                    <span class="billing-mini-card__label"><%= t("admin.payment_methods.status.ecpay_environment") %></span>
                    <strong><%= @form.ecpay_environment.to_s.titleize.presence || "Stage" %></strong>
                  </article>
                <% end %>
              </div>
            </section>

            <section class="billing-column">
              <section class="billing-card billing-card--connection" data-billing-highlight-key="ecpay-fields">
                <div class="billing-card__header">
                  <p class="billing-card__eyebrow"><%= t("admin.payment_methods.sections.ecpay.credentials_eyebrow") %></p>
                  <h3><%= t("admin.payment_methods.sections.ecpay.credentials_title") %></h3>
                  <p><%= t("admin.payment_methods.sections.ecpay.credentials_subtitle") %></p>
                </div>

                <div class="billing-field-grid">
                  <div class="billing-form-field">
                    <%= form.label :ecpay_merchant_id, t("admin.payment_methods.fields.ecpay_merchant_id"), class: "billing-form-label" %>
                    <%= form.text_field :ecpay_merchant_id, autocomplete: "off", class: "billing-form-input" %>
                  </div>

                  <div class="billing-form-field">
                    <%= form.label :ecpay_hash_key, t("admin.payment_methods.fields.ecpay_hash_key"), class: "billing-form-label" %>
                    <%= form.password_field :ecpay_hash_key, autocomplete: "new-password", class: "billing-form-input" %>
                  </div>

                  <div class="billing-form-field">
                    <%= form.label :ecpay_hash_iv, t("admin.payment_methods.fields.ecpay_hash_iv"), class: "billing-form-label" %>
                    <%= form.password_field :ecpay_hash_iv, autocomplete: "new-password", class: "billing-form-input" %>
                  </div>

                  <% if Rails.env.development? %>
                    <div class="billing-form-field">
                      <%= form.label :ecpay_environment, t("admin.payment_methods.fields.ecpay_environment"), class: "billing-form-label" %>
                      <%= form.select :ecpay_environment, options_for_select(@form.ecpay_environment_options, @form.ecpay_environment), {}, class: "billing-form-input billing-form-input--select" %>
                    </div>
                  <% end %>
                </div>

                <div class="billing-card__actions">
                  <%= form.submit t("admin.payment_methods.sections.ecpay.actions.save"), class: "billing-button billing-button--primary" %>
                </div>
              </section>

              <div class="billing-facts-grid">
                <article class="billing-fact-card">
                  <span class="billing-fact-card__label"><%= t("admin.payment_methods.status.ecpay_setup") %></span>
                  <strong><%= t("admin.payment_methods.status.#{@form.ecpay_status_i18n_key}") %></strong>
                </article>
                <% if Rails.env.development? %>
                  <article class="billing-fact-card">
                    <span class="billing-fact-card__label"><%= t("admin.payment_methods.status.ecpay_environment") %></span>
                    <strong><%= @form.ecpay_environment.to_s.titleize.presence || "Stage" %></strong>
                  </article>
                <% end %>
                <article class="billing-fact-card billing-fact-card--wide">
                  <span class="billing-fact-card__label"><%= t("admin.payment_methods.sections.ecpay.credentials_title") %></span>
                  <strong><%= @form.ecpay_merchant_id.presence || t("admin.internal.shared.none") %></strong>
                  <p><%= t("admin.payment_methods.sections.ecpay.credentials_subtitle") %></p>
                </article>
              </div>
            </section>
          </div>
        </section>

        <section class="billing-panel" data-billing-tab-panel="payment-method" role="tabpanel" hidden>
          <div class="billing-layout billing-layout--payment">
            <section class="billing-card">
              <div class="billing-card__header">
                <p class="billing-card__eyebrow"><%= t("admin.payment_methods.sections.payment_method.eyebrow") %></p>
                <h3><%= t("admin.payment_methods.sections.payment_method.title") %></h3>
                <p><%= t("admin.payment_methods.sections.payment_method.subtitle", amount: @form.billing_monthly_fee_label) %></p>
              </div>

              <div class="billing-step-list">
                <article class="billing-info-card">
                  <span class="billing-info-card__label"><%= t("admin.payment_methods.sections.payment_method.notes.price_title", amount: @form.billing_monthly_fee_label) %></span>
                  <p><%= t("admin.payment_methods.sections.payment_method.notes.price_body") %></p>
                </article>
                <article class="billing-info-card">
                  <span class="billing-info-card__label"><%= t("admin.payment_methods.sections.payment_method.notes.freeze_title") %></span>
                  <p><%= t("admin.payment_methods.sections.payment_method.notes.freeze_body", days: @form.billing_grace_days) %></p>
                </article>
              </div>

              <div class="billing-card__actions">
                <% if @form.billing_portal_url.present? %>
                  <%= link_to t("admin.payment_methods.sections.payment_method.actions.open_billing"),
                        @form.billing_portal_url,
                        class: "billing-button billing-button--secondary",
                        target: "_blank",
                        rel: "noopener" %>
                <% else %>
                  <p class="muted"><%= t("admin.payment_methods.sections.payment_method.missing_portal") %></p>
                <% end %>
              </div>
            </section>

            <section class="billing-column">
              <section class="billing-card">
                <div class="billing-card__header">
                  <p class="billing-card__eyebrow"><%= t("admin.payment_methods.sections.payment_method.status_eyebrow") %></p>
                  <h3><%= t("admin.payment_methods.sections.payment_method.status_title") %></h3>
                  <p><%= t("admin.payment_methods.sections.payment_method.status_subtitle") %></p>
                </div>

                <div class="billing-form-field">
                  <label class="billing-checkbox">
                    <%= form.check_box :billing_payment_method_on_file %>
                    <span><%= t("admin.payment_methods.fields.billing_payment_method_on_file") %></span>
                  </label>
                </div>

                <div class="billing-card__actions">
                  <%= form.submit t("admin.payment_methods.sections.payment_method.actions.save"), class: "billing-button billing-button--primary" %>
                </div>
              </section>

              <div class="billing-facts-grid">
                <article class="billing-fact-card">
                  <span class="billing-fact-card__label"><%= t("admin.payment_methods.status.monthly_fee") %></span>
                  <strong><%= @form.billing_monthly_fee_label %></strong>
                </article>
                <article class="billing-fact-card">
                  <span class="billing-fact-card__label"><%= t("admin.payment_methods.status.grace_period_label") %></span>
                  <strong><%= t("admin.payment_methods.status.grace_period_value", days: @form.billing_grace_days) %></strong>
                </article>
                <article class="billing-fact-card billing-fact-card--wide">
                  <span class="billing-fact-card__label"><%= t("admin.payment_methods.status.current_state") %></span>
                  <strong><%= t("admin.payment_methods.status.#{@form.online_payments_status_i18n_key}", **@form.online_payments_status_i18n_options) %></strong>
                  <p><%= t("admin.payment_methods.sections.payment_method.notes.freeze_body", days: @form.billing_grace_days) %></p>
                </article>
              </div>
            </section>
          </div>
        </section>
      </section>
    </div>
  <% end %>
</div>

<% content_for :admin_footer_scripts do %>
  <script>
    (() => {
      const initializeBillingTabs = () => {
        document.querySelectorAll("[data-billing-tabs]").forEach((container) => {
          const buttons = container.querySelectorAll("[data-billing-tab-target='button']");
          const panels = container.querySelectorAll("[data-billing-tab-panel]");

          const activate = (tabId) => {
            buttons.forEach((button) => {
              const active = button.dataset.tabId === tabId;
              button.classList.toggle("is-active", active);
              button.setAttribute("aria-selected", active ? "true" : "false");
            });

            panels.forEach((panel) => {
              const active = panel.dataset.billingTabPanel === tabId;
              panel.classList.toggle("is-active", active);
              panel.hidden = !active;
            });
          };

          buttons.forEach((button) => {
            button.addEventListener("click", () => activate(button.dataset.tabId));
          });

          activate("ecpay");
        });
      };

      const initializeBillingHighlights = () => {
        document.querySelectorAll("[data-billing-highlight]").forEach((step) => {
          const keys = (step.dataset.billingHighlight || "").split(/\s+/).filter(Boolean);
          if (!keys.length) return;

          const toggle = (state) => {
            keys.forEach((key) => {
              document.querySelectorAll(`[data-billing-highlight-key='${key}']`).forEach((node) => {
                node.classList.toggle("is-highlighted", state);
              });
            });
          };

          step.addEventListener("mouseenter", () => toggle(true));
          step.addEventListener("mouseleave", () => toggle(false));
          step.addEventListener("focusin", () => toggle(true));
          step.addEventListener("focusout", () => toggle(false));
        });
      };

      const boot = () => {
        initializeBillingTabs();
        initializeBillingHighlights();
      };

      document.addEventListener("turbo:load", boot);
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", boot, { once: true });
      } else {
        boot();
      }
    })();
  </script>
<% end %>
