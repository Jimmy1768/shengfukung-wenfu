<div class="admin-stack">
  <div class="admin-stack__row admin-stack__row--hero-intro">
    <section class="hero stack-item stack-item--hero">
      <div class="hero-text">
        <h1><%= t("admin.temple_profile.hero.title") %></h1>
        <p><%= t("admin.temple_profile.hero.body") %></p>
      </div>
    </section>
  </div>

  <%= form_with model: @form,
        scope: :temple,
        url: admin_temple_profile_path,
        method: :patch,
        class: "form-stack temple-profile-form",
        authenticity_token: true,
        local: true,
        html: { multipart: true },
        data: { turbo: false } do |form| %>
    <div class="admin-stack__row admin-stack__row--primary">
      <section class="card stack-item stack-item--xl stack-item--with-gutter">
        <div class="card-grid two-column temple-profile-grid">
          <section class="card form-card">
            <header>
              <h2><%= t("admin.temple_profile.sections.basics.title") %></h2>
              <p><%= t("admin.temple_profile.sections.basics.subtitle") %></p>
            </header>

            <div class="field">
              <%= form.label :name, t("admin.temple_profile.fields.name") %>
              <%= form.text_field :name, required: true, placeholder: t("admin.temple_profile.placeholders.name") %>
            </div>

            <div class="field">
              <%= form.label :tagline, t("admin.temple_profile.fields.tagline") %>
              <%= form.text_field :tagline, placeholder: t("admin.temple_profile.placeholders.tagline") %>
            </div>

            <div class="field">
              <%= form.label :hero_copy, t("admin.temple_profile.fields.hero_copy") %>
              <%= form.text_area :hero_copy, rows: 3, placeholder: t("admin.temple_profile.placeholders.hero_copy") %>
            </div>
          </section>

          <section class="card form-card">
            <header>
              <h2><%= t("admin.temple_profile.sections.about.title") %></h2>
              <p><%= t("admin.temple_profile.sections.about.subtitle") %></p>
            </header>

            <%= form.fields_for :about do |about_fields| %>
              <div class="field">
                <%= about_fields.label :hero_subtitle, t("admin.temple_profile.fields.about_hero_subtitle") %>
                <%= text_area_tag "temple[about][hero_subtitle]",
                      @form.about[:hero_subtitle],
                      rows: 2,
                      placeholder: t("admin.temple_profile.placeholders.about_hero_subtitle") %>
              </div>

              <div class="about-card-fields">
                <% @form.about_card_definitions.each do |card| %>
                  <div class="field">
                    <label><%= t("admin.temple_profile.fields.about_cards.#{card[:key]}") %></label>
                    <%= text_area_tag "temple[about][cards][#{card[:key]}][body]",
                          card[:body],
                          rows: 3,
                          placeholder: t("admin.temple_profile.placeholders.about_cards.#{card[:key]}") %>
                  </div>
                <% end %>
              </div>

            <% end %>
          </section>

          <section class="card form-card">
            <header>
              <h2><%= t("admin.temple_profile.sections.contact.title") %></h2>
              <p><%= t("admin.temple_profile.sections.contact.subtitle") %></p>
            </header>

            <div class="field">
              <%= form.label :contact_phone, t("admin.temple_profile.fields.phone") %>
              <%= form.text_field :contact_phone,
                    name: "temple[contact][phone]",
                    value: @form.contact["phone"],
                    placeholder: t("admin.temple_profile.placeholders.phone") %>
            </div>

            <div class="field">
              <%= form.label :map_link, t("admin.temple_profile.fields.map_link") %>
              <%= form.url_field :map_link,
                    value: @form.map_link,
                    placeholder: t("admin.temple_profile.placeholders.map_link"),
                    class: "temple-map-input" %>
              <p class="muted">貼上 Google Maps 分享連結，即可自動帶入地址資訊。</p>
            </div>

            <div class="derived-contact">
              <div class="derived-contact__item">
                <div class="label">地址（中文）</div>
                <div class="muted"><%= @form.temple.contact_details["addressZh"].presence || "尚未設定" %></div>
              </div>
              <div class="derived-contact__item">
                <div class="label">地址（英文）</div>
                <div class="muted"><%= @form.temple.contact_details["addressEn"].presence || "尚未設定" %></div>
              </div>
              <div class="derived-contact__item">
                <div class="label">Plus Code</div>
                <div class="muted"><%= @form.temple.contact_details["plusCode"].presence || "自動帶入" %></div>
              </div>
            </div>
          </section>

          <section class="card form-card">
            <header>
              <h2><%= t("admin.temple_profile.sections.logistics.title") %></h2>
              <p><%= t("admin.temple_profile.sections.logistics.subtitle") %></p>
            </header>

            <div class="grid-2">
              <div class="field">
                <%= form.label :service_times_weekday, t("admin.temple_profile.fields.weekday_hours") %>
                <%= form.text_field :service_times_weekday,
                      name: "temple[service_times][weekday]",
                      value: @form.service_times["weekday"],
                      placeholder: t("admin.temple_profile.placeholders.weekday_hours") %>
              </div>
              <div class="field">
                <%= form.label :service_times_weekend, t("admin.temple_profile.fields.weekend_hours") %>
                <%= form.text_field :service_times_weekend,
                      name: "temple[service_times][weekend]",
                      value: @form.service_times["weekend"],
                      placeholder: t("admin.temple_profile.placeholders.weekend_hours") %>
              </div>
            </div>

            <div class="field">
              <%= form.label :service_times_notes, t("admin.temple_profile.fields.notes") %>
              <%= form.text_area :service_times_notes,
                    name: "temple[service_times][notes]",
                    value: @form.service_times["notes"],
                    rows: 2,
                    placeholder: t("admin.temple_profile.placeholders.notes") %>
            </div>

            <div class="field">
              <%= form.label :visit_info_transportation, t("admin.temple_profile.fields.transportation") %>
              <%= form.text_area :visit_info_transportation,
                    name: "temple[visit_info][transportation]",
                    value: @form.visit_info["transportation"],
                    rows: 3,
                    placeholder: t("admin.temple_profile.placeholders.transportation") %>
            </div>

            <div class="field">
              <%= form.label :visit_info_parking, t("admin.temple_profile.fields.parking") %>
              <%= form.text_area :visit_info_parking,
                    name: "temple[visit_info][parking]",
                    value: @form.visit_info["parking"],
                    rows: 3,
                    placeholder: t("admin.temple_profile.placeholders.parking") %>
            </div>
          </section>

        </div>

        <div class="form-actions form-actions--centered profile-form-actions">
          <%= form.submit t("admin.temple_profile.actions.save"), class: "btn btn-primary" %>
        </div>
      </section>
    </div>

    <div class="admin-stack__row admin-stack__row--hero" data-hero-images-section>
      <section class="card stack-item stack-item--xl stack-item--with-gutter card--hero-images">
        <section class="card form-card hero-image-card">
          <header class="hero-image-header">
            <div>
              <h2><%= t("admin.temple_profile.sections.hero_images.title") %></h2>
              <p class="muted"><%= t("admin.temple_profile.sections.hero_images.subtitle") %></p>
            </div>
            <p class="muted hero-image-fallback-hint"><%= t("admin.temple_profile.sections.hero_images.fallback_hint") %></p>
          </header>

          <div class="hero-image-grid">
            <% Temple::HERO_TABS.each do |tab| %>
              <div class="hero-image-item"
                data-hero-image-slot
                data-hero-tab="<%= tab %>">
                <div class="hero-image-preview-wrapper">
                  <% preview_url = hero_image_preview_for(form.object, tab) %>
                  <%= image_tag(preview_url,
                    alt: t("admin.temple_profile.hero_tabs.#{tab}"),
                    class: "hero-image-preview",
                    data: { hero_preview: true }) %>
                </div>
                <div class="hero-image-field">
                  <p class="form-label hero-image-label"><%= t("admin.temple_profile.hero_tabs.#{tab}") %></p>
                  <div class="hero-image-upload-controls">
                    <label class="btn btn-secondary hero-image-file-label">
                      <span><%= t("admin.temple_profile.sections.hero_images.choose_file") %></span>
                      <%= file_field_tag "hero_image_upload[#{tab}]",
                        accept: "image/*",
                        class: "hero-image-file-input" %>
                    </label>
                    <span class="hero-image-file-name" data-hero-file-name></span>
                  </div>

                  <div class="hero-image-status" data-hero-status></div>

                  <details class="hero-image-url-field">
                    <summary><%= t("admin.temple_profile.sections.hero_images.paste_url") %></summary>
                    <p class="muted"><%= t("admin.temple_profile.sections.hero_images.url_hint") %></p>
                    <%= url_field_tag "temple[hero_images][#{tab}]",
                      form.object.hero_images[tab],
                      placeholder: t("admin.temple_profile.placeholders.hero_image_url"),
                      class: "hero-image-url-input",
                      data: { hero_url_input: true } %>
                  </details>

                  <% if tab != "home" %>
                    <p class="muted hero-image-row-hint"><%= t("admin.temple_profile.sections.hero_images.row_hint") %></p>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </section>
      </section>
    </div>

    <div class="hero-floating-save" data-hero-floating-panel>
      <button type="submit"
        name="temple_profile_save_scope"
        value="hero_images"
        class="btn btn-primary">
        <%= t("admin.temple_profile.actions.save_hero_images", default: "Save hero images") %>
      </button>
      <p class="muted"><%= t("admin.temple_profile.sections.hero_images.save_hint", default: "Changes apply to every tab once you save.") %></p>
    </div>
  <% end %>
</div>

<script>
  (() => {
    const HERO_UPLOAD_I18N = {
      selected: "<%= j t("admin.temple_profile.sections.hero_images.selected_pending") %>"
    };

    const setStatus = (element, message, state = "muted") => {
      if (!element) return;
      element.textContent = message || "";
      element.dataset.state = state;
    };

    const bindHeroSlot = (slot) => {
      if (slot.dataset.heroUploaderBound === "true") return;
      slot.dataset.heroUploaderBound = "true";

      const fileInput = slot.querySelector(".hero-image-file-input");
      const preview = slot.querySelector(".hero-image-preview");
      const fileName = slot.querySelector("[data-hero-file-name]");
      const statusEl = slot.querySelector("[data-hero-status]");
      const heroTab = slot.dataset.heroTab;
      if (!fileInput || !heroTab) return;

      fileInput.addEventListener("change", () => {
        if (fileInput.files && fileInput.files.length > 0) {
          const file = fileInput.files[0];
          if (fileName) fileName.textContent = file.name;
          if (preview) {
            if (preview.dataset.objectUrl) URL.revokeObjectURL(preview.dataset.objectUrl);
            const objectUrl = URL.createObjectURL(file);
            preview.dataset.objectUrl = objectUrl;
            preview.src = objectUrl;
          }
          setStatus(statusEl, HERO_UPLOAD_I18N.selected, "muted");
        } else {
          if (fileName) fileName.textContent = "";
          setStatus(statusEl, "", "muted");
        }
      });
    };

    const initHeroImageUploads = () => {
      document.querySelectorAll("[data-hero-image-slot]").forEach(bindHeroSlot);
    };

    const ready = (fn) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fn);
      } else {
        fn();
      }
    };

    ready(initHeroImageUploads);
    document.addEventListener("turbo:load", initHeroImageUploads);
  })();

  (() => {
    const ready = (fn) => {
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", fn);
      } else {
        fn();
      }
    };

    const initFloatingHeroSave = () => {
      const panel = document.querySelector("[data-hero-floating-panel]");
      const section = document.querySelector("[data-hero-images-section]");
      const sidebar = document.querySelector(".admin-sidebar");
      if (!panel) return;

      const syncPosition = () => {
        if (!sidebar) return;
        const rect = sidebar.getBoundingClientRect();
        const width = rect.width * 0.85;
        panel.style.left = `${rect.left}px`;
        panel.style.width = `${width}px`;
      };

      syncPosition();
      window.addEventListener("resize", syncPosition);

      if (!section || typeof IntersectionObserver === "undefined") {
        panel.classList.add("is-visible");
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        const entry = entries[0];
        if (!entry) return;
        if (entry.isIntersecting) {
          panel.classList.add("is-visible");
        } else {
          panel.classList.remove("is-visible");
        }
      }, { threshold: 0, rootMargin: "0px" });

      observer.observe(section);
    };

    ready(initFloatingHeroSave);
    document.addEventListener("turbo:load", initFloatingHeroSave);
  })();
</script>
