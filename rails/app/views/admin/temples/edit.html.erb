<section class="hero">
  <div class="hero-text">
    <p class="eyebrow">Temple profile</p>
    <h1>Update site copy</h1>
    <p>These fields power the public site hero, footer, and contact sections.</p>
  </div>
</section>

<section class="card">
  <header>
    <h2>Basic details</h2>
    <p>Displayed in the Vue header/footer.</p>
  </header>

  <%= form_with model: @form, url: admin_temple_profile_path, method: :patch, class: "form-stack" do |form| %>
    <div class="field">
      <%= form.label :name, "Temple name" %>
      <%= form.text_field :name, required: true, placeholder: "例：竹南鎮聖福宮" %>
    </div>

    <div class="field">
      <%= form.label :tagline %>
      <%= form.text_field :tagline, placeholder: "例：清淨・莊嚴・在地信仰" %>
    </div>

    <div class="field">
      <%= form.label :hero_copy, "Homepage hero copy" %>
      <%= form.text_area :hero_copy, rows: 3, placeholder: "用一句話說明宗旨、服務、交通提示。" %>
    </div>

    <div class="field">
      <%= form.label :primary_image_url, "Hero image URL" %>
      <%= form.url_field :primary_image_url, placeholder: "https://…" %>
    </div>

    <hr />

    <header>
      <h2>Contact information</h2>
      <p>Shown on the contact page + footer.</p>
    </header>

    <div class="grid-2">
      <div class="field">
        <%= form.label :contact_addressZh, "Address (ZH)" %>
        <%= form.text_field :contact_addressZh, name: "temple[contact][addressZh]", value: @form.contact["addressZh"], placeholder: "例：苗栗縣竹南鎮公教路 136 號" %>
      </div>
      <div class="field">
        <%= form.label :contact_addressEn, "Address (EN)" %>
        <%= form.text_field :contact_addressEn, name: "temple[contact][addressEn]", value: @form.contact["addressEn"], placeholder: "例：No. 136, Gongjiao Rd, Zhunan Township..." %>
      </div>
    </div>

    <div class="grid-2">
      <div class="field">
        <%= form.label :contact_phone, "Phone" %>
        <%= form.text_field :contact_phone, name: "temple[contact][phone]", value: @form.contact["phone"], placeholder: "例：03-747-2826" %>
      </div>
      <div class="field">
        <%= form.label :contact_plusCode, "Plus Code" %>
        <%= form.text_field :contact_plusCode, name: "temple[contact][plusCode]", value: @form.contact["plusCode"], placeholder: "例：MVWF+54 竹南鎮" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :contact_mapUrl, "Map URL" %>
      <%= form.url_field :contact_mapUrl, name: "temple[contact][mapUrl]", value: @form.contact["mapUrl"], placeholder: "https://maps.google.com/?q=..." %>
    </div>

    <hr />

    <header>
      <h2>Service schedule</h2>
      <p>Displayed alongside the contact info on the Vue + Expo clients.</p>
    </header>

    <div class="grid-2">
      <div class="field">
        <%= form.label :service_times_weekday, "Weekday hours" %>
        <%= form.text_field :service_times_weekday, name: "temple[service_times][weekday]", value: @form.service_times["weekday"], placeholder: "例：08:00 – 17:00" %>
      </div>
      <div class="field">
        <%= form.label :service_times_weekend, "Weekend hours" %>
        <%= form.text_field :service_times_weekend, name: "temple[service_times][weekend]", value: @form.service_times["weekend"], placeholder: "例：07:30 – 18:00" %>
      </div>
    </div>

    <div class="field">
      <%= form.label :service_times_notes, "Notes" %>
      <%= form.text_area :service_times_notes, name: "temple[service_times][notes]", value: @form.service_times["notes"], rows: 2, placeholder: "例：農曆初一、十五延長開放。" %>
    </div>

    <div class="actions">
      <%= form.submit "Save profile", class: "btn primary" %>
      <%= link_to "Cancel", admin_dashboard_path, class: "btn secondary" %>
    </div>
  <% end %>
</section>
