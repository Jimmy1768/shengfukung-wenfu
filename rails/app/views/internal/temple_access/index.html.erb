<div class="internal-access-page">
  <section class="dashboard-hero">
    <div>
      <p class="eyebrow"><%= t("admin.internal.temple_access.index.eyebrow") %></p>
      <h1><%= t("admin.internal.temple_access.index.title") %></h1>
      <p><%= t("admin.internal.temple_access.index.subtitle") %></p>
    </div>
  </section>

  <section class="admin-card">
    <header class="section-header">
      <div>
        <p class="eyebrow"><%= t("admin.internal.temple_access.index.operator_eyebrow") %></p>
        <h2><%= current_admin.email %></h2>
        <p><%= t("admin.internal.temple_access.index.operator_email", email: internal_operator_email) %></p>
      </div>
    </header>

    <div class="table-shell">
      <table class="data-table internal-access-table internal-access-table--temples">
        <thead>
          <tr>
            <th><%= t("admin.internal.temple_access.index.table.temple") %></th>
            <th><%= t("admin.internal.temple_access.index.table.slug") %></th>
            <th><%= t("admin.internal.temple_access.index.table.published") %></th>
            <th><%= t("admin.internal.temple_access.index.table.access_state") %></th>
            <th><%= t("admin.internal.temple_access.index.table.role") %></th>
            <th><%= t("admin.internal.temple_access.index.table.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @temples.each do |temple| %>
            <% membership = @memberships_by_temple_id[temple.id] %>
            <tr>
              <td><%= temple.name %></td>
              <td><code><%= temple.slug %></code></td>
              <td><%= temple.published? ? t("admin.internal.shared.yes") : t("admin.internal.shared.no") %></td>
              <td><%= membership.present? ? t("admin.internal.temple_access.index.access.has_access") : t("admin.internal.temple_access.index.access.no_access") %></td>
              <td>
                <% role_label = case membership&.role
                   when "admin" then t("admin.internal.shared.roles.admin")
                   when "owner" then t("admin.internal.shared.roles.owner")
                   else t("admin.internal.shared.none")
                   end %>
                <%= role_label %>
              </td>
              <td>
                <div class="internal-access-actions">
                  <div class="internal-access-actions__primary">
                    <% unless membership&.role == "owner" %>
                      <%= button_to t("admin.internal.temple_access.index.actions.grant_owner"),
                        internal_grant_temple_access_path(temple_id: temple.id, role: "owner"),
                        method: :post,
                        class: "btn btn-primary btn-small" %>
                    <% end %>
                    <% unless membership&.role == "admin" %>
                      <%= button_to t("admin.internal.temple_access.index.actions.grant_admin"),
                        internal_grant_temple_access_path(temple_id: temple.id, role: "admin"),
                        method: :post,
                        class: "btn btn-secondary btn-small" %>
                    <% end %>
                    <%= link_to t("admin.internal.temple_access.index.actions.temple_admins"),
                      internal_temple_access_temple_path(temple_id: temple.id),
                      class: "btn btn-secondary btn-small" %>
                  </div>
                  <div class="internal-access-actions__secondary">
                    <% if membership.present? %>
                      <%= button_to t("admin.internal.temple_access.index.actions.revoke"),
                        internal_revoke_temple_access_path(temple_id: temple.id),
                        method: :delete,
                        class: "btn btn-ghost btn-small",
                        form: {
                          data: {
                            confirm: t("admin.internal.temple_access.index.actions.revoke_confirm", temple: temple.name)
                          }
                        } %>
                    <% end %>
                  </div>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
