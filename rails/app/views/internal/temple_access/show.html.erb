<div class="internal-access-page">
  <section class="dashboard-hero">
    <div>
      <p class="eyebrow"><%= t("admin.internal.temple_access.show.eyebrow") %></p>
      <h1><%= @temple.name %></h1>
      <p><%= t("admin.internal.temple_access.show.subtitle_html", slug: @temple.slug) %></p>
    </div>
  </section>

  <section class="admin-card">
    <header class="section-header">
      <div>
        <p class="eyebrow"><%= t("admin.internal.temple_access.show.admins_eyebrow") %></p>
        <h2><%= t("admin.internal.temple_access.show.current_access_list") %></h2>
        <p><%= t("admin.internal.temple_access.show.current_access_hint") %></p>
      </div>
      <div>
        <%= link_to t("admin.internal.temple_access.show.back"), internal_temple_access_path, class: "btn btn-ghost" %>
      </div>
    </header>

    <div class="table-shell">
      <table class="data-table internal-access-table internal-access-table--admins">
        <thead>
          <tr>
            <th><%= t("admin.internal.temple_access.show.table.name") %></th>
            <th><%= t("admin.internal.temple_access.show.table.email") %></th>
            <th><%= t("admin.internal.temple_access.show.table.role") %></th>
            <th><%= t("admin.internal.temple_access.show.table.manage_permissions") %></th>
            <th><%= t("admin.internal.temple_access.show.table.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @temple_admin_memberships.each do |membership| %>
            <% admin_account = membership.admin_account %>
            <% user = admin_account.user %>
            <% permission = admin_account.permissions_for(@temple) %>
            <tr>
              <td><%= user.english_name %></td>
              <td><%= user.email %></td>
              <td>
                <% role_label = case membership.role
                   when "staff" then t("admin.internal.shared.roles.admin")
                   when "owner" then t("admin.internal.shared.roles.owner")
                   when "support" then t("admin.internal.shared.roles.support")
                   else membership.role.to_s.humanize
                   end %>
                <%= role_label %>
              </td>
              <td><%= permission.allow?(:manage_permissions) ? t("admin.internal.shared.yes") : t("admin.internal.shared.no") %></td>
              <td>
                <% if membership.role == "owner" %>
                  <span><%= t("admin.internal.temple_access.show.actions.already_owner") %></span>
                <% else %>
                  <%= button_to t("admin.internal.temple_access.show.actions.make_owner"),
                    internal_promote_temple_access_owner_path(temple_id: @temple.id, admin_account_id: admin_account.id),
                    method: :post,
                    class: "btn btn-primary btn-small",
                    form: {
                      data: {
                        confirm: t("admin.internal.temple_access.show.actions.make_owner_confirm", email: user.email, temple: @temple.name)
                      }
                    } %>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @temple_admin_memberships.empty? %>
            <tr>
              <td colspan="5"><%= t("admin.internal.temple_access.show.empty") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
