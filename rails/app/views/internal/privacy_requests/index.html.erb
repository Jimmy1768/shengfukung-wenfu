<div class="internal-access-page">
  <section class="dashboard-hero">
    <div>
      <p class="eyebrow"><%= t("admin.internal.privacy_requests.index.eyebrow") %></p>
      <h1><%= t("admin.internal.privacy_requests.index.title") %></h1>
      <p><%= t("admin.internal.privacy_requests.index.subtitle") %></p>
    </div>
  </section>

  <section class="admin-card">
    <header class="section-header">
      <div>
        <p class="eyebrow"><%= t("admin.internal.privacy_requests.index.filters_eyebrow") %></p>
        <h2><%= t("admin.internal.privacy_requests.index.filters_title") %></h2>
      </div>
    </header>

    <div class="admin-filter-bar">
      <%= link_to t("admin.internal.privacy_requests.index.filters.all"), internal_privacy_requests_path, class: "pill-link #{@status_filter.blank? ? 'active' : ''}" %>
      <% PrivacyRequest::STATUSES.each do |status| %>
        <%= link_to t("admin.internal.privacy_requests.shared.statuses.#{status}"), internal_privacy_requests_path(status: status), class: "pill-link #{@status_filter == status ? 'active' : ''}" %>
      <% end %>
    </div>

    <div class="table-shell">
      <table class="data-table internal-access-table">
        <thead>
          <tr>
            <th><%= t("admin.internal.privacy_requests.index.table.requested_at") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.user") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.email") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.type") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.status") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.account_status") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.operator") %></th>
            <th><%= t("admin.internal.privacy_requests.index.table.actions") %></th>
          </tr>
        </thead>
        <tbody>
          <% @privacy_requests.each do |request| %>
            <% user = request.user %>
            <tr>
              <td><%= l(request.requested_at, format: :short) rescue request.requested_at.strftime("%Y/%m/%d") %></td>
              <td><%= user.native_name.presence || user.english_name.presence || t("admin.internal.shared.none") %></td>
              <td><%= user.email %></td>
              <td><%= t("admin.internal.privacy_requests.shared.request_types.#{request.request_type}", default: request.request_type.humanize) %></td>
              <td><%= t("admin.internal.privacy_requests.shared.statuses.#{request.status}", default: request.status.humanize) %></td>
              <td><%= user.closed_account? ? t("admin.internal.privacy_requests.shared.account_statuses.closed") : t("admin.internal.privacy_requests.shared.account_statuses.active") %></td>
              <td><%= request.operator_user&.email || t("admin.internal.shared.none") %></td>
              <td>
                <div class="internal-access-actions">
                  <% if request.status == "pending" %>
                    <%= button_to t("admin.internal.privacy_requests.index.actions.approve"),
                      transition_internal_privacy_request_path(request, next_status: "approved", status: @status_filter),
                      method: :post,
                      class: "btn btn-secondary btn-small" %>
                    <%= button_to t("admin.internal.privacy_requests.index.actions.reject"),
                      transition_internal_privacy_request_path(request, next_status: "rejected", status: @status_filter),
                      method: :post,
                      class: "btn btn-ghost btn-small",
                      form: { data: { confirm: t("admin.internal.privacy_requests.index.actions.reject_confirm") } } %>
                    <%= button_to t("admin.internal.privacy_requests.index.actions.complete"),
                      transition_internal_privacy_request_path(request, next_status: "completed", status: @status_filter),
                      method: :post,
                      class: "btn btn-primary btn-small" %>
                  <% elsif request.status == "approved" %>
                    <%= button_to t("admin.internal.privacy_requests.index.actions.complete"),
                      transition_internal_privacy_request_path(request, next_status: "completed", status: @status_filter),
                      method: :post,
                      class: "btn btn-primary btn-small" %>
                    <%= button_to t("admin.internal.privacy_requests.index.actions.reject"),
                      transition_internal_privacy_request_path(request, next_status: "rejected", status: @status_filter),
                      method: :post,
                      class: "btn btn-ghost btn-small",
                      form: { data: { confirm: t("admin.internal.privacy_requests.index.actions.reject_confirm") } } %>
                  <% else %>
                    <% if request.request_type == "data_export" && request.metadata.to_h["data_export_payload_id"].present? %>
                      <%= link_to t("admin.internal.privacy_requests.index.actions.download_export"),
                        export_internal_privacy_request_path(request),
                        class: "btn btn-secondary btn-small" %>
                    <% else %>
                      <span class="muted"><%= t("admin.internal.privacy_requests.index.actions.no_actions") %></span>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @privacy_requests.empty? %>
      <p class="muted"><%= t("admin.internal.privacy_requests.index.empty") %></p>
    <% end %>
  </section>
</div>
